@model IEnumerable<dynamic>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Training Assignments";
    var studentRole = ViewBag.StudentRole as string ?? "All";
    var noWave = ViewBag.NoWave as bool? ?? false;
}

<div class="max-w-6xl mx-auto px-6 py-12">
    <!-- Header -->
    <div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-xs font-black text-brand-600 uppercase tracking-[0.3em] mb-2">Training Academy</h2>
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Continuous Assignments & Assessments</h1>
            <p class="text-sm text-slate-500 mt-1">View and solve training assignments assigned to your batch</p>
        </div>

        @if (!noWave)
        {
            <div class="bg-indigo-50 border border-indigo-100 rounded-2xl px-6 py-4 flex items-center gap-4">
                <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white text-lg">
                    <i class="fas fa-water"></i>
                </div>
                <div>
                    <span class="text-[9px] font-bold text-indigo-400 uppercase tracking-widest leading-none">Active Batch</span>
                    <p class="text-sm font-black text-indigo-900 leading-tight">@ViewBag.WaveName</p>
                    <span class="px-1.5 py-0.5 rounded text-[8px] font-black uppercase tracking-wider bg-indigo-100 text-indigo-700">@studentRole</span>
                </div>
            </div>
        }
    </div>

    @if (noWave)
    {
        <div class="bg-white border border-slate-200 rounded-[32px] p-12 text-center shadow-sm max-w-xl mx-auto">
            <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center text-slate-400 shadow-inner mx-auto mb-6">
                <i class="fas fa-exclamation-triangle text-2xl"></i>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">You have not been assigned to a training batch yet</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Please contact the training department or HR administrator to assign you to the active training batch so you can view and solve your assignments.</p>
        </div>
    }
    else if (!Model.Any())
    {
        <div class="bg-white border border-slate-200 rounded-[32px] p-12 text-center shadow-sm max-w-xl mx-auto">
            <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center text-slate-400 shadow-inner mx-auto mb-6">
                <i class="fas fa-clipboard-list text-2xl"></i>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">No assignments available currently</h3>
            <p class="text-sm text-slate-500 leading-relaxed">There are no scheduled or active assignments in your current training wave at this time. Check back later.</p>
        </div>
    }
    else
    {
        <!-- Assignments Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var a in Model)
            {
                var now = DateTime.Now;
                bool isExpired = now > (DateTime)a.ScheduledEndTime;
                bool isUpcoming = now < (DateTime)a.ScheduledStartTime;
                bool isCurrent = !isExpired && !isUpcoming;
                
                decimal maxScore = studentRole == "Pharmacist" ? (decimal)a.PharmacistMaxScore : (decimal)a.AssistantMaxScore;

                <div class="bg-white border border-slate-200 rounded-[32px] p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group relative overflow-hidden">
                    @if (isCurrent && a.AttemptStatus != "Completed")
                    {
                        <div class="absolute top-0 right-0 h-1.5 w-full bg-brand-500"></div>
                    }
                    
                    <div>
                        <!-- Title & Status -->
                        <div class="flex justify-between items-start mb-6">
                            <div>
                                <h3 class="text-lg font-black text-slate-900 group-hover:text-brand-600 transition-colors mb-1">@a.Title</h3>
                                <div class="flex flex-wrap gap-2">
                                    <span class="text-[10px] font-bold text-slate-400">@(((DateTime)a.CreatedAt).ToString("dd MMM yyyy"))</span>
                                </div>
                            </div>

                            <!-- Badges -->
                            <div>
                                @if (a.AttemptStatus == "Completed")
                                {
                                    <span class="px-3 py-1 rounded-xl text-[10px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-100 flex items-center gap-1.5">
                                        <i class="fas fa-check-circle"></i> Completed
                                    </span>
                                }
                                else if (a.AttemptStatus == "InProgress")
                                {
                                    <span class="px-3 py-1 rounded-xl text-[10px] font-black uppercase bg-amber-50 text-amber-600 border border-amber-100 flex items-center gap-1.5">
                                        <i class="fas fa-spinner fa-spin"></i> In Progress
                                    </span>
                                }
                                else if (isExpired)
                                {
                                    <span class="px-3 py-1 rounded-xl text-[10px] font-black uppercase bg-rose-50 text-rose-600 border border-rose-100 flex items-center gap-1.5">
                                        <i class="fas fa-hourglass-end"></i> Expired
                                    </span>
                                }
                                else if (isUpcoming)
                                {
                                    <span class="px-3 py-1 rounded-xl text-[10px] font-black uppercase bg-slate-50 text-slate-500 border border-slate-100 flex items-center gap-1.5">
                                        <i class="fas fa-calendar-alt"></i> Upcoming
                                    </span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 rounded-xl text-[10px] font-black uppercase bg-blue-50 text-blue-600 border border-blue-100 flex items-center gap-1.5 animate-pulse">
                                        <i class="fas fa-star"></i> Available Now
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Info Grid -->
                        <div class="grid grid-cols-2 gap-4 py-4 my-4 border-y border-slate-50">
                            <div>
                                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block mb-0.5">Maximum Points</span>
                                <span class="text-sm font-black text-slate-700 font-mono">@maxScore.ToString("0.##") Pts</span>
                            </div>
                            <div>
                                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block mb-0.5">Your Grade</span>
                                <span class="text-sm font-black @(a.AttemptStatus == "Completed" ? "text-brand-600" : "text-slate-400") font-mono">
                                    @(a.AttemptStatus == "Completed" ? $"{((decimal)a.AttemptScore).ToString("0.##")} Pts" : "--")
                                </span>
                            </div>
                        </div>

                        <!-- Date range -->
                        <div class="flex items-center gap-2.5 text-xs text-slate-500 font-medium mb-8">
                            <i class="far fa-clock text-slate-400"></i>
                            <span>
                                From: @(((DateTime)a.ScheduledStartTime).ToString("dd/MM hh:mm tt")) <br/>
                                To: @(((DateTime)a.ScheduledEndTime).ToString("dd/MM hh:mm tt"))
                            </span>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <div>
                        @if (a.AttemptStatus == "Completed")
                        {
                            <a href="@Url.Action("Result", "Assignments", new { id = a.AttemptId })" class="w-full bg-slate-50 hover:bg-slate-100 text-slate-700 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-2 border border-slate-200/50">
                                <i class="fas fa-eye text-xs"></i> View Grade Details
                            </a>
                        }
                        else if (isUpcoming)
                        {
                            <button disabled class="w-full bg-slate-50 text-slate-300 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-widest flex items-center justify-center gap-2 border border-slate-100 cursor-not-allowed">
                                <i class="fas fa-lock text-xs"></i> Not available before start time
                            </button>
                        }
                        else if (isExpired)
                        {
                            <button disabled class="w-full bg-slate-50 text-slate-300 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-widest flex items-center justify-center gap-2 border border-slate-100 cursor-not-allowed">
                                <i class="fas fa-times-circle text-xs"></i> Assignment submission time has expired
                            </button>
                        }
                        else
                        {
                            string btnText = a.AttemptStatus == "InProgress" ? "Resume Assignment" : "Start Assignment";
                            string btnIcon = a.AttemptStatus == "InProgress" ? "fa-play" : "fa-edit";
                            
                            <a href="@Url.Action("Take", "Assignments", new { id = a.Id })" class="w-full bg-brand-600 hover:bg-brand-700 text-white py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-brand-600/10 transition-all flex items-center justify-center gap-2">
                                <i class="fas @btnIcon text-xs"></i> @btnText
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
