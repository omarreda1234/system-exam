@{
    ViewData["Title"] = "Neural Outcome Report";
    var attemptId = (Context.Request.Query["attemptId"].FirstOrDefault() ?? "0");
}

<div class="max-w-4xl mx-auto py-12 px-6">
    <!-- Header -->
    <div class="text-center mb-16 relative">
        <div class="absolute inset-0 flex items-center justify-center -z-10">
            <div class="w-64 h-64 bg-brand-500/10 rounded-full blur-[100px] animate-pulse"></div>
        </div>
        <div class="inline-flex items-center justify-center w-20 h-20 bg-brand-500/10 rounded-full border border-brand-500/20 mb-6 shadow-[0_0_30px_rgba(6,182,212,0.2)]">
            <svg class="w-10 h-10 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
        </div>
        <h2 class="text-4xl font-black text-white italic tracking-tighter uppercase mb-2">Diagnostic Summary</h2>
        <p class="text-[10px] font-mono font-bold text-brand-500 uppercase tracking-[0.4em]">Node Protocol Analysis: #@attemptId</p>
    </div>

    <!-- Container -->
    <div id="resultContainer" class="bg-slate-900/40 backdrop-blur-xl border border-white/5 rounded-[40px] shadow-2xl p-8 md:p-12 min-h-[400px] flex items-center justify-center">
        <div class="flex flex-col items-center gap-6">
            <div class="w-12 h-12 border-2 border-brand-500/20 border-t-brand-500 rounded-full animate-spin"></div>
            <p class="text-[10px] font-mono font-bold text-slate-500 uppercase tracking-widest animate-pulse">Syncing Telemetry...</p>
        </div>
    </div>

    <!-- Navigation -->
    <div class="mt-12 text-center">
        <a asp-action="StudentExams" asp-controller="Home" class="inline-flex items-center gap-3 bg-white/5 hover:bg-white/10 text-white px-8 py-4 rounded-2xl font-black italic uppercase text-xs tracking-widest border border-white/5 transition-all active:scale-95 group">
            <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7 7-7m8 14l-7-7 7-7"/></svg>
            Terminal Return
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(function(){
            var attemptId = '@attemptId';
            $('#resultContainer').load('@Url.Action("GetResultReport", "Admin")', { attemptId: attemptId }, function(){
                $(this).hide().fadeIn(500);
            });
        });
    </script>
}
