@model Exam.DTOs.adminExamDto
@{
    ViewBag.Title = "Edit Exam Details";
    Layout = "_DashboardLayout";
    var examTypes = ViewBag.ExamTypes as IEnumerable<Exam.DTOs.ExamTypeDto> ?? Enumerable.Empty<Exam.DTOs.ExamTypeDto>();
    var categories = ViewBag.Categories as IEnumerable<Exam.DTOs.CategoryDto> ?? Enumerable.Empty<Exam.DTOs.CategoryDto>();
    var questionTypeOptionsHtml = string.Join("", categories.Select(t => $"<option value=\"{t.Id}\">{System.Net.WebUtility.HtmlEncode(t.CategoryName)}</option>"));
}

<div class="max-w-5xl mx-auto py-12 px-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-12">
        <div class="flex items-center gap-6">
            <div class="w-16 h-16 bg-brand-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-brand-500/20">
                <i class="fas fa-sliders-h text-2xl"></i>
            </div>
            <div>
                <h1 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white">Edit Exam</h1>
                <p class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mt-1">Updating Examination Configuration: ID-@Model.Id.ToString("D4")</p>
            </div>
        </div>
        
        <button type="button" id="editQuestionsBtn" class="bg-brand-600 hover:bg-brand-700 text-white px-8 py-3.5 rounded-2xl font-black uppercase text-xs tracking-widest shadow-lg transition-all active:scale-95 flex items-center gap-3">
            <i class="fas fa-layer-group"></i>
            Manage Questions
        </button>
    </div>

    <form asp-action="Edit" method="post" id="editExamForm" class="space-y-8">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Configuration Card -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] shadow-sm overflow-hidden p-10">
            <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-8">Basic Information</h3>
            
            <div class="space-y-8">
                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 px-1">Exam Title</label>
                    <input asp-for="Title" class="block w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl px-6 py-4 text-lg font-bold text-slate-900 dark:text-white focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 outline-none transition-all" />
                    <span asp-validation-for="Title" class="text-xs text-rose-500 mt-2 block font-medium"></span>
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 px-1">Exam Description / Instructions</label>
                    <textarea asp-for="Description" rows="3" class="block w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 text-sm font-medium text-slate-700 dark:text-slate-300 focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 outline-none transition-all resize-none"></textarea>
                    <span asp-validation-for="Description" class="text-xs text-rose-500 mt-2 block font-medium"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-slate-50 dark:bg-slate-950/50 p-8 rounded-[24px] border border-slate-100 dark:border-slate-800">
                    <div class="space-y-6">
                        <div>
                             <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 px-1">Start Time</label>
                             <input asp-for="StartTime" type="datetime-local" class="block w-full bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-bold focus:border-brand-500 outline-none" value="@(Model.StartTime.ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                        <div>
                             <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 px-1">End Time</label>
                             <input asp-for="EndTime" type="datetime-local" class="block w-full bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-bold focus:border-brand-500 outline-none" value="@(Model.EndTime.ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 h-fit">
                        <div class="col-span-2">
                             <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 px-1">Exam Type</label>
                             <select asp-for="ExamTypeId" id="ExamTypeId" class="block w-full bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-bold focus:border-brand-500 outline-none">
                                <option value="0">SELECT CATEGORY</option>
                                @foreach (var t in examTypes) {
                                    <option value="@t.Id" data-type-name="@t.TypeName" selected="@(t.Id == Model.ExamTypeId)">@t.TypeName.ToUpper()</option>
                                }
                             </select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 px-1">Duration (M)</label>
                            <input asp-for="DurationInMinutes" class="block w-full bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-black text-brand-600 dark:text-brand-400 focus:border-brand-500 outline-none" />
                        </div>
                        <div id="passGradeWrapper">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2 px-1">Passing Grade %</label>
                            <input asp-for="PassPercentage" class="block w-full bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-black text-brand-600 dark:text-brand-400 focus:border-brand-500 outline-none" />
                        </div>
                        <div id="totalQuestionsWrapper" class="col-span-2 mt-2" style="display:none;">
                            <label class="block text-[10px] font-black text-indigo-500 uppercase tracking-widest mb-2">Total Dynamic Questions</label>
                            <input asp-for="TotalQuestionsToShow" type="hidden" />
                            <div class="bg-indigo-50/50 dark:bg-slate-900 border border-indigo-100 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-black text-indigo-600 mb-2">
                                <span id="displayTotal">0</span> Questions Total
                            </div>
                            
                            <!-- Role Specific Summary -->
                            <div id="roleSummary" class="flex gap-4 mt-3">
                                <div class="bg-indigo-100/50 dark:bg-indigo-500/10 px-3 py-1.5 rounded-lg border border-indigo-100 dark:border-indigo-500/20">
                                    <span class="text-[8px] font-black text-indigo-400 uppercase block leading-none mb-1">Pharmacist</span>
                                    <div class="flex items-center gap-2">
                                        <div><span id="sumPharmacist" class="text-xs font-black text-indigo-600">0</span> <span class="text-[8px] font-bold text-indigo-400">Qs</span></div>
                                        <div class="w-px h-3 bg-indigo-200 dark:bg-indigo-500/30"></div>
                                        <div><span id="ptsPharmacist" class="text-xs font-black text-indigo-600">0</span> <span class="text-[8px] font-bold text-indigo-400">Pts</span></div>
                                    </div>
                                </div>
                                <div class="bg-emerald-100/50 dark:bg-emerald-500/10 px-3 py-1.5 rounded-lg border border-emerald-100 dark:border-emerald-500/20">
                                    <span class="text-[8px] font-black text-emerald-400 uppercase block leading-none mb-1">Assistant</span>
                                    <div class="flex items-center gap-2">
                                        <div><span id="sumAssistant" class="text-xs font-black text-emerald-600">0</span> <span class="text-[8px] font-bold text-emerald-400">Qs</span></div>
                                        <div class="w-px h-3 bg-emerald-200 dark:bg-emerald-500/30"></div>
                                        <div><span id="ptsAssistant" class="text-xs font-black text-emerald-600">0</span> <span class="text-[8px] font-bold text-emerald-400">Pts</span></div>
                                    </div>
                                </div>
                            </div>

                            <p class="text-[9px] text-slate-400 mt-2 uppercase font-bold italic">The system will dynamically pick questions based on the candidate's role.</p>
                        </div>
                        <div class="col-span-2 mt-4 flex flex-col md:flex-row items-start md:items-center gap-4">
                            <!-- Question Overview -->
                            <div class="flex-1 w-full flex items-center gap-4 bg-amber-50/50 dark:bg-amber-900/10 p-4 rounded-2xl border border-amber-100 dark:border-amber-900/30">
                                <div class="relative inline-block w-12 h-6 transition duration-200 ease-in">
                                    <input type="checkbox" asp-for="ShowQuestionOverview" id="ShowQuestionOverview" class="peer absolute w-6 h-6 opacity-0 z-10 cursor-pointer" />
                                    <div class="w-12 h-6 bg-slate-300 dark:bg-slate-700 rounded-full peer-checked:bg-brand-600 transition-colors"></div>
                                    <div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-6 shadow-sm"></div>
                                </div>
                                <div class="flex flex-col">
                                    <label for="ShowQuestionOverview" class="text-[10px] font-black text-slate-700 dark:text-slate-200 uppercase tracking-wider cursor-pointer">Question Overview & Back Navigation</label>
                                    <span class="text-[9px] font-medium text-slate-500 italic">If disabled, students can only move forward and cannot see the question list.</span>
                                </div>
                            </div>

                            <!-- Is Final Exam -->
                            <div class="flex-1 w-full flex items-center gap-4 bg-rose-50/50 dark:bg-rose-900/10 p-4 rounded-2xl border border-rose-100 dark:border-rose-900/30">
                                <div class="relative inline-block w-12 h-6 transition duration-200 ease-in">
                                    <input type="checkbox" asp-for="IsFinalExam" id="IsFinalExam" class="peer absolute w-6 h-6 opacity-0 z-10 cursor-pointer" />
                                    <div class="w-12 h-6 bg-slate-300 dark:bg-slate-700 rounded-full peer-checked:bg-rose-600 transition-colors"></div>
                                    <div class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full transition-transform peer-checked:translate-x-6 shadow-sm"></div>
                                </div>
                                <div class="flex flex-col">
                                    <label for="IsFinalExam" class="text-[10px] font-black text-slate-700 dark:text-slate-200 uppercase tracking-wider cursor-pointer">Mark as Final Exam</label>
                                    <span class="text-[9px] font-medium text-slate-500 italic">Enable this to apply Final Exam certification rules.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dynamic Rules Section (Blueprint Console) -->
                <div id="blueprintSection" class="bg-indigo-50/50 dark:bg-indigo-950/10 border border-indigo-100 dark:border-indigo-900/50 rounded-[32px] p-8 space-y-6" style="display:none;">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-xs font-black text-indigo-500 uppercase tracking-[0.2em] mb-1">Blueprint Console</h3>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Define rules for dynamic question injection</p>
                        </div>
                        <button type="button" id="addRuleBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2 shadow-lg shadow-indigo-500/20">
                            <i class="fas fa-magic"></i> Add Smart Injection Rule
                        </button>
                    </div>
                    
                    <div id="rulesContainer" class="grid grid-cols-1 gap-4">
                        @if (Model.GenerationRules != null)
                        {
                            for (int i = 0; i < Model.GenerationRules.Count; i++)
                            {
                                <div class="rule-row grid grid-cols-1 md:grid-cols-6 gap-3 bg-white dark:bg-slate-900 border border-indigo-100 dark:border-indigo-900/30 p-4 rounded-2xl animate-in fade-in zoom-in duration-300">
                                    <div class="col-span-1 md:col-span-1">
                                        <label class="block text-[8px] font-black uppercase text-indigo-400 mb-1">Injected Category</label>
                                        <select name="GenerationRules[@i].CategoryId" required class="rule-cat-selector w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs font-bold outline-none">
                                            @foreach (var cat in categories)
                                            {
                                                <option value="@cat.Id" selected="@(cat.Id == Model.GenerationRules[i].CategoryId)">@cat.CategoryName.ToUpper()</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-span-1 md:col-span-1">
                                        <label class="block text-[8px] font-black uppercase text-indigo-400 mb-1">Specific Topic</label>
                                        <select name="GenerationRules[@i].TopicId" class="rule-topic-selector w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs font-bold outline-none" data-selected-id="@Model.GenerationRules[i].TopicId">
                                            <option value="">ALL TOPICS</option>
                                        </select>
                                    </div>
                                    <div class="col-span-1">
                                        <label class="block text-[8px] font-black uppercase text-indigo-400 mb-1">Apply To</label>
                                        <select name="GenerationRules[@i].TargetRole" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs font-bold outline-none">
                                            <option value="All" selected='@(Model.GenerationRules[i].TargetRole == "All")'>ALL ROLES</option>
                                            <option value="Pharmacist" selected='@(Model.GenerationRules[i].TargetRole == "Pharmacist")'>PHARMACISTS ONLY</option>
                                            <option value="Assistant" selected='@(Model.GenerationRules[i].TargetRole == "Assistant")'>ASSISTANTS ONLY</option>
                                        </select>
                                    </div>
                                    <div class="col-span-1 md:col-span-2">
                                        <div class="grid grid-cols-3 gap-1">
                                            <div>
                                                <label class="block text-[7px] font-black text-emerald-500 uppercase">Easy</label>
                                                <input type="number" name="GenerationRules[@i].EasyCount" value="@Model.GenerationRules[i].EasyCount" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-2 text-xs font-bold rounded" />
                                            </div>
                                            <div>
                                                <label class="block text-[7px] font-black text-amber-500 uppercase">Med</label>
                                                <input type="number" name="GenerationRules[@i].MediumCount" value="@Model.GenerationRules[i].MediumCount" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-2 text-xs font-bold rounded" />
                                            </div>
                                            <div>
                                                <label class="block text-[7px] font-black text-rose-500 uppercase">Hard</label>
                                                <input type="number" name="GenerationRules[@i].HardCount" value="@Model.GenerationRules[i].HardCount" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-2 text-xs font-bold rounded" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-span-1 md:col-span-1 flex items-center justify-end relative">
                                         <button type="button" class="remove-rule absolute -right-2 -top-2 w-6 h-6 bg-rose-500 text-white rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-110 active:scale-90"><i class="fas fa-times text-[10px]"></i></button>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="p-6 bg-white dark:bg-slate-900 rounded-2xl border border-indigo-100 dark:border-indigo-900/30 flex items-center justify-between">
                        <div>
                             <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block">Grading Logic</span>
                             <span id="gradingStatus" class="text-xs font-bold text-slate-600 dark:text-slate-300">Non-Evaluative (Points only)</span>
                        </div>
                        <input type="hidden" asp-for="IsGraded" id="hiddenIsGraded" />
                        <div class="flex items-center gap-2">
                            <div id="gradedBadge" class="px-3 py-1 bg-slate-100 text-slate-400 rounded-lg text-[9px] font-black uppercase tracking-widest transition-all">Not Graded</div>
                        </div>
                    </div>
                </div>

                <div id="waveContainer" style="display:none;">
                     <label class="block text-[10px] font-bold text-brand-600 dark:text-brand-400 uppercase tracking-widest mb-3 px-1">Target Student Batch</label>
                     <select asp-for="WaveId" id="WaveId" class="block w-full bg-slate-50 dark:bg-slate-950 border border-brand-500/30 rounded-2xl px-6 py-4 text-sm font-bold focus:ring-4 focus:ring-brand-500/10 outline-none">
                        <option value="">-- SELECT TARGET WAVE --</option>
                        @foreach (var w in ViewBag.Waves as IEnumerable<Exam.DTOs.WaveDto> ?? Enumerable.Empty<Exam.DTOs.WaveDto>()) {
                           <option value="@w.Id" selected="@(w.Id == Model.WaveId)">@w.WaveName.ToUpper()</option>
                        }
                     </select>
                </div>

                <div class="flex items-center justify-between p-6 bg-slate-50 dark:bg-slate-800/20 rounded-2xl border border-slate-100 dark:border-slate-800">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-shield-alt text-emerald-500 text-lg"></i>
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Exam Online Status</span>
                    </div>
                    <label class="relative flex items-center cursor-pointer">
                        <input asp-for="IsActive" class="peer hidden" type="checkbox" />
                        <div class="w-12 h-6 bg-slate-200 dark:bg-slate-700 rounded-full p-1 transition-all peer-checked:bg-emerald-500 flex items-center shadow-inner">
                            <div class="w-4 h-4 bg-white rounded-full transition-all peer-checked:translate-x-6"></div>
                        </div>
                    </label>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex justify-center gap-6 py-8">
            <a asp-action="Index" asp-controller="Admin" class="text-[10px] font-bold text-slate-400 hover:text-slate-900 dark:hover:text-white px-10 py-5 transition-colors uppercase tracking-widest">Cancel</a>
            <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-16 py-4 rounded-[24px] font-black uppercase text-sm tracking-widest shadow-xl shadow-brand-500/20 transition-all hover:scale-105 active:scale-95">
                Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function() {
                // $('#waveContainer').show(); // Handled by syncWave() below

            function updateGradingMode() {
                const opt = $('#ExamTypeId').find(':selected');
                const typeName = (opt.data('type-name')||'').toLowerCase();
                const isWavey = (opt.val() == '2' || typeName.includes('wave'));
                
                if (isWavey) {
                    $('#hiddenIsGraded').val('true');
                    $('#gradedBadge').text('Graded (Pass/Fail)').addClass('bg-emerald-100 text-emerald-600').removeClass('bg-slate-100 text-slate-400 bg-blue-100 text-blue-600');
                    $('#gradingStatus').text('Evaluative Protocol - requires passing threshold for Certification.');
                    $('#blueprintSection').slideDown();
                    $('#passGradeWrapper').show();
                    $('#totalQuestionsWrapper').show();
                } else if (opt.val() != '0') {
                    $('#hiddenIsGraded').val('false');
                    $('#gradedBadge').text('Weekly (Points Only)').addClass('bg-blue-100 text-blue-600').removeClass('bg-emerald-100 text-emerald-600 bg-slate-100 text-slate-400');
                    $('#gradingStatus').text('Assessment Protocol - point accumulation only, no pass/fail logic.');
                    $('#blueprintSection').slideDown();
                    $('#passGradeWrapper').hide();
                    $('#totalQuestionsWrapper').show();
                } else {
                    $('#blueprintSection').slideUp();
                    $('#passGradeWrapper').hide();
                }
            }

            function syncWave() {
                const opt = $('#ExamTypeId').find(':selected');
                const typeName = (opt.data('type-name') || '').toLowerCase();
                const isWavey = (opt.val() == '2' || typeName.includes('wave'));
                if (isWavey) {
                    $('#waveContainer').slideDown();
                } else {
                    $('#waveContainer').slideUp();
                }
            }

            let rIdx = @(Model.GenerationRules?.Count ?? 0);
            function reindexRules() {
                $('#rulesContainer .rule-row').each(function(idx){
                    const $row = $(this);
                    $row.find('select, input').each(function(){
                        const name = $(this).attr('name');
                        if(name) {
                            $(this).attr('name', name.replace(/\[\d+\]/, `[${idx}]`));
                        }
                    });
                });
                updateTotalQuestions();
            }

            function updateTotalQuestions() {
                let totalPharma = 0;
                let totalAssist = 0;

                $('#rulesContainer .rule-row').each(function() {
                    const $row = $(this);
                    const easy = parseInt($row.find('input[name$="EasyCount"]').val()) || 0;
                    const med = parseInt($row.find('input[name$="MediumCount"]').val()) || 0;
                    const hard = parseInt($row.find('input[name$="HardCount"]').val()) || 0;
                    const count = (easy + med + hard);
                    const target = ($row.find('select[name$=".TargetRole"]').val() || "").toLowerCase();

                    if (target === "all") {
                        totalPharma += count;
                        totalAssist += count;
                    } else if (target === "pharmacist") {
                        totalPharma += count;
                    } else if (target === "assistant") {
                        totalAssist += count;
                    }
                });

                $('#sumPharmacist').text(totalPharma);
                $('#sumAssistant').text(totalAssist);

                const opt = $('#ExamTypeId').find(':selected');
                const typeName = (opt.data('type-name') || opt.attr('data-type-name') || '').toLowerCase();
                const isWavey = (opt.val() == '2' || typeName.includes('wave'));
                const multiplier = isWavey ? 2 : 1;

                $('#ptsPharmacist').text(totalPharma * multiplier);
                $('#ptsAssistant').text(totalAssist * multiplier);
                
                const maxTotal = Math.max(totalPharma, totalAssist);
                $('#displayTotal').text(maxTotal);
                $('#TotalQuestionsToShow').val(maxTotal);
            }

            $(document).on('input', 'input[name$="Count"]', function() {
                updateTotalQuestions();
            });

            $(document).on('change', 'select[name$=".TargetRole"]', function() {
                updateTotalQuestions();
            });

            const topicCache = {};
            async function loadTopicsForRule($ruleRow, selectedTopicId) {
                const $catSelector = $ruleRow.find('.rule-cat-selector');
                const $topicSelector = $ruleRow.find('.rule-topic-selector');
                const catId = $catSelector.val();
                if (!catId) return;

                try {
                    let topics;
                    if (topicCache[catId]) {
                        topics = topicCache[catId];
                    } else {
                        topics = await $.get(`/Admin/GetTopicsByCategoryId?categoryId=${catId}`);
                        topicCache[catId] = topics;
                    }

                    $topicSelector.empty().append('<option value="">ALL TOPICS</option>');
                    if (topics && Array.isArray(topics)) {
                        topics.forEach(t => {
                            const tId = t.id !== undefined ? t.id : t.Id;
                            const tName = t.topicName || t.TopicName || "Unnamed Topic";
                            $topicSelector.append($('<option></option>').val(tId).text(tName.toUpperCase()));
                        });
                    }

                    if (selectedTopicId) {
                        $topicSelector.val(selectedTopicId);
                    }
                } catch (err) { console.error("Topic load failed", err); }
            }

            $('#addRuleBtn').click(function(){
                const html = `
                <div class="rule-row grid grid-cols-1 md:grid-cols-6 gap-3 bg-white dark:bg-slate-900 border border-indigo-100 dark:border-indigo-900/30 p-4 rounded-2xl animate-in fade-in zoom-in duration-300">
                    <div class="col-span-1 md:col-span-1">
                        <label class="block text-[8px] font-black uppercase text-indigo-400 mb-1">Injected Category</label>
                        <select name="GenerationRules[${rIdx}].CategoryId" required class="rule-cat-selector w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs font-bold outline-none">
                             ${currentCategoryOptions || '@Html.Raw(questionTypeOptionsHtml)'}
                        </select>
                    </div>
                    <div class="col-span-1 md:col-span-1">
                        <label class="block text-[8px] font-black uppercase text-indigo-400 mb-1">Specific Topic</label>
                        <select name="GenerationRules[${rIdx}].TopicId" class="rule-topic-selector w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs font-bold outline-none">
                             <option value="">ALL TOPICS</option>
                        </select>
                    </div>
                    <div class="col-span-1">
                        <label class="block text-[8px] font-black uppercase text-indigo-400 mb-1">Apply To</label>
                        <select name="GenerationRules[${rIdx}].TargetRole" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs font-bold outline-none">
                             <option value="All">ALL ROLES</option>
                             <option value="Pharmacist">PHARMACISTS ONLY</option>
                             <option value="Assistant">ASSISTANTS ONLY</option>
                        </select>
                    </div>
                    <div class="col-span-1 md:col-span-2">
                        <div class="grid grid-cols-3 gap-1">
                            <div>
                                <label class="block text-[7px] font-black text-emerald-500 uppercase">Easy</label>
                                <input type="number" name="GenerationRules[${rIdx}].EasyCount" value="0" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-2 text-xs font-bold rounded" />
                            </div>
                            <div>
                                <label class="block text-[7px] font-black text-amber-500 uppercase">Med</label>
                                <input type="number" name="GenerationRules[${rIdx}].MediumCount" value="0" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-2 text-xs font-bold rounded" />
                            </div>
                            <div>
                                <label class="block text-[7px] font-black text-rose-500 uppercase">Hard</label>
                                <input type="number" name="GenerationRules[${rIdx}].HardCount" value="0" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-2 text-xs font-bold rounded" />
                            </div>
                        </div>
                    </div>
                    <div class="col-span-1 md:col-span-1 flex items-center justify-end relative">
                         <button type="button" class="remove-rule absolute -right-2 -top-2 w-6 h-6 bg-rose-500 text-white rounded-full flex items-center justify-center shadow-lg transition-transform hover:scale-110 active:scale-90"><i class="fas fa-times text-[10px]"></i></button>
                    </div>
                </div>`;
                const $html = $(html);
                $('#rulesContainer').append($html);
                loadTopicsForRule($html, null);
                rIdx++;
                reindexRules();
            });

            $(document).on('change', '.rule-cat-selector', function(){
                loadTopicsForRule($(this).closest('.rule-row'), null);
            });

            // Initialize existing rules
            $('.rule-row').each(function(){
                const $row = $(this);
                const selectedTopicId = $row.find('.rule-topic-selector').data('selected-id');
                loadTopicsForRule($row, selectedTopicId);
            });
            updateTotalQuestions();

            $(document).on('click', '.remove-rule', function(){
                $(this).closest('.rule-row').remove();
                reindexRules();
            });

            var currentCategoryOptions = '';

            $('#ExamTypeId').on('change', function() {
                var name = $(this).find(':selected').data('type-name') || '';
                var typeId = $(this).val();

                if (typeId) {
                    $.getJSON('/Admin/GetCategoriesByExamType?examTypeId=' + typeId, function(data) {
                        currentCategoryOptions = '<option value="">--- SELECT CATEGORY ---</option>';
                        data.forEach(function(c) {
                            currentCategoryOptions += '<option value="' + c.id + '">' + c.categoryName.toUpperCase() + '</option>';
                        });
                        // Update existing dropdowns
                        $('.rule-cat-selector').each(function() {
                            var $sel = $(this);
                            var oldVal = $sel.val();
                            $sel.html(currentCategoryOptions);
                            $sel.val(oldVal); // try to keep selected if exists
                        });
                    });
                }
                syncWave();
                updateGradingMode();
                updateTotalQuestions();
            });
            syncWave();
            updateGradingMode();
            $('#editExamForm').on('submit', async function(e) {
                e.preventDefault();
                const $form = $(this);
                const $btn = $form.find('button[type="submit"]');
                const fd = new FormData(this);

                $btn.prop('disabled', true).text('Saving Changes...');

                try {
                    const r = await fetch(this.action, {
                        method: 'POST',
                        body: fd,
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
                    });
                    const res = await r.json();

                    if(res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Saved!',
                            text: res.message,
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 3000
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Validation Error',
                            text: res.message
                        });
                    }
                } catch(e) {
                    Swal.fire('Error', 'Update communication failed', 'error');
                } finally {
                    $btn.prop('disabled', false).text('Save Changes');
                }
            });

            updateGradingMode();

            $('#editQuestionsBtn').on('click', function() {
                Swal.fire({
                    title: 'Exam Question Library',
                    html: '<div id="qModalBody" class="text-left py-4" style="min-height:400px; max-height:85vh; overflow-y:auto;"><div class="py-20 text-center"><i class="fas fa-sync fa-spin text-4xl text-brand-500 mb-4 block"></i><p class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">Synchronizing Library...</p></div></div>',
                    width: '95%',
                    background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                    color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                    showConfirmButton: false,
                    showCloseButton: true,
                    customClass: { 
                        popup: 'rounded-[40px] border-none shadow-2xl overflow-hidden',
                        closeButton: 'bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-rose-500 transition-all rounded-full border-none outline-none focus:ring-0 mr-4 mt-4'
                    },
                    didOpen: () => { 
                        $.ajax({
                            url: '/Exams/GetDetails?id=@Model.Id',
                            method: 'GET',
                            success: function(response) {
                                if (response) {
                                    $('#qModalBody').html(response);
                                } else {
                                    $('#qModalBody').html('<div class="p-10 text-center text-rose-500 font-bold">Empty response received from server.</div>');
                                }
                            },
                            error: function(xhr, status, error) {
                                $('#qModalBody').html(`<div class="p-10 text-center text-rose-500 font-bold">Failed to load manual questions.<br/><br/>Error: ${error || status}<br/>Status: ${xhr.status}</div>`);
                            }
                        });
                    }
                });
            });
        });
    </script>
}