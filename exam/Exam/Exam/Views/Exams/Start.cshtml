@model Exam.DTOs.ExamDetailsDto
@{
    ViewData["Title"] = "Neural Evaluation Active";
    var attemptId = (int?)ViewData["AttemptId"] ?? 0;
    ViewData["HideNavbar"] = true;
}

<!-- Prevent Google Translate from interfering with the exam -->
<meta name="google" content="notranslate">

<style translate="no">
    nav.navbar { display: none !important; }
    body {
        user-select: none;
        -webkit-user-select: none;
        background-color: #f8fafc; /* bg-slate-50 */
    }
    #examForm, #examForm * { user-select: none; }
    
    /* Academic Integrity Lock Screen */
    #fs-lock-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(248, 250, 252, 0.95);
        z-index: 999999;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
    }
    
    .answer-choice:has(input:checked) {
        border-color: #16a34a !important; /* brand-600 */
        background: #f0fdf4 !important; /* brand-50 */
        box-shadow: 0 4px 14px 0 rgba(22, 163, 74, 0.08); /* brand shadow */
    }
    
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
</style>

<!-- Security Lock Screen -->
<div id="fs-lock-overlay">
    <div class="text-center p-8 sm:p-12 bg-white rounded-[32px] sm:rounded-[40px] shadow-2xl border border-rose-100 max-w-md w-full mx-4 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-rose-500"></div>
        <div class="mb-8 inline-flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 bg-rose-50 rounded-full border-4 border-white shadow-sm">
            <svg class="w-10 h-10 sm:w-12 sm:h-12 text-rose-500 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h2 class="text-xl sm:text-2xl font-black mb-2 text-slate-800 tracking-tight">Focus Lost</h2>
        <p class="mb-8 text-slate-500 text-sm font-medium leading-relaxed">It appears you left the exam window. Leaving the assessment environment compromises academic integrity.</p>
        <div id="strike-warning-overlay" class="mb-8 text-rose-600 font-bold text-xs uppercase tracking-widest bg-rose-50 py-3 rounded-xl border border-rose-100"></div>
        <button onclick="reEnterFullscreen()" class="w-full bg-slate-900 hover:bg-slate-800 text-white py-4 rounded-2xl font-bold transition-all shadow-lg hover:-translate-y-0.5">
            RETURN TO EXAM
        </button>
    </div>
</div>

<div id="main-exam-container" translate="no" class="notranslate min-h-screen flex flex-col p-3 sm:p-4 md:p-8 transition-all duration-300">
    <!-- Top Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-6 mb-5 sm:mb-8 max-w-5xl mx-auto w-full">
        <div class="flex items-center gap-3 sm:gap-5">
            <div class="w-10 h-10 sm:w-14 sm:h-14 rounded-2xl bg-white flex items-center justify-center shadow-md border border-slate-100 shrink-0">
                <svg class="w-5 h-5 sm:w-7 sm:h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="text-lg sm:text-2xl font-black text-slate-900 tracking-tight truncate">@Model.Title</h3>
                <div id="live-strikes-counter" class="text-xs font-bold text-brand-600 uppercase tracking-widest mt-0.5">Status: Active &amp; Secure</div>
            </div>
        </div>

        <div class="flex items-center gap-2 sm:gap-3">
            <div class="bg-white border border-slate-200 px-4 sm:px-6 py-2.5 sm:py-3 rounded-2xl shadow-sm text-center flex-1 sm:flex-none">
                <div class="text-[9px] sm:text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">Time Remaining</div>
                <div id="timerDisplay" class="text-xl sm:text-2xl font-black text-slate-800 tabular-nums">--:--</div>
            </div>
            <div class="bg-slate-900 px-4 sm:px-6 py-2.5 sm:py-3 rounded-2xl shadow-sm text-center text-white flex-1 sm:flex-none">
                <div class="text-[9px] sm:text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">Progress</div>
                <div class="text-base sm:text-lg font-black"><span id="currentQuestionIndex" class="text-brand-400">1</span> / @Model.Questions.Count()</div>
            </div>
        </div>
    </div>

    <!-- Main Form Area -->
    <form id="examForm" class="flex-1 flex flex-col max-w-5xl mx-auto w-full mb-6 sm:mb-8">
        <input type="hidden" id="attemptId" value="@attemptId" />
        
        <div class="flex-1 bg-white rounded-[20px] sm:rounded-[32px] shadow-sm border border-slate-200 flex flex-col overflow-hidden relative">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-brand-400 to-brand-600"></div>
            
            <div class="flex-1 p-5 sm:p-8 md:p-12 overflow-y-auto custom-scrollbar">
                <style> .question-page { display: none; } </style>
                @{ var idx = 0; }
                @foreach (var q in Model.Questions)
                {
                    <div class="question-page space-y-6 sm:space-y-10" data-index="@idx">
                        
                        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
                            <span class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-brand-600 text-white font-black text-xl sm:text-2xl shrink-0 shadow-md">
                                @(idx + 1)
                            </span>
                            <div class="inline-flex items-center px-3 sm:px-4 py-1.5 rounded-full bg-slate-100 text-[10px] font-black uppercase text-slate-500 tracking-widest">
                                @q.CategoryName
                            </div>
                            @if (!string.IsNullOrEmpty(q.TopicName))
                            {
                                <div class="inline-flex items-center px-3 sm:px-4 py-1.5 rounded-full bg-brand-50 text-[10px] font-black uppercase text-brand-500 tracking-widest border border-brand-100">
                                    <i class="fas fa-tag mr-1.5 opacity-50"></i> @q.TopicName
                                </div>
                            }
                            @{
                                var diffLabel = q.Difficulty == 3 ? "Hard" : (q.Difficulty == 2 ? "Medium" : "Easy");
                                var diffColor = q.Difficulty == 3 ? "bg-rose-100 text-rose-600" : (q.Difficulty == 2 ? "bg-amber-100 text-amber-600" : "bg-emerald-100 text-emerald-600");
                            }
                            <div class="inline-flex items-center px-3 py-1.5 rounded-full @diffColor text-[9px] font-black uppercase tracking-tighter shadow-sm">
                                <svg class="w-2.5 h-2.5 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a3 3 0 01-3-3V6zm3 1a1 1 0 000 2h3a1 1 0 100-2H6z" clip-rule="evenodd" /></svg>
                                @diffLabel
                            </div>
                        </div>
                        
                        <h5 class="text-xl sm:text-2xl lg:text-3xl font-black text-slate-800 tracking-tight leading-snug break-words">@q.QuestionText</h5>
                        
                        <div class="grid grid-cols-1 gap-3 sm:gap-4 mt-6 sm:mt-8">
                            @foreach (var c in q.Choices)
                            {
                                <label class="answer-choice flex items-start sm:items-center gap-3 sm:gap-5 rounded-2xl border-2 border-slate-100 p-4 sm:p-6 hover:border-slate-300 hover:bg-slate-50 transition-all cursor-pointer group/choice">
                                    <div class="relative w-5 h-5 sm:w-6 sm:h-6 flex-shrink-0 mt-0.5 sm:mt-0">
                                        <input class="w-full h-full opacity-0 absolute cursor-pointer peer" type="radio" 
                                               name="q_@q.QuestionId" value="@c.ChoiceId" 
                                               @(q.SelectedChoiceId == c.ChoiceId ? "checked" : "") />
                                        <div class="w-full h-full border-2 border-slate-300 rounded-full peer-checked:border-brand-600 peer-checked:bg-white transition-all flex items-center justify-center bg-white shadow-inner">
                                            <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 bg-brand-600 rounded-full opacity-0 peer-checked:opacity-100 transition-opacity scale-50 peer-checked:scale-100"></div>
                                        </div>
                                    </div>
                                    <span class="text-sm sm:text-base font-semibold text-slate-600 group-hover/choice:text-slate-900 transition-colors break-words w-full">@c.ChoiceText</span>
                                </label>
                            }
                        </div>
                    </div>
                    idx++;
                }
            </div>

            <!-- Footer Controls -->
            <div class="px-5 sm:px-8 py-4 sm:py-6 border-t border-slate-100 bg-slate-50 flex items-center justify-between gap-4">
                <div class="flex gap-2 sm:gap-4 flex-1 sm:flex-none justify-end">
                    <button type="button" id="submitBtn" disabled class="flex-1 sm:flex-none bg-brand-600 text-white px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl font-black uppercase text-xs tracking-widest transition-all shadow-lg hidden" style="opacity:.4;cursor:not-allowed;">
                        Finish &amp; Submit
                    </button>
                    <button type="button" id="nextBtn" disabled class="flex-1 sm:flex-none bg-slate-900 text-white px-8 sm:px-10 py-3.5 sm:py-4 rounded-xl font-black uppercase text-xs tracking-widest transition-all shadow-lg" style="opacity:.4;cursor:not-allowed;">
                        Next
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // ===== BLOCK BROWSER / ANDROID BACK BUTTON =====
        history.pushState(null, '', window.location.href);
        window.addEventListener('popstate', function () {
            if (window.isSubmitting) return;

            history.pushState(null, '', window.location.href);

            Swal.fire({
                title: 'Leave Exam?',
                html: '<p class="text-sm text-slate-500">Are you sure you want to leave?<br><strong class="text-rose-600">Your progress will NOT be saved.</strong></p>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Leave Exam',
                cancelButtonText: 'Stay & Continue',
                reverseButtons: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-200 shadow-2xl',
                    confirmButton: 'bg-rose-600 hover:bg-rose-700 text-white font-bold py-3 px-8 rounded-xl transition-all ml-3 text-sm',
                    cancelButton:  'bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 px-8 rounded-xl transition-all text-sm'
                },
                buttonsStyling: false
            }).then(function (result) {
                if (result.isConfirmed) {
                    window.isSubmitting = true;
                    window.onbeforeunload = null;
                    window.location.replace('@Url.Action("StudentExams", "Home")');
                }
            });
        });
        // =================================================

        window.cheatStrikes = 0;
        window.isSubmitting = false;
        const maxStrikes = 1;
        let lastStrikeTime = 0;

        function reEnterFullscreen() {
            let el = document.documentElement;
            let requestMethod = el.requestFullscreen || el.webkitRequestFullscreen || el.msRequestFullscreen;
            if (requestMethod) {
                requestMethod.call(el).then(() => {
                    $('#fs-lock-overlay').fadeOut(200);
                    $('#main-exam-container').css('filter', 'none').css('opacity', '1');

                    if (window.cheatStrikes > 0 && window.cheatStrikes <= maxStrikes && !window.isSubmitting) {
                        Swal.fire({
                            title: 'Academic Alert',
                            html: `<p class="text-sm text-slate-500 mb-6">Focus lost detected. Continued infractions will result in the exam auto-submitting.</p><div class="flex justify-center gap-3 mb-6">${Array.from({length: maxStrikes}, (_, i) => `<div class="w-12 h-2 rounded-full ${i < window.cheatStrikes ? 'bg-rose-500' : 'bg-slate-200'}"></div>`).join('')}</div><p class="text-[10px] font-black text-rose-600 uppercase tracking-widest border border-rose-100 bg-rose-50 py-2 px-4 rounded-lg inline-block">Violations: ${window.cheatStrikes} / ${maxStrikes}</p>`,
                            icon: 'warning',
                            confirmButtonText: 'I Understand',
                            customClass: { popup: 'rounded-3xl border border-slate-200 shadow-2xl', confirmButton: 'bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-8 rounded-xl transition-all w-full text-sm' },
                            buttonsStyling: false
                        });
                    }
                }).catch(err => { console.log("Fullscreen request failed", err); });
            }
        }

        $(function(){
            var currentIndex = 0;
            var totalQuestions = $('.question-page').length;
            
            // 1. Recover from LocalStorage (for answers not yet synced to server)
            function recoverProgress() {
                const attId = $('#attemptId').val();
                let localData = JSON.parse(localStorage.getItem('exam_cache_' + attId) || '{}');
                
                for (let qId in localData) {
                    const cId = localData[qId];
                    const $radio = $(`input[name="q_${qId}"][value="${cId}"]`);
                    if ($radio.length && !$radio.is(':checked')) {
                        $radio.prop('checked', true);
                    }
                }
                refreshBtnState();
            }
            recoverProgress();
            
            // Auto-submit via sendBeacon when tab/browser is closed
            window.addEventListener('beforeunload', function(e) {
                if (window.isSubmitting) return;
                
                var answers = [];
                $('input[type=radio]:checked').each(function() {
                    answers.push({ 
                        QuestionId: parseInt($(this).attr('name').replace('q_','')), 
                        SelectedChoiceId: parseInt($(this).val()) 
                    });
                });

                var url = '@Url.Action("SubmitAnswers", "Exams")?attemptId=@attemptId&status=Fail_TabClose';
                var blob = new Blob([JSON.stringify(answers)], { type: 'application/json' });
                navigator.sendBeacon(url, blob);

                e.preventDefault();
                e.returnValue = "Warning: Your exam progress may be lost!";
            });

            function lockDown(reason = 'Fail_Security_Breach') {
                if (window.isSubmitting) return;
                if ($('#fs-lock-overlay').is(':visible')) return;

                let now = Date.now();
                if (now - lastStrikeTime < 2000) return;
                lastStrikeTime = now;

                $('#fs-lock-overlay').css('display', 'flex').hide().fadeIn(200);
                $('#main-exam-container').css('filter', 'blur(10px)').css('opacity', '0.5');

                window.cheatStrikes++;

                if(window.cheatStrikes > maxStrikes) {
                    $('#strike-warning-overlay').html("MAXIMUM INFRACTIONS REACHED — AUTO-SUBMITTING");
                    $('#live-strikes-counter').html(`WARNINGS: ${window.cheatStrikes - 1} / ${maxStrikes} (BREACHED)`).removeClass("text-brand-600").addClass("text-rose-600");
                    executeSubmit(true, reason);
                } else {
                    $('#strike-warning-overlay').html(`WARNING ${window.cheatStrikes} OF ${maxStrikes}`);
                    $('#live-strikes-counter').html(`WARNINGS: ${window.cheatStrikes} / ${maxStrikes}`).removeClass("text-brand-600").addClass("text-rose-600");
                }
            }

            document.addEventListener('fullscreenchange', () => { if (!document.fullscreenElement) lockDown('Fail_ExitFullscreen'); });
            document.addEventListener('visibilitychange', () => { if (document.hidden) lockDown('Fail_TabSwitch'); });
            $(window).on('blur', () => { lockDown('Fail_WindowBlur'); });
            $(document).one('mousedown keydown', reEnterFullscreen);

            $(document).on('keydown', function(e) {
                if (e.key === 'F12' || e.key === 'F11') { e.preventDefault(); if(e.key === 'F11') lockDown('Fail_F11'); return false; }
                if ((e.ctrlKey || e.metaKey) && (['c', 'v', 'x', 'a', 'p', 's', 'l', 'r'].includes(e.key.toLowerCase()) || (e.keyCode >= 49 && e.keyCode <= 57))) {
                    e.preventDefault(); lockDown('Fail_IllegalCommand'); return false;
                }
            });
            $(document).on('contextmenu copy paste', e => e.preventDefault());

            // ===== ABSOLUTE SYNC TIMER LOGIC =====
            const serverStartTime = new Date('@(((DateTime)ViewData["StartTime"]).ToString("yyyy-MM-ddTHH:mm:ss"))').getTime();
            const serverNow = new Date('@(((DateTime)ViewData["ServerTime"]).ToString("yyyy-MM-ddTHH:mm:ss"))').getTime();
            const durationMinutes = @(ViewData["Duration"] ?? 60);
            
            // Calculate drift to sync with server time
            const drift = new Date().getTime() - serverNow;
            const absoluteEndTime = serverStartTime + (durationMinutes * 60 * 1000);

            var timerInt = setInterval(function(){
                if (window.isSubmitting) { clearInterval(timerInt); return; }

                const nowInServerTime = new Date().getTime() - drift;
                const remainingMs = absoluteEndTime - nowInServerTime;

                if (remainingMs <= 0) {
                    clearInterval(timerInt);
                    $('#timerDisplay').text('00:00');
                    executeSubmit(false, 'Fail_Timeout');
                    return;
                }

                const totalSeconds = Math.floor(remainingMs / 1000);
                const m = Math.floor(totalSeconds / 60);
                const s = totalSeconds % 60;

                $('#timerDisplay').text(String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0'));
                
                if(totalSeconds < 60) {
                    $('#timerDisplay').addClass('text-rose-600 animate-pulse').removeClass('text-slate-800');
                }
            }, 1000);
            // ======================================

            function refreshBtnState() {
                var answered = $('.question-page[data-index="' + currentIndex + '"] input[type="radio"]:checked').length > 0;
                var $active = (currentIndex === totalQuestions - 1) ? $('#submitBtn') : $('#nextBtn');
                if (answered) {
                    $active.prop('disabled', false)
                           .css({ opacity: '1', cursor: 'pointer' })
                           .addClass('hover:-translate-y-0.5 hover:shadow-lg');
                } else {
                    $active.prop('disabled', true)
                           .css({ opacity: '.4', cursor: 'not-allowed' })
                           .removeClass('hover:-translate-y-0.5 hover:shadow-lg');
                }
            }

            function updateNav(idx) {
                $('.question-page').hide();
                $('.question-page[data-index="'+idx+'"]').fadeIn(200);
                $('#currentQuestionIndex').text(idx + 1);

                if (idx === 0 || !@Model.ShowQuestionOverview.ToString().ToLower()) {
                    $('#prevBtn').hide();
                } else {
                    $('#prevBtn').show();
                }

                if (idx === totalQuestions - 1) {
                    $('#nextBtn').hide().prop('disabled', true);
                    $('#submitBtn').removeClass('hidden').show();
                } else {
                    $('#submitBtn').hide().prop('disabled', true);
                    $('#nextBtn').removeClass('hidden').show();
                }

                refreshBtnState();
            }

            $(document).on('change', '.question-page input[type="radio"]', function () {
                const $radio = $(this);
                const qId = parseInt($radio.attr('name').replace('q_', ''));
                const cId = parseInt($radio.val());
                const attId = $('#attemptId').val();

                // 1. Save to LocalStorage (Immediate safety)
                let localData = JSON.parse(localStorage.getItem('exam_cache_@attemptId') || '{}');
                localData[qId] = cId;
                localStorage.setItem('exam_cache_@attemptId', JSON.stringify(localData));

                refreshBtnState();
            });

            $('#nextBtn').click(() => {
                if ($('#nextBtn').prop('disabled')) return;
                if (currentIndex < totalQuestions - 1) updateNav(++currentIndex);
            });

            $('#prevBtn').click(() => {
                if (currentIndex > 0) updateNav(--currentIndex);
            });

            window.jumpToQuestion = function(idx) {
                Swal.close();
                currentIndex = idx;
                updateNav(currentIndex);
            };

            function showReviewGrid() {
                 let html = '<div class="grid grid-cols-5 sm:grid-cols-6 md:grid-cols-8 gap-3 pt-4">';
                 for(let i = 0; i < totalQuestions; i++) {
                     let answered = $('.question-page[data-index="' + i + '"] input[type="radio"]:checked').length > 0;
                     let colorClass = answered ? 'bg-brand-50 border-brand-500 text-brand-600 shadow-sm' : 'bg-slate-50 border-slate-200 text-slate-400';
                     let currentClass = (i === currentIndex) ? 'ring-4 ring-brand-500/20 ring-offset-2 scale-105' : '';
                     html += `<button type="button" class="h-10 sm:h-12 rounded-xl font-black text-xs sm:text-sm border-2 ${colorClass} ${currentClass} hover:opacity-80 transition-all flex items-center justify-center transform hover:scale-105" onclick="jumpToQuestion(${i})">${i+1}</button>`;
                 }
                 html += '</div>';

                 Swal.fire({
                     title: '<span class="text-xl font-black text-slate-800 tracking-tight uppercase">Exam Overview</span>',
                     html: html,
                     showConfirmButton: false,
                     showCloseButton: true,
                     background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#f8fafc',
                     customClass: { popup: 'rounded-[32px] border border-slate-200 dark:border-slate-800 shadow-2xl', closeButton: 'text-slate-400 hover:text-rose-500 transition-colors mr-2 mt-2 outline-none' }
                 });
            }

            $('#gridBtn').click(() => showReviewGrid());


            $('#submitBtn').click(() => {
                Swal.fire({ 
                    title: 'Submit Assessment?',
                    text: 'Are you sure you want to finalize your exam answers? You cannot return after submission.',
                    icon: 'question',
                    showCancelButton: true, confirmButtonText: 'Yes, Submit Exam', cancelButtonText: 'Cancel',
                    customClass: { popup: 'rounded-3xl border border-slate-200 shadow-2xl', confirmButton: 'bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-8 rounded-xl transition-all ml-3', cancelButton: 'bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold py-3 px-8 rounded-xl transition-all' },
                    buttonsStyling: false
                }).then(r => { 
                    if(r.isConfirmed) {
                        executeSubmit(false, 'Completed'); 
                    }
                });
            });

            let submitInProgress = false;
            function executeSubmit(isCheat, statusText = 'Completed') {
                if (submitInProgress) return;
                submitInProgress = true;

                window.isSubmitting = true;
                window.onbeforeunload = null;
                
                Swal.fire({
                    title: 'Submitting Exam...',
                    text: 'Please wait while we finalize your results.',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                const attId = $('#attemptId').val();
                let answers = [];
                
                // Collect answers from UI or fallback to LocalStorage
                $('input[type=radio]:checked').each(function() {
                    answers.push({ QuestionId: parseInt($(this).attr('name').replace('q_','')), SelectedChoiceId: parseInt($(this).val()) });
                });

                if (answers.length === 0) {
                    // Try to recover from LocalStorage if UI state is lost
                    let localData = JSON.parse(localStorage.getItem('exam_cache_@attemptId') || '{}');
                    for (let qId in localData) {
                        answers.push({ QuestionId: parseInt(qId), SelectedChoiceId: localData[qId] });
                    }
                }

                function performAjax(retryCount = 0) {
                    $.ajax({
                         url: `@Url.Action("SubmitAnswers", "Exams")?attemptId=${attId}&status=${statusText}`,
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(answers),
                        timeout: 120000, // 2 Minutes timeout
                        success: function(res) {
                            if (res.success) {
                                localStorage.removeItem('exam_cache_@attemptId');
                                window.location = '@Url.Action("StudentExams", "Home")';
                            } else {
                                throw new Error(res.message || "Unknown error");
                            }
                        },
                        error: function(err) {
                            submitInProgress = false;
                            console.error("Submission failed:", err);
                            let errorDetail = "We could not reach the server.";
                            if (err.status === 500 && err.responseJSON && err.responseJSON.message) {
                                errorDetail = err.responseJSON.message;
                            } else if (err.statusText === 'timeout') {
                                errorDetail = "Server timeout. The server took too long to process your large request.";
                            }

                            Swal.fire({
                                icon: 'error',
                                title: 'Submission Failed',
                                html: `<p class="text-sm text-slate-500">${errorDetail}</p><p class="text-[10px] mt-4 text-slate-400">Please check your internet or retry. Your answers are still safely cached locally.</p>`,
                                confirmButtonText: 'Retry Submission',
                                showCancelButton: true,
                                cancelButtonText: 'Exit anyway (Risk)',
                                customClass: {
                                    confirmButton: 'bg-brand-600 text-white font-bold py-3 px-8 rounded-xl ml-3',
                                    cancelButton: 'bg-slate-200 text-slate-700 font-bold py-3 px-8 rounded-xl'
                                },
                                buttonsStyling: false
                            }).then(result => {
                                if (result.isConfirmed) {
                                    executeSubmit(isCheat, statusText); // Retry
                                } else {
                                    window.isSubmitting = false; // Let them try to navigate
                                }
                            });
                        }
                    });
                }

                performAjax();
            }
            updateNav(0);
        });
    </script>
}
