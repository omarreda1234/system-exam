@model IEnumerable<dynamic>
@{
    var wave = ViewBag.Wave;
    var company = ViewBag.Company;
    bool isCompany = ViewBag.IsCompany == true;
    
    var title = isCompany ? company.Name : wave.WaveName;
    var subtitle = isCompany ? "Company Training Sessions" : "Wave Training Sessions";
    ViewData["Title"] = $"Manage Sessions - {title}";
}

<div class="min-h-screen bg-slate-50/50 dark:bg-slate-950/20 pb-20">
    <!-- Header -->
    <div class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 pt-24 pb-12">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div class="flex flex-col sm:flex-row items-center gap-6 text-center sm:text-left">
                    <a href="@Url.Action("Index")" class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 hover:text-brand-600 hover:bg-brand-50 transition-all shrink-0">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                    <div>
                        <h1 class="text-xl sm:text-2xl font-black text-slate-900 dark:text-white tracking-tight uppercase">@title</h1>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1">@subtitle</p>
                    </div>
                </div>
                
                <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                    @if (!User.IsInRole("Reception"))
                    {
                        <a href="@Url.Action("ExportAttendance", new { waveId = isCompany ? null : (int?)wave.Id, companyId = isCompany ? (int?)company.Id : null })" class="flex-1 md:flex-none justify-center bg-emerald-600 text-white px-8 py-4 md:py-3 rounded-2xl transition-all text-xs font-black uppercase shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 flex items-center gap-3">
                            <i class="fas fa-file-excel"></i> Export Attendance Report
                        </a>
                        <button onclick="$('#addSessionModal').removeClass('hidden').addClass('flex')" class="flex-1 md:flex-none justify-center bg-brand-600 text-white px-8 py-4 md:py-3 rounded-2xl transition-all text-xs font-black uppercase shadow-lg shadow-brand-600/20 hover:bg-brand-700 flex items-center gap-3">
                            <i class="fas fa-plus"></i> Add New Session
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Sessions List -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 mt-8">
        <div class="grid grid-cols-1 gap-4">
            @foreach (var session in Model)
            {
                <div class="saas-card flex flex-col sm:flex-row sm:items-center justify-between gap-6 group hover:border-brand-500/30 transition-all">
                    <div class="flex items-center gap-4 sm:gap-6">
                        <div class="w-14 h-14 sm:w-16 sm:h-16 bg-slate-50 dark:bg-slate-800 rounded-2xl flex flex-col items-center justify-center border border-slate-100 dark:border-slate-800 shrink-0">
                            <span class="text-[9px] sm:text-[10px] font-black text-brand-600 uppercase">@session.SessionDate.ToString("MMM")</span>
                            <span class="text-lg sm:text-xl font-black text-slate-900 dark:text-white">@session.SessionDate.ToString("dd")</span>
                        </div>
                        <div>
                            <h3 class="font-black text-slate-900 dark:text-white uppercase text-xs sm:text-sm">@session.SessionName</h3>
                            <div class="flex flex-wrap items-center gap-3 sm:gap-4 mt-1">
                                <span class="text-[9px] sm:text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                                    <i class="far fa-clock mr-1"></i> @session.SessionDate.ToString("dddd")
                                </span>
                                <span class="text-[9px] sm:text-[10px] font-bold text-brand-600 uppercase tracking-widest bg-brand-50 dark:bg-brand-950/20 px-2 py-0.5 rounded-full">
                                    <i class="fas fa-user-check mr-1"></i> @session.PresentCount Trainees Present
                                </span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-2 border-t sm:border-t-0 pt-4 sm:pt-0 border-slate-100 dark:border-slate-800">
                        @{
                            bool canTakeAttendance = false;
                            if (session.SessionDate is DateTime dt)
                            {
                                canTakeAttendance = dt.Date <= DateTime.Now.Date;
                            }
                            else if (DateTime.TryParse(session.SessionDate?.ToString(), out DateTime parsedDt))
                            {
                                canTakeAttendance = parsedDt.Date <= DateTime.Now.Date;
                            }
                        }

                        @if (canTakeAttendance)
                        {
                            <a href="@Url.Action("TakeAttendance", new { sessionId = session.Id })" class="flex-1 sm:flex-none text-center bg-slate-900 hover:bg-slate-800 dark:bg-slate-850 dark:hover:bg-slate-800 text-white px-6 py-3 sm:py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-brand-600 transition-all">
                                Take Attendance
                            </a>
                        }
                        else
                        {
                            <button disabled class="flex-1 sm:flex-none text-center bg-slate-100 dark:bg-slate-800/50 text-slate-400 dark:text-slate-600 px-6 py-3 sm:py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest cursor-not-allowed border border-slate-200 dark:border-slate-800" title="Session starts on @session.SessionDate.ToString("dd MMM yyyy")">
                                Pending Date
                            </button>
                        }
                        <a href="@Url.Action("ExportSessionAttendance", new { sessionId = session.Id })" class="flex-1 sm:flex-none text-center bg-emerald-50 hover:bg-emerald-600 text-emerald-600 hover:text-white px-5 py-3 sm:py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest border border-emerald-100 dark:border-emerald-950/30 transition-all flex items-center justify-center gap-1.5" title="Export Excel">
                            <i class="fas fa-file-excel"></i> Export Excel
                        </a>
                        @if (!User.IsInRole("Reception"))
                        {
                            <button onclick="deleteSession(@session.Id)" class="w-12 h-12 sm:w-10 sm:h-10 bg-rose-50 text-rose-500 rounded-xl flex items-center justify-center hover:bg-rose-500 hover:text-white transition-all border border-rose-100 dark:border-rose-950/30" title="Delete Session">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        }
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="bg-white dark:bg-slate-900 rounded-[32px] p-20 text-center border-2 border-dashed border-slate-200 dark:border-slate-800 shadow-sm">
                    <p class="text-slate-400 font-bold uppercase text-[10px] tracking-widest">No sessions defined for this training ciclo yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal -->
<div id="addSessionModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm p-6">
    <div class="bg-white dark:bg-slate-900 w-full max-w-md rounded-[32px] p-8 shadow-2xl border border-slate-200 dark:border-slate-800">
        <div class="flex justify-between items-center mb-8">
            <h3 class="text-xl font-black text-slate-900 dark:text-white uppercase">New Session</h3>
            <button onclick="$('#addSessionModal').addClass('hidden').removeClass('flex')" class="text-slate-400 hover:text-rose-500 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <form asp-action="CreateSession" method="post" class="space-y-6">
            @if (isCompany)
            {
                <input type="hidden" name="companyId" value="@company.Id" />
            }
            else
            {
                <input type="hidden" name="waveId" value="@wave.Id" />
            }
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Session Date</label>
                <input type="text" id="sessionDatePicker" name="sessionDate" placeholder="dd/mm/yyyy" required class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-4 text-sm font-bold outline-none focus:border-brand-500 transition-all text-slate-900 dark:text-white" />
            </div>
            <div>
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Session Name / Label</label>
                <input type="text" name="sessionName" placeholder="e.g. Day 1: Product Intro" required class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-4 text-sm font-bold outline-none focus:border-brand-500 transition-all text-slate-900 dark:text-white" />
            </div>
            <button type="submit" class="w-full bg-brand-600 text-white py-4 rounded-2xl font-black uppercase text-xs tracking-widest shadow-lg shadow-brand-600/20 hover:bg-brand-700 transition-all mt-4">
                Confirm & Create
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <!-- Flatpickr CSS & JS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        $(function() {
            flatpickr("#sessionDatePicker", {
                altInput: true,
                altFormat: "d/m/Y",
                dateFormat: "Y-m-d",
                altInputClass: "w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-4 text-sm font-bold outline-none focus:border-brand-500 transition-all text-slate-900 dark:text-white"
            });
        });

        function deleteSession(id) {
            Swal.fire({
                title: 'Delete Session?',
                text: "All attendance records for this day will be permanently removed.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                confirmButtonText: 'Yes, Delete it',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteSession")', { sessionId: id }, function(res) {
                        if (res.success) {
                            location.reload();
                        }
                    });
                }
            });
        }
    </script>
}
