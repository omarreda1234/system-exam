@model IEnumerable<Exam.Controllers.LocalItemDto>
@{
    ViewData["Title"] = "Sync Items Matrix";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Staggered Entry / Glassmorphism Dashboard Card -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-8 shadow-sm">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Inventory Management</h2>
            <div class="flex items-center gap-3">
                <p class="text-xl font-bold">Live Items Matrix</p>
                <span class="px-2.5 py-0.5 rounded-full text-xs font-bold bg-brand-50 text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">
                    @(ViewBag.TotalCount ?? 0) Items Total
                </span>
            </div>
        </div>
        
        <div>
            <button id="btnSync" class="bg-brand-600 hover:bg-brand-700 dark:bg-brand-500/20 dark:hover:bg-brand-500/30 text-white dark:text-brand-400 px-6 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center gap-2">
                <i class="fas fa-sync-alt"></i> Sync Items
            </button>
        </div>
    </div>
</div>

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 overflow-hidden shadow-sm">
    <div id="tableWrapper" class="overflow-x-auto">
        <table id="itemsTable" class="saas-table">
            <thead>
                <tr>
                    <th class="min-w-[120px]">Item No</th>
                    <th class="min-w-[200px]">Description</th>
                    <th class="min-w-[150px]">Description 2</th>
                    <th class="min-w-[120px]">Item Definition</th>
                    <th>Storage</th>
                    <th>Incentive</th>
                    <th>Color</th>
                    <th class="min-w-[130px]">Created</th>
                    <th class="min-w-[130px]">Modified</th>
                    <th class="min-w-[130px]">Synced At</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize DataTable with server-side processing for high performance
            $('#itemsTable').DataTable({
                serverSide: true,
                processing: true,
                stateSave: true, // Persistent search, pagination, and sorting
                deferRender: true,
                autoWidth: false,
                ajax: {
                    url: '/Admin/GetItemsPaged',
                    type: 'POST'
                },
                columns: [
                    { data: 'no_', className: 'font-mono font-bold text-brand-600 dark:text-brand-400' },
                    { data: 'description', className: 'font-semibold' },
                    { data: 'description2', className: 'text-slate-500 dark:text-slate-400' },
                    { 
                        data: 'itemDefinition',
                        render: function(data, type, row) {
                            if (!data) return '';
                            return '<span class="px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 text-xs font-semibold">' + data + '</span>';
                        }
                    },
                    { 
                        data: 'storageInstructions',
                        className: 'text-xs truncate max-w-[150px]',
                        render: function(data, type, row) {
                            if (!data) return '';
                            return '<span title="' + data + '">' + data + '</span>';
                        }
                    },
                    { data: 'incentiveValue', className: 'font-mono text-xs' },
                    { 
                        data: 'color',
                        render: function(data, type, row) {
                            if (!data) return '';
                            return '<span class="inline-flex items-center gap-1.5">' +
                                   '<span class="w-2.5 h-2.5 rounded-full border border-slate-300 dark:border-slate-600" style="background-color: ' + data + '"></span>' +
                                   '<span class="text-xs">' + data + '</span>' +
                                   '</span>';
                        }
                    },
                    { data: 'dateCreated', className: 'text-xs' },
                    { data: 'lastDateModified', className: 'text-xs' },
                    { data: 'lastSyncedAt', className: 'text-xs font-semibold text-slate-500' }
                ],
                order: [[8, "desc"]], // Default sort by modified date descending
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search items matrix...",
                    lengthMenu: "Show _MENU_ records",
                    info: "Showing _START_ to _END_ of _TOTAL_ items",
                    paginate: {
                        first: "First",
                        previous: "Prev",
                        next: "Next",
                        last: "Last"
                    }
                }
            });

            // Sync Button Action with SweetAlert2 password authorization
            $('#btnSync').on('click', function () {
                Swal.fire({
                    title: 'Live Database Sync',
                    text: 'Enter administrator authorization passcode:',
                    input: 'password',
                    inputPlaceholder: '••••••',
                    inputAttributes: {
                        autocapitalize: 'off',
                        autocorrect: 'off',
                        autocomplete: 'new-password'
                    },
                    showCancelButton: true,
                    confirmButtonText: '<i class="fas fa-cloud-download-alt mr-2"></i> Authorize & Sync',
                    confirmButtonColor: '#2a766f',
                    cancelButtonColor: '#64748b',
                    showLoaderOnConfirm: true,
                    preConfirm: (password) => {
                        return fetch('/Admin/SyncItems', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ password: password })
                        })
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.json();
                        })
                        .catch(error => {
                            Swal.showValidationMessage(`Sync failed: ${error}`);
                        });
                    },
                    allowOutsideClick: () => !Swal.isLoading()
                }).then((result) => {
                    if (result.isConfirmed) {
                        if (result.value && result.value.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Sync Completed',
                                text: result.value.message,
                                confirmButtonColor: '#2a766f'
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Sync Authorization Failed',
                                text: (result.value && result.value.message) || 'Passcode incorrect.',
                                confirmButtonColor: '#dc2626'
                            });
                        }
                    }
                });
            });
        });
    </script>
}
