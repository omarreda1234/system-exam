                                            <td>${u.branchName ?? 'N/A'}</td>
                                                                                        <td class="text-right flex items-center justify-end gap-2">
                                            <button class="resend-mail-btn w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all flex items-center justify-center border border-indigo-100" title="Resend Assignment Mail" data-userid="${u.id ?? u.Id}" data-examid="${examId}">
                                                <i class="fas fa-envelope text-[10px]"></i>
                                            </button>
                                            <button class="remove-enroll-btn unassign-user-btn w-8 h-8 rounded-lg bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all flex items-center justify-center border border-rose-100" data-userid="${u.id ?? u.Id}" data-examid="${examId}">
                                                <i class="fas fa-user-minus text-[10px]"></i>
                                            </button>
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                                </table>
                            </div>
                            ${assignedUsers.length === 0 ? '<div class="p-12 text-center text-slate-400 font-bold uppercase tracking-widest">No active enrollments for this exam</div>' : ''}
                        </div>
                    `,
                    width: '1000px',
                    showConfirmButton: false,
                    showCloseButton: true,
                    customClass: { popup: 'rounded-3xl' },
                    didOpen: () => {
                        if (assignedUsers.length > 0) {
                            $('#swalAssignedTable').DataTable({
                                pageLength: 5,
                                lengthMenu: [5, 10, 25],
                                language: { search: "", searchPlaceholder: "Filter enrolled students..." }
                            });
                            $('.dataTables_filter input').addClass('bg-slate-50 border-slate-200 rounded-xl px-4 py-2 text-[10px] focus:ring-0 outline-none mb-4');
                        }
                    }
                });
            }

            window.unassignAllStudentsFromExam = function(examId) {
                Swal.fire({
                    title: 'Clear All Assignments?',
                    text: 'This will permanently remove all enrolled students from this exam and wipe their attempts. This action cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Clear All',
                    cancelButtonText: 'Cancel',
                    customClass: {
                        confirmButton: 'bg-rose-600 text-white px-8 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
                        cancelButton: 'text-slate-500 font-bold uppercase text-xs tracking-widest px-8 py-3'
                    },
                    buttonsStyling: false
                }).then(result => {
                    if (result.isConfirmed) {
                        Swal.fire({ title: 'Clearing Enrollments...', didOpen: () => Swal.showLoading() });
                        $.post('/Admin/RemoveAllStudentsFromExam', { examId }, function(r) {
                            if (r.success) {
                                Swal.fire({ icon: 'success', title: 'Cleared', text: r.message, timer: 1500, showConfirmButton: false }).then(() => {
                                    Swal.close();
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire({ icon: 'error', title: 'Failed', text: r.message });
                            }
                        });
                    }
                });
            };

            $(document).on('click', '.unassign-user-btn, .remove-enroll-btn', function() {
                const btn = $(this);
                const examId = btn.data('examid');
                const userId = btn.data('userid');
                const row = btn.closest('tr');

                if (confirm('Are you sure you want to revoke this student\'s access?')) {
                    // Show a spinner on the button
                    const icon = btn.find('i');
                    const originalClass = icon.attr('class');
                    icon.attr('class', 'fas fa-spinner fa-spin text-[10px]');
                    btn.prop('disabled', true);

                    $.post('/Admin/RemoveStudentFromExam', { examId, studentId: userId }, function(r) {
                        if (r.success) {
                            showStatus('Student access revoked successfully');
                            
                            // Remove from DataTable
                            const table = $('#swalAssignedTable').DataTable();
                            table.row(row).remove().draw();
                        } else {
                            showStatus('Failed: ' + (r.message || 'Error occurred'), true);
                            icon.attr('class', originalClass);
                            btn.prop('disabled', false);
                        }
                    }).fail(function() {
                        showStatus('Connection error', true);
                        icon.attr('class', originalClass);
                        btn.prop('disabled', false);
                    });
                }
            });

            // Handle Resend Email with Spinner
            $(document).on('click', '.resend-mail-btn', async function(e) {
                e.preventDefault();
                const $btn = $(this);
                const $icon = $btn.find('i');
                const userId = $btn.attr('data-userid');
                const examId = $btn.attr('data-examid');

                if (!userId) return;

                // UI Feedback: Spinner
                const originalClass = $icon.attr('class');
                $icon.attr('class', 'fas fa-spinner fa-spin text-[10px]');
                $btn.prop('disabled', true).addClass('opacity-50');

                try {
                    const res = await fetch(`/Admin/ResendAssignmentEmail?examId=${examId}&userId=${userId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
                    });
                    const result = await res.json();

                    if (result.success) {
                        showStatus('Reminder sent successfully');
                        $btn.removeClass('bg-indigo-50 text-indigo-600').addClass('bg-emerald-500 text-white border-emerald-600');
                        $icon.attr('class', 'fas fa-check text-[10px]');
                        // Don't restore icon if success, keep it as checkmark
                        return; 
                    } else {
                        showStatus('Failed: ' + result.message, true);
                    }
                } catch (e) {
                    showStatus('Connection Error', true);
                } finally {
                    // Only restore icon if it's NOT a success checkmark
                    if (!$btn.hasClass('bg-emerald-500')) {
                        $icon.attr('class', originalClass);
                        $btn.prop('disabled', false).removeClass('opacity-50');
                    }
                }
            });

            // MODAL LOGIC FOR CLONE
            $(document).on('click', '.clone-btn', async function() {
                const oldExamId = $(this).data('examid');
                Swal.fire({ title: 'Loading...', didOpen: () => Swal.showLoading() });
                
                try {
                    const waves = await $.getJSON(wavesUrl);
                    let wavesHtml = '<option value="">-- SELECT TARGET BATCH --</option>';
                    waves.forEach(w => wavesHtml += `<option value="${w.id ?? w.Id}">${escapeHtml((w.waveName ?? w.WaveName).toUpperCase())}</option>`);

                    Swal.fire({
                        title: `<div class="text-left border-b border-slate-100 pb-4"><p class="text-[10px] font-bold text-amber-600 uppercase tracking-[0.2em] mb-1">Create a copy of this exam with new dates</p><p class="text-2xl font-black uppercase text-slate-900">CLONE EXAM INSTANCE</p></div>`,
                        html: `
                            <div class="mt-8 text-left space-y-4">
                                <div><label class="block text-xs font-bold text-slate-500 uppercase mb-2">New Title (Optional)</label><input id="clone-title" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-4 rounded-xl outline-none focus:border-amber-500 font-bold" placeholder="Leave empty to use original"></div>
                                <div><label class="block text-xs font-bold text-slate-500 uppercase mb-2">Target Batch</label><select id="clone-wave" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-4 rounded-xl outline-none focus:border-amber-500 font-bold">${wavesHtml}</select></div>
                                <div><label class="block text-xs font-bold text-slate-500 uppercase mb-2">New Start Time</label><input type="datetime-local" id="clone-start" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-4 rounded-xl outline-none focus:border-amber-500 font-bold"></div>
                                <div><label class="block text-xs font-bold text-slate-500 uppercase mb-2">New End Time</label><input type="datetime-local" id="clone-end" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-4 rounded-xl outline-none focus:border-amber-500 font-bold"></div>
                            </div>
                        `,
                        width: '800px',
                        showCancelButton: true,
                        confirmButtonText: 'Confirm Clone',
                        cancelButtonText: 'Cancel',
                        customClass: {
                           confirmButton: 'bg-amber-600 hover:bg-amber-700 text-white px-8 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
                           cancelButton: 'text-slate-500 font-bold uppercase text-xs tracking-widest px-8 py-3'
                        },
                        buttonsStyling: false,
                        preConfirm: () => {
                            const newTitle = document.getElementById('clone-title').value;
                            const newWaveId = document.getElementById('clone-wave').value;
                            const newStart = document.getElementById('clone-start').value;
                            const newEnd = document.getElementById('clone-end').value;

                            if (!newWaveId) { Swal.showValidationMessage('Please select a target batch'); return false; }
                            if (!newStart || !newEnd) { Swal.showValidationMessage('Start and End times are required'); return false; }
                            if (new Date(newEnd) <= new Date(newStart)) { Swal.showValidationMessage('End time must be after start time'); return false; }

                            return {
                                OldExamId: oldExamId,
                                NewWaveId: parseInt(newWaveId),
                                NewStartTime: newStart,
                                NewEndTime: newEnd,
                                NewTitle: newTitle || null
                            };
                        }
                    }).then(result => {
                        if (result.isConfirmed) {
                            Swal.fire({ title: 'Cloning...', didOpen: () => Swal.showLoading() });
                            $.ajax({
                                url: '/Admin/CloneExam',
                                type: 'POST',
                                contentType: 'application/json',
                                data: JSON.stringify(result.value),
                                success: function(r) {
                                    if(r.success) {
                                        Swal.fire({ icon: 'success', title: 'Exam Cloned', text: 'New Exam ID: ' + r.newExamId, timer: 1500, showConfirmButton: false });
                                        setTimeout(() => location.reload(), 1500);
                                    } else {
                                        Swal.fire({ icon: 'error', title: 'Error', text: r.message });
                                    }
                                },
                                error: function() {
                                    Swal.fire({ icon: 'error', title: 'Error', text: 'Network request failed' });
                                }
                            });
                        }
                    });
                } catch(e) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to fetch batches data.' });
                }
            });
            // --- EXCEL IMPORT LOGIC ---
            let currentExamIdForImport = 0;

            $(document).on('click', '.import-questions-btn', function() {
                currentExamIdForImport = $(this).data('examid');
                
                Swal.fire({
                    title: '<span class="text-xl font-black text-slate-800 dark:text-white tracking-tight uppercase">Excel Import Guide</span>',
                    html: `
                        <div class="text-left text-xs font-bold space-y-3 mb-2 bg-slate-50 dark:bg-slate-900 text-slate-700 dark:text-slate-300 p-4 rounded-2xl border border-slate-200 dark:border-slate-800" style="direction: ltr;">
                            <p class="text-rose-600 font-black uppercase text-[10px] mb-2 tracking-widest border-b border-rose-100 dark:border-rose-900 pb-2"><i class="fas fa-exclamation-triangle"></i> Mandatory Column Structure</p>
                            <ul class="list-disc list-inside space-y-1 ml-1 text-[11px]">
                                <li><b>Col 1:</b> Question Text</li>
                                <li><b>Col 2:</b> Category ID (Number)</li>
                                <li><b>Col 3:</b> Points (Number)</li>
                                <li><b>Col 4:</b> Difficulty (1=Easy, 2=Mid, 3=Hard)</li>
                                <li><b>Col 5 & 6:</b> Choice A Text &nbsp;|&nbsp; IsCorrect (TRUE/FALSE)</li>
                                <li><b>Col 7 & 8:</b> Choice B Text &nbsp;|&nbsp; IsCorrect (TRUE/FALSE)</li>
                                <li><b>Col 9 & 10:</b> Choice C Text &nbsp;|&nbsp; IsCorrect (TRUE/FALSE)</li>
                                <li><b>Col 11 & 12:</b> Choice D Text &nbsp;|&nbsp; IsCorrect (TRUE/FALSE)</li>
                                <li><b>Col 13:</b> Topic ID (Optional Number)</li>
                            </ul>
                            <div class="mt-3 bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400 p-3 rounded-lg text-[10px]">
                                <b>Note:</b> The first row is treated as a header and will be skipped. Only 4 choices are evaluated.
                            </div>
                        </div>
                    `,
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonText: '<i class="fas fa-upload mr-1"></i> Selection Override',
                    cancelButtonText: 'Cancel',
                    customClass: {
                        confirmButton: 'bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-xl font-bold uppercase text-xs tracking-widest shadow-lg',
                        cancelButton: 'text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 px-6 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
                        popup: 'bg-white dark:bg-slate-950 rounded-[32px] border border-slate-200 dark:border-slate-800 shadow-2xl'
                    },
                    buttonsStyling: false
                }).then((r) => {
                    if(r.isConfirmed) $('#excelQuestionInput').click();
                });
            });

            $('#excelQuestionInput').on('change', function() {
                const file = this.files[0];
                if (!file || currentExamIdForImport === 0) return;

                const formData = new FormData();
                formData.append('examId', currentExamIdForImport);
                formData.append('excelFile', file);

                Swal.fire({
                    title: 'Importing Questions',
                    text: 'Please wait while we process the Excel file...',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                $.ajax({
                    url: '/Admin/ImportQuestionsFromExcel',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(r) {
                        if (r.success) {
                            Swal.fire({ icon: 'success', title: 'Import Successful', text: r.message });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Import Failed', text: r.message });
                        }
                        $('#excelQuestionInput').val(''); // Reset input
                    },
                    error: function() {
                        Swal.fire({ icon: 'error', title: 'Network Error', text: 'Failed to communicate with server.' });
                        $('#excelQuestionInput').val('');
                    }
                });
            });
        });
    </script>
}
