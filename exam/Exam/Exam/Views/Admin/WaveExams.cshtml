@model IEnumerable<Exam.DTOs.adminExamDto>
@{
    ViewData["Title"] = "Exam Control Center";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var examTypes = ViewBag.ExamTypes as IEnumerable<Exam.DTOs.ExamTypeDto> ?? new List<Exam.DTOs.ExamTypeDto>();
}

<!-- Filters Area -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-8 shadow-sm">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Search & Filter</h2>
            <p class="text-xl font-bold">Exam Management Matrix</p>
        </div>
        
        <div class="flex flex-wrap items-center gap-4">
            @if (User.IsInRole("Admin"))
            {
                <button onclick="window.parent.openNewTab('Create Protocol', 'fas fa-plus', '@Url.Action("Create", "Exams", new { type = "wave" })');" class="bg-brand-600 hover:bg-brand-700 text-white px-5 py-3 rounded-xl text-sm font-bold shadow-lg transition-all flex items-center gap-2 mr-4">
                    <i class="fas fa-plus"></i>
                    <span>Create Wave Exam</span>
                </button>
                <button id="bulkAssignWaveBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-3 rounded-xl text-sm font-bold shadow-lg transition-all flex items-center gap-2 mr-4 hidden">
                    <i class="fas fa-users-cog"></i>
                    <span>Bulk Assign Wave Exams</span>
                </button>
            }
            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Classification Hub</label>
                <select id="examTypeFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 outline-none transition-all min-w-[220px]">
                    <option value="0">ALL WAVE EXAM TYPES</option>
                    @foreach (var t in examTypes)
                    {
                        <option value="@t.Id">@t.TypeName.ToUpper()</option>
                    }
                </select>
            </div>

            <div id="waveFilterContainer" class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Target Wave</label>
                <select id="waveFilter" class="bg-slate-50 dark:bg-slate-950 border border-brand-500/30 rounded-xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 outline-none min-w-[220px]">
                    <option value="0">-- SELECT BATCH --</option>
                    @if (ViewBag.Waves != null)
                    {
                        foreach(var w in ViewBag.Waves)
                        {
                            <option value="@w.Id">@w.WaveName.ToUpper()</option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Hidden File Input for Excel Import -->
<input type="file" id="excelQuestionInput" accept=".xlsx, .xls" style="display:none;" />

<!-- Table Area -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table id="examsTable" class="saas-table">
            <thead>
                <tr>
                    <th>Exam Title</th>
                    <th>Category</th>
                    <th>Batch/Wave</th>
                    <th>Availability</th>
                    <th class="text-center">Status</th>
                    <th class="text-right px-8">Actions</th>
                </tr>
            </thead>
            <tbody id="examsTbody">
                @foreach (var exam in Model)
                {
                    <tr>
                        <td>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400">
                                    <i class="fas fa-file-code"></i>
                                </div>
                                <div class="flex flex-col">
                                    <span class="font-bold text-slate-900 dark:text-white">@exam.Title</span>
                                    <div class="flex items-center gap-2">
                                        <span class="text-[10px] font-bold text-slate-400 dark:text-slate-600">ID: @exam.Id.ToString("D4")</span>
                                        @if (exam.Stats != null && exam.Stats.TotalQuestions > 0)
                                        {
                                            <button type="button" class="show-stats-btn text-[9px] font-black bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400 px-2 py-0.5 rounded-md hover:bg-brand-600 hover:text-white transition-all" 
                                                    data-stats='@Json.Serialize(exam.Stats)'>
                                                <i class="fas fa-layer-group mr-1"></i> @exam.Stats.TotalQuestions Qs
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-lg text-[10px] font-bold uppercase tracking-wider">@exam.ExamType</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(exam.ExamType) && exam.ExamType.ToLower().Contains("wave"))
                            {
                                <span class="text-xs font-bold text-brand-600 dark:text-brand-400 uppercase">@(string.IsNullOrEmpty(exam.WaveName) ? "GLOBAL" : exam.WaveName)</span>
                            }
                            else
                            {
                                <span class="text-xs font-bold text-slate-400 uppercase">-</span>
                            }
                        </td>
                        <td>
                            <div class="flex flex-col">
                                <span class="text-xs font-bold">@exam.StartTime.ToString("MMM d, HH:mm")</span>
                                <span class="text-[10px] font-bold text-slate-400">@exam.EndTime.ToString("MMM d, HH:mm")</span>
                            </div>
                        </td>
                        <td class="text-center">
                            @if (exam.IsActive)
                            {
                                <span class="inline-flex items-center gap-1.5 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-emerald-50 dark:bg-emerald-500/10 rounded-full">
                                    <i class="fas fa-circle text-[6px] animate-pulse"></i>
                                    ACTIVE
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 text-slate-400 text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-slate-100 dark:bg-slate-800/50 rounded-full">
                                    <i class="fas fa-circle text-[6px]"></i>
                                    INACTIVE
                                </span>
                            }
                        </td>
                        <td class="text-right px-8">
                            <div class="flex items-center justify-end gap-2">
                                <a href="@Url.Action("Edit", "Exams", new { id = exam.Id })" class="p-2.5 text-slate-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl" title="Configure">
                                    <i class="fas fa-cog"></i>
                                </a>
                                <button class="p-2.5 text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl import-questions-btn" data-examid="@exam.Id" title="Import Questions (Excel)">
                                    <i class="fas fa-file-excel"></i>
                                </button>
                                <button class="p-2.5 text-slate-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl assign-btn" data-examid="@exam.Id" data-isactive="@exam.IsActive.ToString().ToLower()" title="Assign Students">
                                    <i class="fas fa-users"></i>
                                </button>
                                <button class="p-2.5 text-slate-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl clone-btn" data-examid="@exam.Id" title="Clone">
                                    <i class="fas fa-copy"></i>
                                </button>
                                <button class="p-2.5 text-slate-400 hover:text-rose-600 dark:hover:text-rose-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl delete-btn"
                                        data-examid="@exam.Id"
                                        data-examtitle="@exam.Title"
                                        title="Delete Exam">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>




@section Scripts {
    <script>
        $(function () {
            const examsUrl = '@Url.Action("GetWaveExamsForFilter", "Admin")';
            const editExamBaseUrl = '@Url.Action("Edit", "Exams")';
            const wavesUrl = '@Url.Action("GetWaves", "Admin")';
            function escapeHtml(str) { return String(str ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
            function formatDate(value) { if (!value) return ''; let d = new Date(value); return d.toLocaleString(undefined, { month: 'short', day: '2-digit', hour: '2-digit', minute: '2-digit' }); }

            function showStatus(msg, isError = false) {
                const toastId = 'custom-toast-' + Date.now();
                const bg = isError ? '#ef4444' : '#10b981';
                const toastHtml = `
                    <div id="${toastId}" style="position:fixed; top:20px; right:20px; background:${bg}; color:white; padding:12px 24px; border-radius:12px; z-index:999999; font-weight:bold; font-size:13px; box-shadow:0 10px 15px -3px rgba(0,0,0,0.1); animation: slideIn 0.3s ease-out; display:flex; align-items:center; gap:8px;">
                        <i class="fas ${isError ? 'fa-exclamation-circle' : 'fa-check-circle'}"></i>
                        <span>${msg}</span>
                    </div>
                    <style>
                        @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
                    </style>
                `;
                $('body').append(toastHtml);
                setTimeout(() => {
                    $(`#${toastId}`).fadeOut(300, function() { $(this).remove(); });
                }, 3000);
            }
            function renderExamRows(exams) {
                if (!exams || exams.length === 0) return '';
                return exams.map(exam => {
                    const id = exam.id ?? exam.Id;
                    const isActive = exam.isActive ?? exam.IsActive;
                    return `
                        <tr>
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400"><i class="fas fa-file-code"></i></div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-900 dark:text-white">${escapeHtml(exam.title ?? exam.Title)}</span>
                                        <div class="flex items-center gap-2">
                                            <span class="text-[10px] font-bold text-slate-400 dark:text-slate-600">ID: ${String(id).padStart(4, '0')}</span>
                                            ${exam.stats && exam.stats.totalQuestions > 0 ? `
                                                <button type="button" class="show-stats-btn text-[9px] font-black bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400 px-2 py-0.5 rounded-md hover:bg-brand-600 hover:text-white transition-all" 
                                                        data-stats='${JSON.stringify(exam.stats)}'>
                                                    <i class="fas fa-layer-group mr-1"></i> ${exam.stats.totalQuestions} Qs
                                                </button>
                                            ` : ''}
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-lg text-[10px] font-bold uppercase tracking-wider">${escapeHtml(exam.examType ?? exam.ExamType ?? 'N/A')}</span></td>
                            <td>
                                ${ (exam.examType ?? exam.ExamType ?? '').toLowerCase().includes('wave') ? 
                                    `<span class="text-xs font-bold text-brand-600 dark:text-brand-400 uppercase">${escapeHtml(exam.waveName ?? exam.WaveName ?? 'GLOBAL')}</span>` 
                                    : `<span class="text-xs font-bold text-slate-400 uppercase">-</span>` 
                                }
                            </td>
                            <td>
                                <div class="flex flex-col">
                                    <span class="text-xs font-bold">${formatDate(exam.startTime ?? exam.StartTime)}</span>
                                    <span class="text-[10px] font-bold text-slate-400">${formatDate(exam.endTime ?? exam.EndTime)}</span>
                                </div>
                            </td>
                            <td class="text-center">
                                ${isActive ? '<span class="inline-flex items-center gap-1.5 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-emerald-50 dark:bg-emerald-500/10 rounded-full"><i class="fas fa-circle text-[6px] animate-pulse"></i>ACTIVE</span>' : '<span class="inline-flex items-center gap-1.5 text-slate-400 text-[10px] font-bold uppercase tracking-widest px-3 py-1 bg-slate-100 dark:bg-slate-800/50 rounded-full"><i class="fas fa-circle text-[6px]"></i>INACTIVE</span>'}
                            </td>
                            <td class="text-right px-8">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="${editExamBaseUrl}/${id}" class="p-2.5 text-slate-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl"><i class="fas fa-cog"></i></a>
                                    <button class="p-2.5 text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl import-questions-btn" data-examid="${id}" title="Import Questions (Excel)">
                                        <i class="fas fa-file-excel"></i>
                                    </button>
                                    <button class="p-2.5 text-slate-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl assign-btn" 
                                            data-examid="${id}" 
                                            data-isactive="${isActive.toString().toLowerCase()}"
                                            data-wave="${escapeHtml(exam.waveName ?? exam.WaveName ?? '')}">
                                        <i class="fas fa-user-plus"></i>
                                    </button>
                                    <button class="p-2.5 text-slate-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl clone-btn" data-examid="${id}"><i class="fas fa-copy"></i></button>
                                    <button class="p-2.5 text-slate-400 hover:text-rose-600 dark:hover:text-rose-400 transition-colors bg-slate-50 dark:bg-slate-800 rounded-xl delete-btn" data-examid="${id}" data-examtitle="${escapeHtml(exam.title ?? exam.Title)}" title="Delete Exam"><i class="fas fa-trash-alt"></i></button>
                                </div>
                            </td>
                        </tr>`;
                }).join('');
            }

            let table = $('#examsTable').DataTable({
                pageLength: 10,
                deferRender: true,
                processing: true,
                orderClasses: false,
                language: { search: "", searchPlaceholder: "Search exams..." }
            });
            $('.dataTables_filter input').addClass('bg-slate-50 border-slate-200 rounded-xl px-4 py-2 text-xs focus:ring-0 outline-none mb-4');

            // Standard Filter Logic
            $('#examTypeFilter').on('change', async function() {
                const typeId = parseInt($(this).val());
                const waveId = parseInt($('#waveFilter').val()) || 0;
                await refreshExams(typeId, waveId);
            });
                    // منطق حذف الامتحان
        $(document).on('click', '.delete-btn', function() {
            const examId = $(this).data('examid');
            const examTitle = $(this).data('examtitle');

            Swal.fire({
                title: 'Are you sure?',
                html: `You are about to delete <br><b class="text-rose-600">${examTitle}</b><br>This action cannot be undone!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Delete it!',
                cancelButtonText: 'Cancel',
                customClass: {
                    confirmButton: 'bg-rose-600 hover:bg-rose-700 text-white px-8 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
                    cancelButton: 'text-slate-500 font-bold uppercase text-xs tracking-widest px-8 py-3'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Deleting...', didOpen: () => Swal.showLoading() });

                    $.ajax({
                        url: '/Exams/DeleteExam',
                        type: 'POST',
                        data: { examid: examId },
                        success: function(r) {
                            if (r.success) {
                                Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Exam has been removed.', timer: 1500, showConfirmButton: false });
                                // تحديث الجدول أو الصفحة
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire({ icon: 'error', title: 'Error', text: r.message || 'Could not delete exam.' });
                            }
                        },
                            error: function() {
                            Swal.fire({ icon: 'error', title: 'Error', text: 'Network request failed.' });
                        }
                    });
                }
            });
        });

            $(document).on('click', '.show-stats-btn', function() {
                const stats = $(this).data('stats');
                if (!stats) return;

                let html = `<div class="text-left space-y-4 max-h-[400px] overflow-y-auto px-2">`;
                stats.categories.forEach(cat => {
                    html += `
                        <div class="border-b border-slate-100 dark:border-slate-800 pb-3 last:border-0">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-black text-slate-900 dark:text-white uppercase tracking-wider">${cat.categoryName}</span>
                                <span class="bg-brand-100 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400 text-[10px] font-black px-2 py-0.5 rounded-full">${cat.count} Questions</span>
                            </div>
                            <div class="grid grid-cols-1 gap-1 pl-3">
                                ${cat.topics.map(t => `
                                    <div class="flex justify-between text-[10px] text-slate-500 dark:text-slate-400 italic">
                                        <span>• ${t.topicName}</span>
                                        <span class="font-bold">${t.count}</span>
                                    </div>
                                `).join('')}
                            </div>
                        </div>`;
                });
                html += `</div>`;

                Swal.fire({
                    title: '<span class="text-sm font-black uppercase tracking-widest text-slate-400">Question Bank Summary</span>',
                    html: html,
                    confirmButtonText: 'CLOSE',
                    customClass: {
                        popup: 'rounded-[32px] dark:bg-slate-900 border border-slate-200 dark:border-slate-800',
                        confirmButton: 'bg-slate-900 dark:bg-brand-600 text-white px-8 py-3 rounded-2xl font-bold text-xs'
                    }
                });
            });

            $('#waveFilter').on('change', async function() {
                const waveId = $(this).val();
                const typeId = $('#examTypeFilter').val();
                await refreshExams(typeId, waveId);
                if (waveId && waveId !== '0') {
                    $('#bulkAssignWaveBtn').removeClass('hidden');
                } else {
                    $('#bulkAssignWaveBtn').addClass('hidden');
                }
            });

            async function refreshExams(tid, wid) {
                const exams = await $.getJSON(examsUrl, { examTypeId: tid, waveId: wid });
                table.destroy();
                $('#examsTbody').html(renderExamRows(exams));
                table = $('#examsTable').DataTable({
                    pageLength: 10,
                    deferRender: true,
                    processing: true,
                    orderClasses: false,
                    language: { search: "", searchPlaceholder: "Search exams..." }
                });
                $('.dataTables_filter input').addClass('bg-slate-50 border-slate-200 rounded-xl px-4 py-2 text-xs focus:ring-0 outline-none mb-4');
            }

            $('#bulkAssignWaveBtn').on('click', function() {
                const waveId = $('#waveFilter').val();
                const waveName = $('#waveFilter option:selected').text();
                
                if (!waveId || waveId === '0') return;

                Swal.fire({ title: 'Fetching Wave Personnel...', didOpen: () => Swal.showLoading() });
                
                $.getJSON(`/Admin/GetUsersByWaveId?waveId=${waveId}`).done(users => {
                    if (!users || users.length === 0) {
                        Swal.fire({ icon: 'info', title: 'No Personnel', text: 'There are no users enrolled in this wave.' });
                        return;
                    }

                    Swal.fire({
                        title: `<div class="text-left border-b border-slate-100 pb-4"><p class="text-[10px] font-bold text-indigo-600 uppercase tracking-[0.2em] mb-1">Bulk Assign Wave Exams to</p><p class="text-2xl font-black italic uppercase text-slate-900">${waveName}</p></div>`,
                        html: `
                            <div class="mt-8 text-left">
                                <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
                                    <div class="flex items-center gap-3 bg-slate-50 dark:bg-slate-800/50 p-2.5 rounded-xl border border-slate-200 dark:border-slate-700">
                                        <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest pl-2">Filter by Role</label>
                                        <div class="flex items-center gap-3 text-[10px] font-bold">
                                            <label class="flex items-center gap-1.5 cursor-pointer">
                                                <input type="checkbox" id="bulkRolePharmacist" class="bulk-swal-role-cb w-3.5 h-3.5 accent-indigo-500 rounded" checked>
                                                <span>PHARMACISTS</span>
                                            </label>
                                            <label class="flex items-center gap-1.5 cursor-pointer">
                                                <input type="checkbox" id="bulkRoleAssistant" class="bulk-swal-role-cb w-3.5 h-3.5 accent-indigo-500 rounded" checked>
                                                <span>ASSISTANTS</span>
                                            </label>
                                            <label class="flex items-center gap-1.5 cursor-pointer">
                                                <input type="checkbox" id="bulkRoleOther" class="bulk-swal-role-cb w-3.5 h-3.5 accent-indigo-500 rounded" checked>
                                                <span>OTHERS</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="overflow-x-auto">
                                    <table id="bulkSwalUserTable" class="saas-table display w-full text-xs">
                                    <thead>
                                        <tr class="bg-slate-50">
                                            <th class="w-10"><input type="checkbox" id="bulkSelectAllSwal" class="w-4 h-4 accent-indigo-500"></th>
                                            <th>Student</th>
                                            <th>Code</th>
                                            <th>Role</th>
                                            <th>Branch</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${users.map(u => {
                                            return `
                                                <tr class="border-b border-slate-50 transition-colors cursor-pointer hover:bg-slate-50">
                                                    <td><input type="checkbox" class="bulk-user-cb w-4 h-4 accent-indigo-500" value="${u.id ?? u.Id}"></td>
                                                    <td>
                                                        <div class="flex flex-col">
                                                            <div class="flex items-center gap-2">
                                                                <span class="font-bold text-slate-900">${u.fullName ?? u.FullName ?? u.userName ?? u.UserName}</span>
                                                            </div>
                                                            <span class="text-[9px] text-slate-500 uppercase">${u.email ?? u.Email}</span>
                                                        </div>
                                                    </td>
                                                    <td class="font-bold text-slate-500">${u.userCode ?? u.UserCode ?? '--'}</td>
                                                    <td>
                                                        <span class="bulk-js-role-name px-2 py-0.5 rounded-full text-[8px] font-black uppercase bg-slate-100 text-slate-500 border border-slate-200">
                                                            ${u.roleName ?? u.RoleName ?? 'User'}
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="text-[9px] font-bold text-slate-400 uppercase">
                                                            ${u.branchName ?? u.BranchName ?? 'N/A'}
                                                        </span>
                                                    </td>
                                                </tr>
                                            `;
                                        }).join('')}
                                    </tbody>
                                </table>
                            </div>
                        `,
                        width: '1000px',
                        showCancelButton: true,
                        confirmButtonText: 'Assign All Exams',
                        cancelButtonText: 'Cancel',
                        customClass: {
                           confirmButton: 'bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
