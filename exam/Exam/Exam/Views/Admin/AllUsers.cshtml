                            toast: true, 
                            position: 'top-end', 
                            showConfirmButton: false, 
                            timer: 3000,
                            background: '#f8fafc'
                        });
                    }
                    else Swal.fire('Error', res.message, 'error');
                }).catch(() => Swal.fire('Error', 'Request failed', 'error'));
            });
        }



