        function applyPersonnelRowFromServer(userId, res) {
            const $tr = $('tr[data-user-id]').filter(function () { return $(this).attr('data-user-id') === userId; });
            if (!$tr.length) return;
            $tr.attr('data-email', res.email || '');
            $tr.attr('data-username', res.fullName || res.userName || '');
            $tr.attr('data-usercode', res.userCode || '');
            $tr.attr('data-branch-id', res.branchId == null ? '' : String(res.branchId));
            const un = res.fullName || res.userName || '';
            $tr.find('.js-user-display').text(un.replace(/_/g, ' '));
            $tr.find('.js-user-avatar').text(un ? un.charAt(0).toUpperCase() : '?');
            const sub = res.userCode ? res.userCode : ('SYS-' + userId.substring(0, 8).toUpperCase());
            $tr.find('.js-user-sub').text(sub);
            $tr.find('.js-user-email').text(res.email || '');
            $tr.find('.js-user-branch-name').text((res.branchName || 'GLOBAL').toUpperCase());
            $tr.find('.js-user-code').text(res.userCode || '');
            const $tbl = $tr.closest('table.datatable');
            if ($tbl.length && $.fn.DataTable.isDataTable($tbl[0])) {
                try { $tbl.DataTable().row($tr).invalidate('dom').draw(false); } catch (e) { /* ignore */ }
            }
        }

        function openEditUserModal(userId, email, userName, userCode, branchId) {
            const getVal = (obj, prop) => {
                if (!obj) return "";
                return obj[prop.charAt(0).toLowerCase() + prop.slice(1)] || obj[prop] || "";
            };
            const $tr = $('tr[data-user-id="' + userId + '"]');
            const shiftId = $tr.attr('data-shift-id') || '0';
            const oldBranchKey = (branchId == null || branchId === '') ? '' : String(branchId);
            let branchOptions = '<option value="">-- NO BRANCH --</option>';
            branchesData.forEach(b => {
                let name = getVal(b, 'BranchName');
                let bid = getVal(b, 'Id');
                let sel = (oldBranchKey !== '' && String(bid) === oldBranchKey) ? ' selected' : '';
                branchOptions += `<option value="${bid}"${sel}>${(name || '').toUpperCase()}</option>`;
            });

            let shiftOptions = '<option value="0">-- NO SHIFT --</option>';
            shiftsData.forEach(s => {
                let name = s.shiftName || s.ShiftName || '';
                let sid = s.id || s.Id;
                let sel = (shiftId !== '0' && String(sid) === String(shiftId)) ? ' selected' : '';
                shiftOptions += `<option value="${sid}"${sel}>${(name || '').toUpperCase()}</option>`;
            });

            const disabledAttr = isHR ? 'disabled' : '';

            Swal.fire({
                title: 'Edit Personnel',
                html: `
                    <div class="text-left space-y-3 p-2">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Email</label>
                            <input id="editEmail" type="email" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:border-brand-500" ${disabledAttr} />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">User name</label>
                            <input id="editUserName" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:border-brand-500" ${disabledAttr} />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">User code</label>
                            <input id="editUserCode" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:border-brand-500" ${disabledAttr} />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Branch</label>
                            <select id="editBranchId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:border-brand-500" ${disabledAttr}>${branchOptions}</select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Shift</label>
                            <select id="editShiftId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:border-brand-500">${shiftOptions}</select>
                        </div>
                    </div>`,
                showCancelButton: true,
                confirmButtonText: 'Save',
                confirmButtonColor: '#0284c7',
                cancelButtonText: 'Cancel',
                width: '520px',
                didOpen: () => {
                    document.getElementById('editEmail').value = email || '';
                    document.getElementById('editUserName').value = (userName || '').replace(/_/g, ' ');
                    document.getElementById('editUserCode').value = userCode || '';
                    const sel = document.getElementById('editBranchId');
                    sel.value = oldBranchKey;
                    if (oldBranchKey && sel.value !== oldBranchKey) {
                        const opt = Array.from(sel.options).find(o => String(o.value) === oldBranchKey);
                        if (opt) opt.selected = true;
                    }
                    const shiftSel = document.getElementById('editShiftId');
                    shiftSel.value = shiftId;
                },
                preConfirm: async () => {
                    const newShiftVal = document.getElementById('editShiftId').value || '0';
                    if (isHR) {
                        const r = await fetch('/Admin/UpdateUserShift', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            },
                            body: `userId=${userId}&newShiftId=${newShiftVal}`
                        });
                        const res = await r.json();
                        if (!res.success) {
                            Swal.showValidationMessage(res.message || 'Update failed');
                            return false;
                        }
                        return { isShiftOnly: true, newShiftId: newShiftVal };
                    } else {
                        const fd = new FormData();
                        fd.append('userId', userId);
                        fd.append('email', document.getElementById('editEmail').value.trim());
                        fd.append('userName', document.getElementById('editUserName').value.trim());
                        fd.append('userCode', document.getElementById('editUserCode').value.trim());
                        const newBr = document.getElementById('editBranchId').value || '';
                        if (newBr !== oldBranchKey)
                            fd.append('branchId', newBr);
                        
                        const profilePromise = fetch('/Admin/UpdateUserProfile', {
                            method: 'POST',
                            body: fd,
                            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
                        }).then(r => r.json());

                        const shiftPromise = fetch('/Admin/UpdateUserShift', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            },
                            body: `userId=${userId}&newShiftId=${newShiftVal}`
                        }).then(r => r.json());

                        const [profileRes, shiftRes] = await Promise.all([profilePromise, shiftPromise]);
                        if (!profileRes.success) {
                            Swal.showValidationMessage(profileRes.message || 'Profile update failed');
                            return false;
                        }
                        if (!shiftRes.success) {
                            Swal.showValidationMessage(shiftRes.message || 'Shift update failed');
                            return false;
                        }
                        return { ...profileRes, newShiftId: newShiftVal };
                    }
                }
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    if (result.value.isShiftOnly) {
                        location.reload();
                    } else {
                        const $tr = $('tr[data-user-id="' + userId + '"]');
                        $tr.attr('data-shift-id', result.value.newShiftId);
                        applyPersonnelRowFromServer(userId, result.value);
                        Swal.fire({ icon: 'success', title: 'Saved', toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
                        setTimeout(() => location.reload(), 1000);
                    }
                }
            });
        }

