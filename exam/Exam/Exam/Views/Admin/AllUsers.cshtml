                $('#importForm').on('submit', async function(e) {
            e.preventDefault();
            if(!cid) return Swal.fire('Error', 'Neural link not established.', 'error');

            const fd = new FormData(this);
            // إظهار الـ Overlay
            document.getElementById('importOverlay').style.display = 'flex';
            $('#btnImport').prop('disabled', true).css('opacity', 0.6);

            try {
                const response = await fetch(this.action + '?connectionId=' + cid, {
                    method: 'POST',
                    body: fd,
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
                });

                // تأكد إن الرد JSON قبل التحويل
                const contentType = response.headers.get("content-type");
                if (!response.ok || !contentType || !contentType.includes("application/json")) {
                    const errorText = await response.text();
                    throw new Error("Server returned non-json response or error status.");
                }

                const res = await response.json();

                // إخفاء السبينر فوراً قبل إظهار أي Alert
                hideImportOverlay();

                if(res.success) {
                    if (res.errors && res.errors.length > 0) {
                        let errHtml = '<ul class="text-left text-xs text-rose-500 overflow-y-auto max-h-48 mt-4 list-disc pl-4">';
                        res.errors.forEach(e => { errHtml += `<li>${String(e).replace(/</g,'&lt;')}</li>`; });
                        errHtml += '</ul>';

                        Swal.fire({
                            icon: 'warning',
                            title: 'Imported with Errors',
                            width: '640px',
                            html: `<p class="text-sm font-bold">${res.message}</p>${errHtml}`
                        }).then(() => location.reload());
                    } else {
                        Swal.fire({ icon: 'success', title: 'Ingestion Complete', timer: 2000 })
                            .then(() => location.reload());
                    }
                } else {
                    Swal.fire('Error', res.message || 'Import failed', 'error');
                }

            } catch(err) {
                console.error("Import Error:", err);
                hideImportOverlay(); // تأكيد الإخفاء في حالة الـ Catch
                Swal.fire('Error', 'Import request failed: ' + (err.message || 'Network error'), 'error');
            }
            // شلنا الـ finally وحطينا الإخفاء يدوي في كل مسار لضمان الدقة
        });
        function deactivateUser(userId) {
