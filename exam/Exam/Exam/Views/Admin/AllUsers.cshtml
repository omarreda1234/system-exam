                width: '520px',
                showLoaderOnConfirm: true,
                preConfirm: async () => {
                    const subject = document.getElementById('mailSubject').value.trim();
                    const message = document.getElementById('mailMessage').value.trim();
                    
                    if (!message) {
                        Swal.showValidationMessage('Message content cannot be empty');
                        return false;
                    }

                    try {
                        const fd = new FormData();
                        fd.append('userId', userId);
                        fd.append('subject', subject);
                        fd.append('message', message);

                        const response = await fetch('/Admin/SendCustomEmail', {
                            method: 'POST',
                            body: fd,
                            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
                        });
                        const res = await response.json();
                        if (!res.success) throw new Error(res.message);
                        return res;
                    } catch (error) {
                        Swal.showValidationMessage(`Error: ${error.message}`);
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Email Dispatched',
                        text: 'Your custom message has been sent successfully.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                }
            });
        }

        function resetPassword(userId) {
            Swal.fire({
                title: 'Reset Password?',
                text: "The user's password will be set to 'TempPass@123' and they will receive an email notification.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f59e0b',
                confirmButtonText: 'Yes, Reset and Email',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Admin/ResetUserPassword',
                        type: 'POST',
                        data: { userId: userId },
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Reset Successful!', res.message, 'success');
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}