        $(document).on('submit', '.ajax-update-form', async function(e) {
            e.preventDefault();
            const $form = $(this);
            const $select = $form.find('select');
            const type = $form.data('type');
            const fd = new FormData(this);
            
            $select.prop('disabled', true).addClass('opacity-50 cursor-wait');
            
            try {
                const r = await fetch(this.action, { 
                    method: 'POST', 
                    body: fd, 
                    headers: { 'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val() } 
                });
                const res = await r.json();
                
                if(res.success) {
                    Swal.fire({ 
                        icon: 'success', 
                        title: 'Updated', 
                        toast: true, 
                        position: 'top-end', 
                        showConfirmButton: false, 
                        timer: 3000,
                        background: '#f8fafc'
                    });
                    
                    // Update UI labels without refresh
                    const $row = $form.closest('tr');
                    if(type === 'role') {
                        const newRole = $form.find('select option:selected').text();
                        $row.find('td:nth-child(5) span').text(newRole);
                    } else if(type === 'shift') {
                        const $opt = $form.find('select option:selected');
                        const name = $opt.data('name');
                        const time = $opt.data('time');
                        
                        let html = '';
                        if(name) {
                            html = `<div class="flex flex-col">
                                        <span class="text-[10px] font-bold italic uppercase">${name}</span>
                                        <span class="text-[8px] font-bold text-slate-400">${time}</span>
                                    </div>`;
                        } else {
                            html = `<span class="text-[9px] font-bold text-rose-500/50 uppercase">Unassigned</span>`;
                        }
                        $row.find('td:nth-child(6)').html(html);
                    }
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            } catch(e) {
                Swal.fire('Error', 'Update communication failed', 'error');
            } finally {
                $select.prop('disabled', false).removeClass('opacity-50 cursor-wait');
            }
        });

