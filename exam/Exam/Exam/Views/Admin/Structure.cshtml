@using Exam.DTOs
@{
    ViewBag.Title = "Course Structure Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var examTypes = ViewBag.ExamTypes as IEnumerable<ExamTypeDto> ?? new List<ExamTypeDto>();
}

<div class="mb-8 bg-white dark:bg-slate-900 rounded-3xl p-6 sm:p-8 border border-slate-100 dark:border-slate-800 shadow-sm relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
        <i class="fas fa-sitemap text-8xl text-brand-500"></i>
    </div>
    <div class="relative z-10">
        <h2 class="text-2xl font-black text-slate-900 dark:text-white mb-2">Academic Hierarchy</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">Define the relationship between Exam Types, Categories, and Lecture Topics.</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    
    <!-- Level 1: Exam Types -->
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col h-[600px]">
        <div class="p-5 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50 flex items-center justify-between">
            <h3 class="font-black text-xs uppercase tracking-widest text-slate-500">1. Exam Varieties</h3>
            <button onclick="openTypeModal()" class="w-8 h-8 rounded-xl bg-brand-500 text-white flex items-center justify-center hover:scale-110 transition-all shadow-lg shadow-brand-500/20"><i class="fas fa-plus text-xs"></i></button>
        </div>
        <div class="flex-1 overflow-y-auto p-4 space-y-2 custom-scrollbar" id="typeList">
            @foreach (var type in examTypes)
            {
                <div class="type-item group p-4 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-100 dark:border-slate-700/50 cursor-pointer hover:border-brand-500 transition-all" 
                     data-id="@type.Id" data-name="@type.TypeName">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-white dark:bg-slate-800 shadow-sm flex items-center justify-center text-brand-500"><i class="fas fa-layer-group text-xs"></i></div>
                            <span class="font-bold text-sm text-slate-700 dark:text-slate-200">
                                @type.TypeName
                                <span onclick="copyId(event, @type.Id)" class="cursor-pointer hover:bg-slate-300 dark:hover:bg-slate-600 bg-slate-200 dark:bg-slate-700 px-2 py-0.5 rounded text-[10px] font-mono text-slate-600 dark:text-slate-300 ml-2 transition-all group/copy" title="Copy ID">ID: @type.Id <i class="far fa-copy ml-0.5 opacity-50 group-hover/copy:opacity-100"></i></span>
                            </span>
                        </div>
                        <button onclick="deleteType(@type.Id)" class="opacity-0 group-hover:opacity-100 p-2 text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-500/10 rounded-lg transition-all"><i class="fas fa-trash-alt text-xs"></i></button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Level 2: Categories -->
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col h-[600px]">
        <div class="p-5 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50 flex items-center justify-between">
            <h3 class="font-black text-xs uppercase tracking-widest text-slate-500">2. Mapped Categories</h3>
            <button id="addCatBtn" onclick="openCatModal()" class="hidden w-8 h-8 rounded-xl bg-indigo-500 text-white flex items-center justify-center hover:scale-110 transition-all shadow-lg shadow-indigo-500/20"><i class="fas fa-plus text-xs"></i></button>
        </div>
        <div id="categoryPlaceholder" class="flex-1 flex flex-col items-center justify-center p-8 text-center opacity-40">
            <i class="fas fa-arrow-left text-3xl mb-4"></i>
            <p class="text-sm font-bold">Select an Exam Variety to view categories</p>
        </div>
        <div class="hidden flex-1 overflow-y-auto p-4 space-y-2 custom-scrollbar" id="categoryList">
            <!-- Loaded via Ajax -->
        </div>
    </div>

    <!-- Level 3: Topics -->
    <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-sm overflow-hidden flex flex-col h-[600px]">
        <div class="p-5 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50 flex items-center justify-between">
            <h3 class="font-black text-xs uppercase tracking-widest text-slate-500">3. Lecture Topics</h3>
            <button id="addTopicBtn" onclick="openTopicModal()" class="hidden w-8 h-8 rounded-xl bg-orange-500 text-white flex items-center justify-center hover:scale-110 transition-all shadow-lg shadow-orange-500/20"><i class="fas fa-plus text-xs"></i></button>
        </div>
        <div id="topicPlaceholder" class="flex-1 flex flex-col items-center justify-center p-8 text-center opacity-40">
            <i class="fas fa-arrow-left text-3xl mb-4"></i>
            <p class="text-sm font-bold">Select a category to view lecture topics</p>
        </div>
        <div class="hidden flex-1 overflow-y-auto p-4 space-y-2 custom-scrollbar" id="topicList">
            <!-- Loaded via Ajax -->
        </div>
    </div>

</div>

<!-- Modals -->
<div class="modal fade" id="academicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white dark:bg-slate-900 border-0 rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8">
                <div class="flex items-center gap-4 mb-8">
                    <div id="modalIcon" class="w-12 h-12 rounded-2xl bg-brand-50 flex items-center justify-center text-brand-600">
                        <i class="fas fa-plus"></i>
                    </div>
                    <div>
                        <h5 id="modalTitle" class="text-xl font-black text-slate-900 dark:text-white">Add New Item</h5>
                        <p id="modalSub" class="text-xs text-slate-500 font-bold uppercase tracking-widest">Global Registry</p>
                    </div>
                </div>
                
                <form id="academicForm" class="space-y-6">
                    <input type="hidden" id="itemParentId" name="parentId" />
                    <input type="hidden" id="itemType" />
                    
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2 ml-1">Label Name</label>
                        <input type="text" id="itemName" name="name" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-100 dark:border-slate-700 rounded-2xl px-5 py-4 text-sm font-bold focus:ring-4 focus:ring-brand-500/10 outline-none transition-all" placeholder="Enter name..." required />
                    </div>

                    <div id="parentDisplay" class="hidden p-4 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-dashed border-slate-200 dark:border-slate-700">
                        <span class="text-[10px] font-bold text-slate-400 block mb-1">PARENT ASSOCIATION</span>
                        <span id="parentNameText" class="text-xs font-black text-brand-600 dark:text-brand-400">---</span>
                    </div>

                    <div class="flex gap-3 pt-4">
                        <button type="button" data-bs-dismiss="modal" class="flex-1 py-4 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-slate-200 transition-all">Cancel</button>
                        <button type="submit" class="flex-1 py-4 bg-brand-600 text-white rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-brand-700 shadow-xl shadow-brand-500/30 transition-all">Create Item</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .type-item.active, .cat-item.active {
        @@apply border-brand-500 bg-brand-50/30 dark:bg-brand-500/10 ring-2 ring-brand-500/20;
    }
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { @@apply bg-slate-200 dark:bg-slate-800 rounded-full; }
</style>

@section Scripts {
    <script>
        let currentTypeId = null;
        let currentCatId = null;

        // Selection Logic
        $(document).on('click', '.type-item', function() {
            $('.type-item').removeClass('active');
            $(this).addClass('active');
            currentTypeId = $(this).data('id');
            loadCategories(currentTypeId);
            $('#topicPlaceholder').show();
            $('#topicList').hide();
            $('#addTopicBtn').hide();
        });

        $(document).on('click', '.cat-item', function() {
            $('.cat-item').removeClass('active');
            $(this).addClass('active');
            currentCatId = $(this).data('id');
            loadTopics(currentCatId);
        });

        // Loaders
        function loadCategories(typeId) {
            $('#categoryPlaceholder').hide();
            $('#categoryList').show().html('<div class="p-8 text-center"><i class="fas fa-circle-notch fa-spin text-brand-500"></i></div>');
            $('#addCatBtn').show();

            $.get('@Url.Action("GetCategoriesByExamType", "Admin")', { examTypeId: typeId }, function(res) {
                let html = '';
                if (res.length === 0) html = '<div class="p-8 text-center text-xs font-bold text-slate-400">No categories found</div>';
                res.forEach(c => {
                    html += `
                        <div class="cat-item group p-4 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-100 dark:border-slate-700/50 cursor-pointer hover:border-indigo-500 transition-all" data-id="${c.id}">
                            <div class="flex items-center justify-between">
                                <span class="font-bold text-sm text-slate-700 dark:text-slate-200">
                                    ${c.categoryName}
                                    <span onclick="copyId(event, ${c.id})" class="cursor-pointer hover:bg-slate-300 dark:hover:bg-slate-600 bg-slate-200 dark:bg-slate-700 px-2 py-0.5 rounded text-[10px] font-mono text-slate-600 dark:text-slate-300 ml-2 transition-all group/copy" title="Copy ID">ID: ${c.id} <i class="far fa-copy ml-0.5 opacity-50 group-hover/copy:opacity-100"></i></span>
                                </span>
                                <button onclick="deleteCategory(${c.id})" class="opacity-0 group-hover:opacity-100 p-2 text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-500/10 rounded-lg transition-all"><i class="fas fa-trash-alt text-xs"></i></button>
                            </div>
                        </div>
                    `;
                });
                $('#categoryList').html(html);
            });
        }

        function loadTopics(catId) {
            $('#topicPlaceholder').hide();
            $('#topicList').show().html('<div class="p-8 text-center"><i class="fas fa-circle-notch fa-spin text-orange-500"></i></div>');
            $('#addTopicBtn').show();

            $.get('@Url.Action("GetTopicsByCategoryId", "Admin")', { categoryId: catId }, function(res) {
                let html = '';
                if (res.length === 0) html = '<div class="p-8 text-center text-xs font-bold text-slate-400">No topics found</div>';
                res.forEach(t => {
                    let dateHtml = '';
                    if (t.createdAt) {
                        const date = new Date(t.createdAt);
                        const formattedDate = date.toLocaleString('en-US', { month: 'short', year: 'numeric' });
                        dateHtml = `<span class="bg-indigo-50 dark:bg-indigo-900/30 px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 ml-2"><i class="far fa-calendar-alt mr-1"></i>${formattedDate}</span>`;
                    }
                    html += `
                        <div class="topic-item group p-4 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-100 dark:border-slate-700/50 transition-all">
                            <div class="flex items-start justify-between gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="font-bold text-sm text-slate-700 dark:text-slate-200 truncate" id="topic-name-${t.id}">
                                        ${t.topicName}
                                    </div>
                                    <div class="mt-1 flex items-center flex-wrap gap-1">
                                        <span onclick="copyId(event, ${t.id})" class="cursor-pointer hover:bg-slate-300 dark:hover:bg-slate-600 bg-slate-200 dark:bg-slate-700 px-2 py-0.5 rounded text-[10px] font-mono text-slate-600 dark:text-slate-300 transition-all group/copy" title="Copy ID">ID: ${t.id} <i class="far fa-copy ml-0.5 opacity-50 group-hover/copy:opacity-100"></i></span>
                                        ${dateHtml}
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-all shrink-0">
                                    <button onclick="editTopic(${t.id}, '${t.topicName.replace(/'/g, "\\'")}')" class="p-2 text-brand-500 hover:bg-brand-50 dark:hover:bg-brand-500/10 rounded-lg transition-all"><i class="fas fa-pen text-xs"></i></button>
                                    <button onclick="deleteTopic(${t.id})" class="p-2 text-rose-500 hover:bg-rose-50 dark:hover:bg-rose-500/10 rounded-lg transition-all"><i class="fas fa-trash-alt text-xs"></i></button>
                                </div>
                            </div>
                        </div>
                    `;
                });
                $('#topicList').html(html);
            });
        }

        function editTopic(id, currentName) {
            Swal.fire({
                title: 'Edit Topic',
                input: 'text',
                inputValue: currentName,
                showCancelButton: true,
                confirmButtonColor: '#f97316',
                confirmButtonText: 'Update'
            }).then((result) => {
                if (result.isConfirmed && result.value.trim() !== '') {
                    $.post('@Url.Action("UpdateTopic", "Admin")', { topicId: id, topicName: result.value.trim() }, function(res) {
                        if (res.success) {
                            loadTopics(currentCatId);
                            Swal.fire({ icon: 'success', title: 'Updated!', timer: 1000, showConfirmButton: false });
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        }

        // Modal Handlers
        function openTypeModal() {
            $('#itemType').val('type');
            $('#modalTitle').text('New Exam Variety');
            $('#modalIcon').attr('class', 'w-12 h-12 rounded-2xl bg-brand-50 flex items-center justify-center text-brand-600');
            $('#parentDisplay').hide();
            $('#academicModal').modal('show');
        }

        function openCatModal() {
            $('#itemType').val('category');
            $('#itemParentId').val(currentTypeId);
            $('#modalTitle').text('New Category');
            $('#modalIcon').attr('class', 'w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600');
            $('#parentNameText').text($('.type-item.active').data('name'));
            $('#parentDisplay').show();
            $('#academicModal').modal('show');
        }

        function openTopicModal() {
            $('#itemType').val('topic');
            $('#itemParentId').val(currentCatId);
            $('#modalTitle').text('New Lecture Topic');
            $('#modalIcon').attr('class', 'w-12 h-12 rounded-2xl bg-orange-50 flex items-center justify-center text-orange-600');
            $('#parentNameText').text($('.cat-item.active').find('span').first().text());
            $('#parentDisplay').show();
            $('#academicModal').modal('show');
        }

        // Form Submit
        $('#academicForm').on('submit', function(e) {
            e.preventDefault();
            const type = $('#itemType').val();
            const name = $('#itemName').val();
            const parentId = $('#itemParentId').val();

            let url = '';
            let data = {};

            if (type === 'type') {
                url = '@Url.Action("createexamtype", "Admin")';
                data = { typename: name };
            } else if (type === 'category') {
                url = '@Url.Action("createcategory", "Admin")';
                data = { catname: name, examTypeId: parentId };
            } else {
                url = '@Url.Action("CreateTopic", "Admin")';
                data = { topicName: name, categoryId: parentId };
            }

            $.post(url, data, function(res) {
                if (res.success) {
                    $('#academicModal').modal('hide');
                    $('#itemName').val('');
                    if (type === 'type') location.reload();
                    else if (type === 'category') loadCategories(currentTypeId);
                    else loadTopics(currentCatId);
                    Swal.fire({ icon: 'success', title: 'Success', timer: 1000, showConfirmButton: false });
                } else {
                    Swal.fire('Error', res.message || 'Operation failed', 'error');
                }
            });
        });

        // Deletion
        function deleteType(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Deleting a variety might orphan its categories!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("deleteexamtype", "Admin")', { id: id }, function(res) {
                        if (res.success) location.reload();
                    });
                }
            });
        }

        function deleteCategory(id) {
            Swal.fire({
                title: 'Are you sure?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("deletecategory", "Admin")', { id: id }, function(res) {
                        if (res.success) loadCategories(currentTypeId);
                    });
                }
            });
        }

        function deleteTopic(id) {
            Swal.fire({
                title: 'Are you sure?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteTopic", "Admin")', { topicId: id }, function(res) {
                        if (res.success) loadTopics(currentCatId);
                    });
                }
            });
        }

        function copyId(event, id) {
            if (event) event.stopPropagation();
            navigator.clipboard.writeText(id).then(() => {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'ID copied: ' + id,
                    showConfirmButton: false,
                    timer: 1500,
                    customClass: {
                        popup: 'colored-toast'
                    }
                });
            }).catch(err => {
                console.error('Failed to copy ID: ', err);
            });
        }
    </script>
}
