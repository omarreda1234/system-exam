@model IEnumerable<Exam.DTOs.StudentExamReviewRowDto>

@{
    var questions = (Model ?? Enumerable.Empty<Exam.DTOs.StudentExamReviewRowDto>())
        .GroupBy(r => new { r.QuestionId, r.QuestionText, r.Points, r.QuestionType, r.Difficulty })
        .OrderBy(g => g.Key.QuestionId)
        .ToList();
}

@if (!questions.Any())
{
    <div class="rounded-lg border border-sky-200 bg-sky-50 px-4 py-3 text-sky-900">No answers found for this student.</div>
}
else
{
    foreach (var q in questions)
    {
        <div class="mb-4 bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
            <div class="border-b border-slate-200 bg-slate-50 px-5 py-4">
                <div class="flex items-start justify-between gap-3">
                    <div class="flex-1">
                        <div class="font-semibold text-slate-900 mb-2">@q.Key.QuestionText</div>
                        <div class="flex items-center gap-2">
                             <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-[10px] font-bold text-blue-700 ring-1 ring-inset ring-blue-700/10 uppercase tracking-wider">
                                @q.Key.QuestionType
                            </span>
                            @{
                                var badgeClass = q.Key.Difficulty == 3 ? "bg-rose-50 text-rose-600 border-rose-200" :
                                                 q.Key.Difficulty == 2 ? "bg-amber-50 text-amber-600 border-amber-200" :
                                                                        "bg-emerald-50 text-emerald-600 border-emerald-200";
                                var diffText = q.Key.Difficulty == 3 ? "HARD" :
                                               q.Key.Difficulty == 2 ? "MID" : "EASY";
                            }
                            <span class="px-2 py-1 text-[10px] font-black uppercase tracking-wider border rounded-md @badgeClass">@diffText</span>
                        </div>
                    </div>
                    <div class="text-sm font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded-lg self-center">@q.Key.Points PTS</div>
                </div>
            </div>
            <div class="p-5">
                <div class="space-y-2">
                    @foreach (var c in q.OrderBy(x => x.ChoiceId))
                    {
                        var isStudent = c.IsStudentSelection;
                        var isCorrect = c.IsRightAnswer;
                        var rowClass = isStudent
                            ? (isCorrect ? "border-emerald-200 bg-emerald-50" : "border-rose-200 bg-rose-50")
                            : (isCorrect ? "border-emerald-200 bg-emerald-50" : "border-slate-200 bg-white");
                        var textClass = isStudent ? (isCorrect ? "text-emerald-900" : "text-rose-900") : (isCorrect ? "text-emerald-900" : "text-slate-800");

                        <div class="@rowClass flex items-center justify-between gap-3 rounded-lg border px-4 py-3">
                            <div class="text-sm font-medium @textClass">
                                @if (isStudent)
                                {
                                    <span class="mr-2 inline-flex items-center rounded-full @(isCorrect ? "bg-emerald-600" : "bg-rose-600") px-2 py-0.5 text-[10px] font-black text-white uppercase tracking-tighter">(Selected)</span>
                                }
                                @c.ChoiceText
                            </div>
                            <div class="text-[10px] font-black uppercase tracking-widest">
                                @if (isCorrect)
                                {
                                    <span class="text-emerald-600">Correct</span>
                                }
                                else if (isStudent && !isCorrect)
                                {
                                    <span class="text-rose-600">Wrong Choice</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

