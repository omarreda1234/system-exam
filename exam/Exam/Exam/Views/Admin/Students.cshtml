@model IEnumerable<Exam.DTOs.ExamResultRowDto>
@{
    ViewData["Title"] = "Global Analytics Matrix";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var exams = ViewBag.Exams as IEnumerable<Exam.DTOs.ExamDropdownDto> ?? Enumerable.Empty<Exam.DTOs.ExamDropdownDto>();
    var selectedExamId = ViewBag.SelectedExamId as int? ?? 0;
}

<!-- Filters Area -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-8 shadow-sm">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Analytical Filter</h2>
            <div class="flex items-center gap-3">
                <p class="text-xl font-bold">Cross-Module Performance</p>
                @{
                    var template = Model?.FirstOrDefault()?.CertificateTemplatePath;
                    if(!string.IsNullOrEmpty(template)) {
                        <span id="templateBadge" class="bg-indigo-100 text-indigo-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-indigo-200">
                             Custom Template Active
                        </span>
                    } else {
                        <span id="templateBadge" class="hidden bg-indigo-100 text-indigo-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-indigo-200">
                             Custom Template Active
                        </span>
                    }
                }
            </div>
        </div>
        
        <div class="flex flex-wrap items-center gap-4">
            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Selected Module</label>
                <select id="examFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-5 py-3 text-sm font-bold focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 outline-none transition-all min-w-[280px]">
                    @foreach (var e in exams) {
                        <option value="@e.Id" selected="@(e.Id == selectedExamId ? "selected" : null)">@e.Title.ToUpper() @(!string.IsNullOrEmpty(e.WaveName) ? $"- {e.WaveName.ToUpper()}" : "")</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Filter by Wave</label>
                <select id="waveFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-bold min-w-[150px]">
                    <option value="">ALL WAVES</option>
                    @{
                        var waves = Model?.Select(x => x.WaveName).Distinct().Where(x => !string.IsNullOrEmpty(x)).ToList();
                        if (waves != null) { foreach(var w in waves) { <option value="@w">@w.ToUpper()</option> } }
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Filter by Branch</label>
                <select id="branchFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm font-bold min-w-[150px]">
                    <option value="">ALL BRANCHES</option>
                    @{
                        var branches = Model?.Select(x => x.BranchName).Distinct().Where(x => !string.IsNullOrEmpty(x)).ToList();
                        if (branches != null) { foreach(var b in branches) { <option value="@b">@b.ToUpper()</option> } }
                    }
                </select>
            </div>

            <div class="flex items-center gap-2 mt-auto">
                <button onclick="document.getElementById('certUpload').click()" class="bg-indigo-50 text-indigo-600 hover:bg-indigo-100 px-5 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center gap-2">
                    <i class="fas fa-upload"></i> New Template
                </button>
                <input type="file" id="certUpload" hidden onchange="uploadTemplate(@selectedExamId, this)" accept="image/*" />
                
                <button id="btnSendSelectedCerts" onclick="sendSelectedCerts(@selectedExamId)" class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all shadow-lg flex items-center gap-2">
                    <i class="fas fa-certificate"></i> Send Selected Certs
                </button>
                
                <button onclick="reassignSelected(@selectedExamId)" class="bg-amber-500 hover:bg-amber-600 text-white px-6 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all shadow-lg flex items-center gap-2">
                    <i class="fas fa-redo"></i> Reassign Failed Nodes
                </button>

                <button onclick="sendFailEmails(@selectedExamId)" class="bg-rose-600 hover:bg-rose-700 text-white px-6 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all shadow-lg flex items-center gap-2">
                    <i class="fas fa-envelope"></i> Send Fail Notifications
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Table Area -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="datatable saas-table">
            <thead>
                <tr>
                    <th class="w-10 px-4">
                        <input type="checkbox" id="selectAll" class="rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
                    </th>
                    <th>Personnel Node</th>
                    <th class="hidden sm:table-cell">Email Address</th>
                    <th class="hidden lg:table-cell">Wave</th>
                    <th class="hidden md:table-cell">Branch</th>
                    <th>Status</th>
                    <th>Score</th>
                    <th class="hidden sm:table-cell">Pass</th>
                    <th class="hidden xl:table-cell">Certificate Code</th>
                    <th class="text-right px-8">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null) {
                    foreach (var s in Model) {
                        var statusClass = s.Status.StartsWith("Completed") ? "bg-emerald-500" : (s.Status == "InProgress" ? "bg-blue-500" : "bg-slate-400");
                        <tr class="student-row" data-wave="@s.WaveName" data-branch="@s.BranchName">
                             <td class="px-4 text-center">
                                 @if(s.Status.StartsWith("Completed") || s.Status.StartsWith("Fail_")) {
                                     <input type="checkbox" class="student-checkbox rounded border-slate-300 text-brand-600 focus:ring-brand-500" value="@s.Id" data-passed="@(s.IsPassed?.ToString().ToLower() ?? "null")" />
                                 } else {
                                     <input type="checkbox" disabled class="opacity-20 pointer-events-none" />
                                 }
                             </td>
                            <td>
                                <div class="flex items-center gap-3 px-4 py-3">
                                    <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 font-bold uppercase transition-transform hover:scale-105">@s.StudentName.Substring(0,1)</div>
                                    <div class="flex flex-col">
                                        <div class="flex items-center gap-2">
                                            <span class="font-bold text-slate-900 dark:text-white leading-tight">@s.StudentName</span>
                                            @if(s.AttemptNumber > 0) {
                                                <span class="bg-amber-100 text-amber-700 text-[8px] font-black px-1.5 py-0.5 rounded uppercase tracking-tighter">Attempt @s.AttemptNumber</span>
                                            }
                                        </div>
                                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">@s.ExamType.ToUpper()</span>
                                    </div>
                                </div>
                            </td>
                            <td class="hidden sm:table-cell"><span class="text-xs font-medium text-slate-500">@s.StudentEmail</span></td>
                            <td class="hidden lg:table-cell"><span class="text-[10px] font-black text-slate-400 uppercase">@(string.IsNullOrEmpty(s.WaveName) ? "Global" : s.WaveName)</span></td>
                            <td class="hidden md:table-cell"><span class="text-[10px] font-black text-slate-400 uppercase">@(string.IsNullOrEmpty(s.BranchName) ? "Global" : s.BranchName)</span></td>
                            <td>
                                <div class="flex items-center gap-1.5 px-3 py-1 rounded-full @(statusClass.Replace("bg-", "bg-opacity-10 text-")) w-fit">
                                    <div class="w-1.5 h-1.5 @statusClass rounded-full"></div>
                                    <span class="text-[10px] font-black uppercase tracking-widest">@s.Status.ToUpper()</span>
                                </div>
                            </td>
                            <td class="font-mono font-bold">
                                <div class="flex flex-col">
                                    <span class="text-brand-600 dark:text-brand-400 text-sm">@s.FinalScore.ToString("0") / @s.TotalScoreAvailable.ToString("0") <span class="text-[10px]">PTS</span></span>
                                    <span class="text-[9px] text-slate-400 uppercase tracking-widest">@s.Score.ToString("0.0")% Achievement</span>
                                </div>
                            </td>
                            <td class="hidden sm:table-cell">
                                @if (s.Status.StartsWith("Completed")) {
                                    <div class="flex flex-col gap-1">
                                        @if (s.IsPassed == true) {
                                            <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-emerald-50 text-emerald-600">PASSED</span>
                                        } else if (s.IsPassed == false) {
                                            <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-rose-50 text-rose-600">FAILED</span>
                                            @if (s.EmailSent) {
                                                <span class="text-[8px] font-bold text-slate-400 uppercase text-center"><i class="fas fa-check"></i> Mail Sent</span>
                                            }
                                        } else {
                                            <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-blue-50 text-blue-600">UNGRADED</span>
                                        }
                                    </div>
                                } else {
                                    <span class="text-slate-300">--</span>
                                }
                            </td>
                            <td class="hidden xl:table-cell">
                                 @if(s.Status.StartsWith("Completed") && s.IsPassed == true && !string.IsNullOrEmpty(s.CertificateCode)) {
                                     <div class="flex flex-col">
                                         <span class="text-[9px] font-mono text-slate-400">@s.CertificateCode</span>
                                         <span class="text-[8px] font-black text-emerald-600 uppercase tracking-widest">Issued</span>
                                     </div>
                                 } else if(s.Status.StartsWith("Completed") && s.IsPassed == true) {
                                     <span class="text-[9px] font-black text-rose-400 uppercase tracking-widest">Pending Generation</span>
                                 } else if(s.Status.StartsWith("Completed") && s.IsPassed == null) {
                                     <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Not Applicable</span>
                                 } else {
                                     <span class="text-slate-200">--</span>
                                 }
                             </td>
                            <td class="text-right px-8">
                                <div class="flex items-center justify-end gap-2">
                                    @if(s.IsPassed == true) {
                                        <button class="p-2.5 text-brand-600 bg-brand-50 hover:bg-brand-100 rounded-xl transition-all" onclick="sendSelectedCerts(@selectedExamId, ['@s.Id'])" title="Send Certificate">
                                            <i class="fas fa-certificate"></i>
                                        </button>
                                    }
                                    <button class="p-2.5 text-slate-400 hover:text-blue-600 bg-slate-50 rounded-xl transition-all view-review" data-student-id="@s.Id">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>



@section Scripts {
    <script>
        $(function () {
            $('#examFilter').change(function () { 
                let newUrl = '@Url.Action("Students", "Admin")' + '?examId=' + $(this).val(); 
                if (window.location.search.includes('iframe=true')) newUrl += '&iframe=true';
                window.location = newUrl;
            });
            $('#btnExport').on('click', function () { window.location = '@Url.Action("ExportStudentsToExcel", "Admin")' + '?examId=' + $('#examFilter').val(); });

            $('.send-message').on('click', function () {
                var email = $(this).data('student-email');
                Swal.fire({
                    title: 'Relay Transmission',
                    input: 'textarea',
                    inputPlaceholder: 'Inscribe neural message...',
                    background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                    color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                    confirmButtonText: 'Execute',
                    customClass: { confirmButton: 'bg-brand-600 text-white px-8 py-3 rounded-xl' }
                }).then(r => { if(r.isConfirmed) Swal.fire('Success', 'Message embedded in node.', 'success'); });
            });

            // Toggle checkbox on row click
            $(document).on('click', '.student-row', function(e) {
                if ($(e.target).is('input[type="checkbox"]') || $(e.target).closest('button').length) return;
                const cb = $(this).find('.student-checkbox');
                if (cb.length && !cb.is(':disabled')) {
                    cb.prop('checked', !cb.prop('checked')).trigger('change');
                }
            });

            // Removed inefficient manual tbody replacement that broke DataTable functionality
        });

        function applyFilters() {
            const wave = $('#waveFilter').val();
            const branch = $('#branchFilter').val();
            const $table = $('.datatable');
            
            if ($.fn.DataTable.isDataTable($table[0])) {
                const dt = $table.DataTable();
                // Custom filtering logic for DataTables
                $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                    const row = settings.aoData[dataIndex].nTr;
                    const rowWave = $(row).data('wave');
                    const rowBranch = $(row).data('branch');
                    
                    if (wave && rowWave !== wave) return false;
                    if (branch && rowBranch !== branch) return false;
                    return true;
                });
                dt.draw();
                $.fn.dataTable.ext.search.pop(); // Clear for next use
            } else {
                // Fallback for non-datatable mode
                $('.student-row').each(function() {
                    const rowWave = $(this).data('wave');
                    const rowBranch = $(this).data('branch');
                    let show = true;
                    if(wave && rowWave !== wave) show = false;
                    if(branch && rowBranch !== branch) show = false;
                    $(this).toggle(show);
                });
            }
        }
        window.applyFilters = applyFilters;

        function sendSelectedCerts(examId, forceIds) {
            var ids = forceIds || [];
            if(!forceIds) {
                $('.student-checkbox:checked').each(function() { ids.push($(this).val()); });
            }

            if(ids.length === 0) {
                Swal.fire('Selection Required', 'Please select at least one passed student.', 'info');
                return;
            }

            Swal.fire({
                title: 'Issuing Certificates...',
                text: 'Preparing ' + ids.length + ' documents. Please wait.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            fetch('/Admin/SendCertificates?examId=' + examId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(ids)
            }).then(r => r.json()).then(res => {
                if(res.success) Swal.fire('Success', res.message, 'success').then(() => window.location.reload());
                else Swal.fire('Error', res.message, 'error');
            });
        }

        function reassignSelected(examId) {
            var ids = [];
            $('.student-checkbox:checked').each(function() { 
                const passedVal = $(this).attr('data-passed');
                if (passedVal === 'false' || passedVal === 'null' || !passedVal) {
                    ids.push($(this).val());
                }
            });

            if(ids.length === 0) {
                Swal.fire('Selection Required', 'Please select at least one FAILED student to reassign.', 'info');
                return;
            }

            Swal.fire({
                title: 'Professional Reassignment',
                html: `
                    <div class="text-left space-y-4 p-4">
                        <p class="text-xs text-slate-500 font-bold uppercase tracking-widest">Assigning ${ids.length} personnel for a second attempt.</p>
                        <div>
                            <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">New Start Time</label>
                            <input type="datetime-local" id="reStart" class="w-full bg-slate-50 p-3 rounded-xl border border-slate-200 outline-none focus:border-brand-500 font-bold">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">New End Time</label>
                            <input type="datetime-local" id="reEnd" class="w-full bg-slate-50 p-3 rounded-xl border border-slate-200 outline-none focus:border-brand-500 font-bold">
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Confirm Reassignment',
                cancelButtonText: 'Cancel',
                preConfirm: () => {
                    const start = document.getElementById('reStart').value;
                    const end = document.getElementById('reEnd').value;
                    if(!start || !end) return Swal.showValidationMessage('Selection of full date range is mandatory.');
                    return { startTime: start, endTime: end };
                },
                customClass: {
                    confirmButton: 'bg-brand-600 hover:bg-brand-700 text-white px-8 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
                    cancelButton: 'text-slate-500 font-bold uppercase text-xs tracking-widest px-8 py-3'
                },
                buttonsStyling: false
            }).then(r => {
                if(r.isConfirmed) {
                    Swal.fire({ title: 'Deploying Assignment...', didOpen: () => Swal.showLoading() });
                    fetch('/Admin/ReassignExamToStudents?examId=' + examId, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ StudentIds: ids, StartTime: r.value.startTime, EndTime: r.value.endTime })
                    }).then(res => res.json()).then(data => {
                        if(data.success) Swal.fire('Success', 'Personnel successfully reassigned for a second attempt.', 'success').then(() => location.reload());
                        else Swal.fire('Error', 'Deployment failed.', 'error');
                    });
                }
            });
        }

        function uploadTemplate(examId, input) {
            if(!input.files || !input.files[0]) return;
            var formData = new FormData();
            formData.append('examId', examId);
            formData.append('templateFile', input.files[0]);

            Swal.fire({ title: 'Uploading...', didOpen: () => Swal.showLoading() });

            fetch('/Admin/UploadCertificateTemplate', { method: 'POST', body: formData })
                .then(r => r.json())
                .then(res => {
                    if(res.success) {
                        Swal.fire('Success', 'Certificate template updated for this exam.', 'success');
                        $('#templateBadge').removeClass('hidden');
                    }
                    else Swal.fire('Error', 'Upload failed.', 'error');
                });
        }

        $(function() {
            $('#selectAll').on('change', function() {
                $('.student-checkbox:not(:disabled)').prop('checked', this.checked);
            });

            $('#waveFilter, #branchFilter').on('change', applyFilters);

            // Use event delegation for buttons that might be replaced by AJAX
            $(document).on('click', '.view-review', function() {
                var id = $(this).data('student-id');
                var examId = $('#examFilter').val();
                
                Swal.fire({
                    title: 'Exam Review Analysis',
                    width: '80%',
                    showConfirmButton: false,
                    showCloseButton: true,
                    background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                    color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                    html: '<div id="swalReviewContent" style="text-align:left; max-height: 70vh; overflow-y: auto;"><div class="py-10 text-center"><i class="fas fa-sync fa-spin text-3xl text-brand-500"></i></div></div>',
                    didOpen: () => {
                        $.get('@Url.Action("GetStudentExamReview", "Admin")', { examId: examId, studentId: id })
                         .done(h => $('#swalReviewContent').html(h));
                    }
                });
            });
        });

        function sendFailEmails(examId) {
            Swal.fire({
                title: 'Sending Emails...',
                text: 'Please wait while we notify failed students.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.post('@Url.Action("SendFailEmails", "Admin")', { examId: examId })
                .done(function (res) {
                    if(res.success) {
                        Swal.fire('Success', res.message, 'success');
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                })
                .fail(function() { Swal.fire('Error', 'Server error occurred.', 'error'); });
        }
    </script>
}