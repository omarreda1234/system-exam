@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Deactivated Users Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="min-h-screen pb-20">
    <!-- Main Premium Header -->
    <div class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 pt-24 pb-12">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-2xl font-black text-slate-900 dark:text-white uppercase tracking-tight flex items-center gap-3">
                        <i class="fas fa-user-slash text-rose-500"></i>
                        <span>Deactivated Users Registry</span>
                    </h1>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1">Manage departure tracks, resignations, and permanent data scrubbing</p>
                </div>
                <div class="flex items-center gap-3">
                    <span id="activeCount" class="bg-rose-50 text-rose-600 dark:bg-rose-950/30 dark:text-rose-400 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest border border-rose-100 dark:border-rose-900/30">
                        @Model.Count() Archived Accounts
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Controls Cards -->
    <div class="max-w-7xl mx-auto px-6 mt-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <!-- Batch Deactivation Card -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-xl bg-brand-50 dark:bg-brand-950/30 flex items-center justify-center text-brand-600 dark:text-brand-400">
                            <i class="fas fa-file-excel text-lg"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Batch Deactivation</h3>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Upload track/resignation Excel sheet</p>
                        </div>
                    </div>
                    <div class="bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-900/30 rounded-2xl p-4 flex gap-3 text-amber-800 dark:text-amber-300 mb-6">
                        <i class="fas fa-info-circle text-lg shrink-0 mt-0.5"></i>
                        <div class="text-xs space-y-1 text-left">
                            <p class="font-black uppercase tracking-wide">Excel Sheet Requirements / متطلبات شيت الإكسيل</p>
                            <p class="font-medium text-amber-700 dark:text-amber-400">
                                The Excel sheet should have the following columns (row 1 can be headers):
                            </p>
                            <ul class="list-disc pl-4 space-y-1 mt-1 font-bold">
                                <li>First Column / العمود الأول: <span class="text-slate-900 dark:text-white">User Code (كود المستخدم)</span></li>
                                <li>Second Column / العمود الثاني: <span class="text-slate-500 dark:text-slate-400">User Name (optional - الاسم اختياري)</span></li>
                            </ul>
                            <p class="text-[10px] text-amber-600 dark:text-amber-500 mt-2 font-medium italic">
                                * Note: The system deactivates users by matching the unique <b>User Code</b> in the first column of the sheet.
                            </p>
                        </div>
                    </div>
                </div>
                <form id="excelImportForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="flex flex-col sm:flex-row items-center gap-3">
                        <label class="flex-1 w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-dashed border-slate-300 dark:border-slate-700 hover:border-brand-500 dark:hover:border-brand-400 cursor-pointer transition-colors bg-slate-50 dark:bg-slate-800/50">
                            <i class="fas fa-cloud-upload-alt text-slate-400"></i>
                            <span class="text-xs font-bold text-slate-600 dark:text-slate-400 uppercase tracking-wider" id="excelFileName">Select Excel File</span>
                            <input type="file" name="excelFile" id="excelFile" class="hidden" accept=".xlsx" onchange="updateFileName(this)" required />
                        </label>
                        <button type="submit" class="w-full sm:w-auto bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-lg shadow-brand-600/20 whitespace-nowrap">
                            <i class="fas fa-play mr-1.5"></i> Run Batch
                        </button>
                    </div>
                </form>
            </div>

            <!-- Single User Deactivation Card -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 shadow-sm flex flex-col justify-between">
                <div>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-xl bg-rose-50 dark:bg-rose-950/30 flex items-center justify-center text-rose-600 dark:text-rose-400">
                            <i class="fas fa-user-minus text-lg"></i>
                        </div>
                        <div>
                            <h3 class="text-sm font-black text-slate-900 dark:text-white uppercase tracking-wider">Manual Deactivation</h3>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Deactivate individual user by code</p>
                        </div>
                    </div>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-6 leading-relaxed">
                        To archive a single trainee or employee, search directly for their unique user code. If found, their state will be toggled to inactive immediately.
                    </p>
                </div>
                <form id="manualDeactivateForm">
                    @Html.AntiForgeryToken()
                    <div class="flex flex-col sm:flex-row gap-3">
                        <input type="text" name="userCode" id="userCodeInput" placeholder="ENTER USER CODE (e.g. 1005)..." class="flex-1 px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50 text-xs font-bold uppercase tracking-wider focus:outline-none focus:ring-2 focus:ring-rose-500/20 text-slate-900 dark:text-white placeholder:text-slate-400" required />
                        <button type="submit" class="w-full sm:w-auto bg-rose-500 hover:bg-rose-600 text-white px-6 py-3 rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-lg shadow-rose-500/20 whitespace-nowrap">
                            <i class="fas fa-user-slash mr-1.5"></i> Deactivate
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Inactive Registry Table -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
                <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Archived Staff List</span>
            </div>
            <table class="saas-table datatable">
                <thead>
                    <tr>
                        <th>Trainee Details</th>
                        <th>Credentials</th>
                        <th>Branch</th>
                        <th>Shift</th>
                        <th>Account Status</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr id="row-@user.Id">
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center font-black text-slate-400 text-xs uppercase">
                                        @(user.UserName?[0].ToString() ?? "?")
                                    </div>
                                    <div>
                                        <p class="font-black text-slate-900 dark:text-white uppercase text-xs">@user.UserName</p>
                                        <p class="text-[10px] text-slate-400 font-bold">@user.Phone</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <p class="text-xs font-bold text-slate-700 dark:text-slate-300">@user.Email</p>
                                <p class="text-[10px] font-mono text-brand-600">Code: @user.Code</p>
                            </td>
                            <td>
                                <span class="text-xs font-black text-slate-600 dark:text-slate-400 uppercase">@user.BranchName</span>
                            </td>
                            <td>
                                <span class="bg-slate-50 dark:bg-slate-800 px-2 py-0.5 rounded text-[9px] font-bold">
                                    @user.ShiftName
                                </span>
                            </td>
                            <td>
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[9px] font-black uppercase tracking-wider bg-rose-50 text-rose-600 dark:bg-rose-950/30 dark:text-rose-400 border border-rose-100 dark:border-rose-900/30">
                                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse"></span>
                                    Deactivated
                                </span>
                            </td>
                            <td class="text-right">
                                <div class="flex justify-end gap-2">
                                    <!-- Reactivate Option -->
                                    <button onclick="reactivateUser('@user.Id', '@user.UserName')" class="bg-emerald-50 text-emerald-600 hover:bg-emerald-600 hover:text-white px-3 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all">
                                        <i class="fas fa-user-check mr-1"></i> Reactivate
                                    </button>
                                    <!-- Permanent Cascade Delete -->
                                    <button onclick="deleteUserPermanently('@user.Id', '@user.UserName')" class="bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white px-3 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all">
                                        <i class="fas fa-trash-alt mr-1"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            @if (!Model.Any())
            {
                <div id="noDataPlaceholder" class="p-20 text-center">
                    <div class="w-20 h-20 bg-slate-50 dark:bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-300">
                        <i class="fas fa-user-slash text-3xl"></i>
                    </div>
                    <p class="text-slate-400 font-bold uppercase text-[10px] tracking-widest">No deactivated users in the archive currently.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateFileName(input) {
            const fileName = input.files[0] ? input.files[0].name : "Select Excel File";
            document.getElementById('excelFileName').textContent = fileName;
        }

        // Manual Deactivation Form Submit
        $('#manualDeactivateForm').on('submit', function(e) {
            e.preventDefault();
            const userCode = $('#userCodeInput').val();

            Swal.fire({
                title: 'Deactivate Trainee?',
                text: `Are you sure you want to deactivate trainee with code: ${userCode}?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Deactivate!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeactivateUserByCode", "Admin")',
                        type: 'POST',
                        data: {
                            userCode: userCode,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Archived',
                                    text: response.message
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Not Found',
                                    text: response.message
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Protocol Alert',
                                text: 'Failed to communicate with authorization server.'
                            });
                        }
                    });
                }
            });
        });

        // Excel Import Form Submit
        $('#excelImportForm').on('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);

            Swal.fire({
                title: 'Process Batch?',
                text: 'Are you sure you want to run this deactivation Excel sheet? All matched user codes will be immediately deactivated.',
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#4f46e5',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Execute!'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.showLoading();
                    $.ajax({
                        url: '@Url.Action("ImportDeactivationsFromExcel", "Admin")',
                        type: 'POST',
                        data: formData,
                        processData: false,
                        contentType: false,
                        success: function(response) {
                            Swal.close();
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Batch Sync Complete',
                                    text: response.message
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Batch Error',
                                    text: response.message
                                });
                            }
                        },
                        error: function() {
                            Swal.close();
                            Swal.fire({
                                icon: 'error',
                                title: 'Protocol Alert',
                                text: 'Failed to process Excel batch deactivation.'
                            });
                        }
                    });
                }
            });
        });

        // Reactivate User action
        function reactivateUser(userId, userName) {
            Swal.fire({
                title: 'Reactivate Account?',
                text: `Restore active login state and system privileges for ${userName}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#059669',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Restore!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("ActivateUser", "Admin")',
                        type: 'POST',
                        data: {
                            userId: userId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Reactivated',
                                    text: 'Trainee profile is now active on the system.'
                                }).then(() => {
                                    $(`#row-${userId}`).fadeOut(300, function() {
                                        $(this).remove();
                                        // Update count
                                        const curCount = parseInt($('#activeCount').text()) - 1;
                                        $('#activeCount').text(`${curCount} Archived Accounts`);
                                        if (curCount <= 0) {
                                            location.reload();
                                        }
                                    });
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Action Denied',
                                    text: response.message
                                });
                            }
                        }
                    });
                }
            });
        }

        // Permanent Cascade Deletion
        function deleteUserPermanently(userId, userName) {
            Swal.fire({
                title: '<span style="color:#ef4444">PERMANENT DELETION</span>',
                html: `Are you absolute certain you want to <strong>WIPE</strong> trainee <strong>${userName}</strong>?<br/><br/><span style="color:#f59e0b;font-size:11px;font-weight:bold;"><i class="fas fa-exclamation-triangle"></i> WARNING: This will permanently delete the trainee, their exam assignments, historical wave links, and all attendance logs! This cannot be undone!</span>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Wipe All Data!'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Final Security Check',
                        text: `Type "DELETE" to confirm the purging of ${userName}:`,
                        input: 'text',
                        inputPlaceholder: 'DELETE',
                        showCancelButton: true,
                        confirmButtonColor: '#d97706',
                        cancelButtonColor: '#64748b',
                        confirmButtonText: 'Purge Database Record',
                        preConfirm: (value) => {
                            if (value !== 'DELETE') {
                                Swal.showValidationMessage('You must type DELETE exactly.');
                            }
                        }
                    }).then((finalResult) => {
                        if (finalResult.isConfirmed) {
                            Swal.showLoading();
                            $.ajax({
                                url: '@Url.Action("DeleteUserPermanently", "Admin")',
                                type: 'POST',
                                data: {
                                    userId: userId,
                                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                                },
                                success: function(response) {
                                    Swal.close();
                                    if (response.success) {
                                        Swal.fire({
                                            icon: 'success',
                                            title: 'Wiped',
                                            text: response.message
                                        }).then(() => {
                                            $(`#row-${userId}`).fadeOut(300, function() {
                                                $(this).remove();
                                                // Update count
                                                const curCount = parseInt($('#activeCount').text()) - 1;
                                                $('#activeCount').text(`${curCount} Archived Accounts`);
                                                if (curCount <= 0) {
                                                    location.reload();
                                                }
                                            });
                                        });
                                    } else {
                                        Swal.fire({
                                            icon: 'error',
                                            title: 'Purge Failed',
                                            text: response.message
                                        });
                                    }
                                },
                                error: function() {
                                    Swal.close();
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Protocol Alert',
                                        text: 'Failed to perform remote cascade deletion.'
                                    });
                                }
                            });
                        }
                    });
                }
            });
        }
    </script>
}
