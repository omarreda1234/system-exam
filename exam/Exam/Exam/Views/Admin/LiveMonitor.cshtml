@model IEnumerable<Exam.DTOs.LiveMonitorRowDto>
@{
    ViewData["Title"] = "Live Monitor";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var branches  = ViewBag.Branches  as IEnumerable<Exam.DTOs.BranchDto>    ?? Enumerable.Empty<Exam.DTOs.BranchDto>();
    var shifts    = ViewBag.Shifts    as IEnumerable<Exam.DTOs.ShiftDto>      ?? Enumerable.Empty<Exam.DTOs.ShiftDto>();
    var waves     = ViewBag.Waves     as IEnumerable<Exam.DTOs.WaveDto>       ?? Enumerable.Empty<Exam.DTOs.WaveDto>();
    var weeklyExams = ViewBag.WeeklyExams as IEnumerable<Exam.DTOs.adminExamDto> ?? Enumerable.Empty<Exam.DTOs.adminExamDto>();
    var roles     = ViewBag.Roles     as IEnumerable<string>                  ?? Enumerable.Empty<string>();
    string selBranch = ViewBag.SelectedBranchId?.ToString() ?? "";
    string selShift  = ViewBag.SelectedShiftId?.ToString()  ?? "";
    string selRole   = ViewBag.SelectedRoleName ?? "";
    string selStatus = ViewBag.SelectedStatus   ?? "";
    string selWave   = ViewBag.SelectedWaveId?.ToString()   ?? "";
    string selDate   = ViewBag.SelectedDate     ?? "";
    string selExam   = ViewBag.SelectedExamId?.ToString()   ?? "";
    string selCategory = "";
    if (!string.IsNullOrEmpty(selExam))
    {
        if (weeklyExams.Any(e => e.Id.ToString() == selExam))
        {
            selCategory = "weekly";
        }
        else
        {
            selCategory = "wave";
        }
    }
    else if (!string.IsNullOrEmpty(selWave))
    {
        selCategory = "wave";
    }
}

<!-- Header -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-6 shadow-sm">
    <div class="flex flex-col gap-6">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Reports & Monitoring</h2>
                <div class="flex items-center gap-3">
                    <p class="text-xl font-bold">Live Monitor</p>
                    <span class="relative flex h-2.5 w-2.5">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                    </span>
                    <span class="bg-emerald-100 text-emerald-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-emerald-200">
                        Real-Time Data
                    </span>
                </div>
            </div>
            <div class="flex gap-2">
                <button id="btnExport" class="bg-indigo-50 text-indigo-600 hover:bg-indigo-100 px-5 py-2.5 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center gap-2">
                    <i class="fas fa-file-excel"></i> Export Excel
                </button>
                <button id="btnRefresh" class="bg-slate-50 text-slate-600 hover:bg-slate-100 px-5 py-2.5 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center gap-2">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Filter Bar -->
        <form method="get" action="/Admin/LiveMonitor" id="filterForm" class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Branch</label>
                <select name="branchId" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Branches</option>
                    @foreach (var b in branches)
                    {
                        <option value="@b.Id" selected="@(selBranch == b.Id.ToString() ? "selected" : null)">@b.BranchName</option>
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Shift</label>
                <select name="shiftId" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Shifts</option>
                    @foreach (var s in shifts)
                    {
                        <option value="@s.Id" selected="@(selShift == s.Id.ToString() ? "selected" : null)">@s.ShiftName</option>
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Role</label>
                <select name="roleName" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Roles</option>
                    @foreach (var r in roles)
                    {
                        <option value="@r" selected="@(selRole == r ? "selected" : null)">@r</option>
                    }
                </select>
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Status</label>
                <select name="status" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Statuses</option>
                    <option value="InProgress"  selected="@(selStatus == "InProgress"  ? "selected" : null)">🟡 In Progress</option>
                    <option value="Completed"   selected="@(selStatus == "Completed"   ? "selected" : null)">🟢 Completed</option>
                    <option value="Not Started" selected="@(selStatus == "Not Started" ? "selected" : null)">⚪ Not Started</option>
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Exam Category</label>
                <select id="examCategory" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="" selected="@(selCategory == "" ? "selected" : null)">All Exams</option>
                    <option value="weekly" selected="@(selCategory == "weekly" ? "selected" : null)">Weekly Exams</option>
                    <option value="wave" selected="@(selCategory == "wave" ? "selected" : null)">Wave Exams</option>
                </select>
            </div>

            <!-- Weekly Exam -->
            <div class="flex flex-col gap-1 @(selCategory == "weekly" ? "" : "hidden")" id="weeklyExamWrapper">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Weekly Exam</label>
                <select id="weeklyExamFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Weekly Exams</option>
                    @foreach (var e in weeklyExams)
                    {
                        <option value="@e.Id" selected="@(selCategory == "weekly" && selExam == e.Id.ToString() ? "selected" : null)">@e.Title</option>
                    }
                </select>
            </div>

            <!-- Wave Select -->
            <div class="flex flex-col gap-1 @(selCategory == "wave" ? "" : "hidden")" id="waveWrapper">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Wave</label>
                <select name="waveId" id="waveFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Waves</option>
                    @foreach (var w in waves)
                    {
                        <option value="@w.Id" selected="@(selWave == w.Id.ToString() ? "selected" : null)">@w.WaveName</option>
                    }
                </select>
            </div>

            <!-- Wave Exam Select -->
            <div class="flex flex-col gap-1 @(selCategory == "wave" ? "" : "hidden")" id="waveExamWrapper">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Wave Exam</label>
                <select id="waveExamFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold">
                    <option value="">All Wave Exams</option>
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest px-1">Date</label>
                <input type="date" name="date" value="@selDate"
                    class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3 py-2 text-xs font-bold" />
            </div>

            <input type="hidden" name="examId" id="hiddenExamId" value="@selExam" />

            <div class="flex flex-col gap-1 justify-end">
                <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-4 py-2 rounded-xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center justify-center gap-2 h-[38px]">
                    <i class="fas fa-search"></i> Apply
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[20px] p-5 shadow-sm">
        <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Records</div>
        <div class="text-3xl font-black text-slate-900 dark:text-white" id="cardTotalCount">@ViewBag.TotalCount</div>
    </div>
    <div class="bg-amber-50 dark:bg-amber-950 border border-amber-200 dark:border-amber-800 rounded-[20px] p-5 shadow-sm">
        <div class="text-[10px] font-black text-amber-600 uppercase tracking-widest mb-1 flex items-center gap-2">
            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span></span>
            In Progress Now
        </div>
        <div class="text-3xl font-black text-amber-700" id="cardInProgressCount">@ViewBag.InProgressCount</div>
    </div>
    <div class="bg-emerald-50 dark:bg-emerald-950 border border-emerald-200 dark:border-emerald-800 rounded-[20px] p-5 shadow-sm">
        <div class="text-[10px] font-black text-emerald-600 uppercase tracking-widest mb-1">Completed</div>
        <div class="text-3xl font-black text-emerald-700" id="cardCompletedCount">@ViewBag.CompletedCount</div>
    </div>
    <div class="bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-[20px] p-5 shadow-sm">
        <div class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Not Started</div>
        <div class="text-3xl font-black text-slate-600 dark:text-slate-300" id="cardNotStartedCount">@ViewBag.NotStartedCount</div>
    </div>
</div>

<!-- Results Table -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="datatable saas-table" id="liveMonitorTable">
            <thead>
                <tr>
                    <th class="min-w-[220px]">Personnel</th>
                    <th>Branch</th>
                    <th>Shift</th>
                    <th>Role</th>
                    <th>Exam</th>
                    <th>Wave</th>
                    <th>Status</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Time (M)</th>
                    <th>Score</th>
                    <th>Result</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <div class="flex items-center gap-3 flex-nowrap">
                                <div class="w-9 h-9 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 font-bold uppercase text-sm flex-shrink-0">
                                    @(r.StudentName?.Length > 0 ? r.StudentName.Substring(0,1) : "?")
                                </div>
                                <div class="flex flex-col min-w-0">
                                    <span class="font-bold text-slate-900 dark:text-white text-sm leading-tight truncate">@r.StudentName</span>
                                    <span class="text-[10px] text-slate-400 font-bold uppercase">@r.UserCode</span>
                                </div>
                            </div>
                        </td>
                        <td><span class="text-[11px] font-bold text-slate-500 uppercase">@(string.IsNullOrEmpty(r.BranchName) ? "--" : r.BranchName)</span></td>
                        <td><span class="text-[11px] font-bold text-slate-500">@(string.IsNullOrEmpty(r.ShiftName) ? "--" : r.ShiftName)</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(r.RoleName))
                            {
                                bool isPharm = r.RoleName.ToLower().Contains("pharmacist") || r.RoleName.Contains("صيدل");
                                <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase @(isPharm ? "bg-purple-50 text-purple-600 border border-purple-200" : "bg-sky-50 text-sky-600 border border-sky-200")">
                                    @(isPharm ? "Pharm." : "Asst.")
                                </span>
                            }
                            else { <span class="text-slate-300 text-xs">--</span> }
                        </td>
                        <td>
                            <div class="flex flex-col max-w-[180px]">
                                <span class="text-xs font-bold text-slate-700 dark:text-slate-300 truncate">@r.ExamTitle</span>
                                <span class="text-[9px] font-bold text-slate-400 uppercase">@r.ExamType</span>
                            </div>
                        </td>
                        <td><span class="text-[11px] font-bold text-slate-400 uppercase">@(string.IsNullOrEmpty(r.WaveName) ? "--" : r.WaveName)</span></td>
                        <td>
                            @switch (r.Status)
                            {
                                case "InProgress":
                                    <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase bg-amber-50 text-amber-600 border border-amber-200 flex items-center gap-1 w-fit">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse flex-shrink-0"></span> In Progress
                                    </span>
                                    break;
                                case "Completed":
                                    <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-200 w-fit">✓ Completed</span>
                                    break;
                                default:
                                    <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase bg-slate-100 text-slate-400 w-fit">Not Started</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div class="flex flex-col">
                                <span class="text-[10px] font-bold text-slate-500">@(r.StartTime?.ToString("dd/MM/yyyy") ?? "--")</span>
                                <span class="text-[9px] text-slate-400">@(r.StartTime?.ToString("hh:mm tt") ?? "")</span>
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col">
                                <span class="text-[10px] font-bold text-slate-500">@(r.EndTime?.ToString("dd/MM/yyyy") ?? "--")</span>
                                <span class="text-[9px] text-slate-400">@(r.EndTime?.ToString("hh:mm tt") ?? "")</span>
                            </div>
                        </td>
                        <td><span class="text-xs font-bold text-slate-500">@(r.DurationInMinutes > 0 ? $"{r.DurationInMinutes} min" : "--")</span></td>
                        <td>
                            <div class="flex flex-col">
                                <span class="text-sm font-bold font-mono text-brand-600">@r.FinalScore.ToString("0") / @r.TotalPoints.ToString("0")</span>
                                <span class="text-[9px] text-slate-400">@r.Percentage.ToString("0.0")%</span>
                            </div>
                        </td>
                        <td>
                            @if (r.Status == "Completed")
                            {
                                if (r.IsPassed == true)
                                {
                                    <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-200">PASS</span>
                                }
                                else
                                {
                                    <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase bg-rose-50 text-rose-600 border border-rose-200">FAILED</span>
                                }
                            }
                            else
                            {
                                <span class="text-slate-300 text-xs">--</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        let refreshTimer = null;

        function toggleCategoryWrappers() {
            const category = $('#examCategory').val();
            if (category === 'weekly') {
                $('#weeklyExamWrapper').removeClass('hidden');
                $('#waveWrapper').addClass('hidden');
                $('#waveExamWrapper').addClass('hidden');
            } else if (category === 'wave') {
                $('#weeklyExamWrapper').addClass('hidden');
                $('#waveWrapper').removeClass('hidden');
                $('#waveExamWrapper').removeClass('hidden');
            } else {
                $('#weeklyExamWrapper').addClass('hidden');
                $('#waveWrapper').addClass('hidden');
                $('#waveExamWrapper').addClass('hidden');
            }
        }

        $('#examCategory').on('change', function () {
            toggleCategoryWrappers();
            // Clear selections
            $('#weeklyExamFilter').val('');
            $('#waveFilter').val('').trigger('change');
        });

        $('#waveFilter').on('change', function () {
            const waveId = $(this).val();
            const examFilter = $('#waveExamFilter');
            examFilter.html('<option value="">All Wave Exams</option>');

            if (waveId) {
                $.getJSON('/Admin/GetExamsByWaveId', { waveId: waveId }, function (exams) {
                    exams.forEach(e => {
                        const isSelected = e.id.toString() === '@selExam';
                        examFilter.append(`<option value="${e.id}" ${isSelected ? 'selected' : ''}>${e.title}</option>`);
                    });
                });
            }
        });

        function loadData() {
            Swal.fire({
                title: 'Updating Live Monitor...',
                html: 'Fetching fresh records...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // Map the selected value to hidden examId
            let examId = null;
            const category = $('#examCategory').val();
            if (category === 'weekly') {
                examId = $('#weeklyExamFilter').val();
            } else if (category === 'wave') {
                examId = $('#waveExamFilter').val();
            }
            $('#hiddenExamId').val(examId || '');

            const formData = $('#filterForm').serialize();
            
            // Update URL in address bar so users can refresh/bookmark
            const params = new URLSearchParams(formData);
            window.history.pushState({}, '', window.location.pathname + '?' + params.toString());

            $.ajax({
                url: '/Admin/GetLiveMonitorData',
                type: 'GET',
                data: formData,
                success: function (data) {
                    let total = data.length;
                    let inProgress = 0;
                    let completed = 0;
                    let notStarted = 0;

                    const dt = $('#liveMonitorTable').DataTable();
                    dt.clear();

                    const newRows = [];

                    data.forEach(item => {
                        if (item.status === 'InProgress') inProgress++;
                        else if (item.status === 'Completed') completed++;
                        else notStarted++;

                        // Build Personnel HTML
                        let personnelHtml = `
                            <div class="flex items-center gap-3 flex-nowrap">
                                <div class="w-9 h-9 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 font-bold uppercase text-sm flex-shrink-0">
                                    ${item.studentName ? item.studentName.substring(0, 1) : '?'}
                                </div>
                                <div class="flex flex-col min-w-0">
                                    <span class="font-bold text-slate-900 dark:text-white text-sm leading-tight truncate">${item.studentName || ''}</span>
                                    <span class="text-[10px] text-slate-400 font-bold uppercase">${item.userCode || ''}</span>
                                </div>
                            </div>
                        `;

                        // Branch HTML
                        let branchHtml = `<span class="text-[11px] font-bold text-slate-500 uppercase">${item.branchName || '--'}</span>`;

                        // Shift HTML
                        let shiftHtml = `<span class="text-[11px] font-bold text-slate-500">${item.shiftName || '--'}</span>`;

                        // Role HTML
                        let roleHtml = '--';
                        if (item.roleName) {
                            let isPharm = item.roleName.toLowerCase().includes('pharmacist') || item.roleName.includes('صيدل');
                            roleHtml = `
                                <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase ${isPharm ? 'bg-purple-50 text-purple-600 border border-purple-200' : 'bg-sky-50 text-sky-600 border border-sky-200'}">
                                    ${isPharm ? 'Pharm.' : 'Asst.'}
                                </span>
                            `;
                        }

                        // Exam HTML
                        let examHtml = `
                            <div class="flex flex-col max-w-[180px]">
                                <span class="text-xs font-bold text-slate-700 dark:text-slate-300 truncate">${item.examTitle || ''}</span>
                                <span class="text-[9px] font-bold text-slate-400 uppercase">${item.examType || ''}</span>
                            </div>
                        `;

                        // Wave HTML
                        let waveHtml = `<span class="text-[11px] font-bold text-slate-400 uppercase">${item.waveName || '--'}</span>`;

                        // Status HTML
                        let statusHtml = '';
                        if (item.status === 'InProgress') {
                            statusHtml = `
                                <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase bg-amber-50 text-amber-600 border border-amber-200 flex items-center gap-1 w-fit">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse flex-shrink-0"></span> In Progress
                                </span>
                            `;
                        } else if (item.status === 'Completed') {
                            statusHtml = `
                                <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-200 w-fit">✓ Completed</span>
                            `;
                        } else {
                            statusHtml = `
                                <span class="px-2.5 py-1 rounded-full text-[9px] font-black uppercase bg-slate-100 text-slate-400 w-fit">Not Started</span>
                            `;
                        }

                        // Start/End Time HTML
                        let startHtml = '--';
                        if (item.startTime) {
                            let parts = item.startTime.split(' ');
                            startHtml = `
                                <div class="flex flex-col">
                                    <span class="text-[10px] font-bold text-slate-500">${parts[0]}</span>
                                    <span class="text-[9px] text-slate-400">${parts[1]} ${parts[2] || ''}</span>
                                </div>
                            `;
                        }

                        let endHtml = '--';
                        if (item.endTime) {
                            let parts = item.endTime.split(' ');
                            endHtml = `
                                <div class="flex flex-col">
                                    <span class="text-[10px] font-bold text-slate-500">${parts[0]}</span>
                                    <span class="text-[9px] text-slate-400">${parts[1]} ${parts[2] || ''}</span>
                                </div>
                            `;
                        }

                        // Duration HTML
                        let durationHtml = `<span class="text-xs font-bold text-slate-500">${item.durationInMinutes > 0 ? item.durationInMinutes + ' min' : '--'}</span>`;

                        // Score HTML
                        let scoreHtml = `
                            <div class="flex flex-col">
                                <span class="text-sm font-bold font-mono text-brand-600">${Math.round(item.finalScore)} / ${Math.round(item.totalPoints)}</span>
                                <span class="text-[9px] text-slate-400">${item.percentage.toFixed(1)}%</span>
                            </div>
                        `;

                        // Result HTML
                        let resultHtml = '<span class="text-slate-300 text-xs">--</span>';
                        if (item.status === 'Completed') {
                            if (item.isPassed) {
                                resultHtml = `<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-200">PASS</span>`;
                            } else {
                                resultHtml = `<span class="px-2 py-0.5 rounded text-[9px] font-black uppercase bg-rose-50 text-rose-600 border border-rose-200">FAILED</span>`;
                            }
                        }

                        // Push row
                        newRows.push([
                            personnelHtml,
                            branchHtml,
                            shiftHtml,
                            roleHtml,
                            examHtml,
                            waveHtml,
                            statusHtml,
                            startHtml,
                            endHtml,
                            durationHtml,
                            scoreHtml,
                            resultHtml
                        ]);
                    });

                    // Add and draw
                    dt.rows.add(newRows).draw();

                    // Update UI Counters
                    $('#cardTotalCount').text(total);
                    $('#cardInProgressCount').text(inProgress);
                    $('#cardCompletedCount').text(completed);
                    $('#cardNotStartedCount').text(notStarted);

                    // Re-schedule auto refresh if InProgress is selected
                    clearTimeout(refreshTimer);
                    const currentStatus = $('[name="status"]').val();
                    if (currentStatus === 'InProgress') {
                        refreshTimer = setTimeout(loadData, 60000);
                    }

                    Swal.close();
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to retrieve fresh monitor records.'
                    });
                }
            });
        }

        // Intercept form submit to load data via AJAX
        $('#filterForm').on('submit', function (e) {
            e.preventDefault();
            loadData();
        });

        // Auto-refresh timer for initial page load if needed
        const initialStatus = $('[name="status"]').val();
        if (initialStatus === 'InProgress') {
            refreshTimer = setTimeout(loadData, 60000);
        }

        $('#btnRefresh').on('click', function(e) {
            e.preventDefault();
            loadData();
        });

        $('#btnExport').on('click', function() {
            // Map the selected value to hidden examId before export
            let examId = null;
            const category = $('#examCategory').val();
            if (category === 'weekly') {
                examId = $('#weeklyExamFilter').val();
            } else if (category === 'wave') {
                examId = $('#waveExamFilter').val();
            }
            $('#hiddenExamId').val(examId || '');

            const params = new URLSearchParams($('#filterForm').serialize());
            window.location = '/Admin/ExportLiveMonitorToExcel?' + params.toString();
        });

        // Initial setup
        toggleCategoryWrappers();
        const initialWave = '@selWave';
        if (initialWave) {
            $('#waveFilter').val(initialWave).trigger('change');
        }

        // Today's shortcut
        document.addEventListener('keydown', e => {
            if (e.altKey && e.key === 't') {
                const today = new Date().toISOString().split('T')[0];
                document.querySelector('[name="date"]').value = today;
                loadData();
            }
        });
    </script>
}
