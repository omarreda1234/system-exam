@model IEnumerable<Exam.DTOs.BranchDto>
@using System.Web
@{
    ViewData["Title"] = "Branch Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@Html.AntiForgeryToken()

<div class="min-h-screen pb-20 bg-slate-50/50 dark:bg-slate-950/20">
    <!-- Main Premium Header -->
    <div class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 pt-24 pb-12">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-2xl font-black text-slate-900 dark:text-white uppercase tracking-tight flex items-center gap-3">
                        <i class="fas fa-code-branch text-brand-600"></i>
                        <span>Branch Management / إدارة الفروع</span>
                    </h1>
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mt-1">Manage system branches, codes, and associated resources</p>
                </div>
                @if (User.IsInRole("Admin"))
                {
                    <div class="flex items-center gap-3">
                        <button onclick="openBranchModal()" class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-xl text-xs font-black uppercase tracking-widest transition-all shadow-lg shadow-brand-600/20 flex items-center gap-2 group">
                            <i class="fas fa-plus text-xs group-hover:rotate-90 transition-transform"></i>
                            Add New Branch
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-6 mt-8">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
                <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Active Branches</span>
            </div>
            
            <div class="overflow-x-auto w-full">
                <table class="saas-table datatable">
                <thead>
                    <tr>
                        <th>Branch Name</th>
                        <th>Branch Code</th>
                        <th>Status</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var branch in Model)
                    {
                        <tr id="row-@branch.Id">
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-950/30 flex items-center justify-center font-black text-indigo-600 text-xs uppercase">
                                        @(branch.BranchName?[0].ToString() ?? "B")
                                    </div>
                                    <div>
                                        <p class="text-xs font-black text-slate-900 dark:text-white uppercase tracking-wide">@branch.BranchName</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded border border-slate-200 dark:border-slate-700 text-[10px] font-mono font-bold text-slate-500">
                                    @(string.IsNullOrEmpty(branch.BranchCode) ? "N/A" : branch.BranchCode)
                                </span>
                            </td>
                            <td>
                                @if (branch.IsActive ?? true)
                                {
                                    <span class="bg-emerald-50 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400 border border-emerald-200/50 dark:border-emerald-800/50 px-2.5 py-1 rounded-full text-[9px] font-black uppercase tracking-widest inline-flex items-center gap-1.5">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="bg-rose-50 text-rose-600 dark:bg-rose-900/30 dark:text-rose-400 border border-rose-200/50 dark:border-rose-800/50 px-2.5 py-1 rounded-full text-[9px] font-black uppercase tracking-widest inline-flex items-center gap-1.5">
                                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span> Inactive
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="flex items-center justify-end gap-2">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button onclick="openBranchModal('@branch.Id', '@Html.Raw(HttpUtility.JavaScriptStringEncode(branch.BranchName))', '@Html.Raw(HttpUtility.JavaScriptStringEncode(branch.BranchCode ?? ""))')" class="bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white px-3 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all shrink-0">
                                            <i class="fas fa-edit mr-1"></i> Edit
                                        </button>
                                        <button onclick="mergeBranch('@branch.Id', '@Html.Raw(HttpUtility.JavaScriptStringEncode(branch.BranchName))')" class="bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white px-3 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all shrink-0 border border-amber-100 dark:border-amber-900/30">
                                            <i class="fas fa-compress-arrows-alt mr-1"></i> Merge
                                        </button>
                                        <button onclick="deleteBranch('@branch.Id', '@Html.Raw(HttpUtility.JavaScriptStringEncode(branch.BranchName))')" class="bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white px-3 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all shrink-0 border border-rose-100 dark:border-rose-900/30">
                                            <i class="fas fa-trash-alt mr-1"></i> Delete
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openBranchModal(id = null, currentName = '', currentCode = '') {
            const isEdit = id != null;
            Swal.fire({
                title: isEdit ? 'Edit Branch / تعديل الفرع' : 'Add New Branch / إضافة فرع جديد',
                html: `
                    <div class="text-left space-y-4">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Branch Name <span class="text-rose-500">*</span></label>
                            <input type="text" id="branchName" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 dark:text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500" placeholder="e.g. Main Branch" value="${currentName}">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Branch Code (Optional)</label>
                            <input type="text" id="branchCode" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 dark:text-white focus:outline-none focus:border-brand-500 focus:ring-1 focus:ring-brand-500" placeholder="e.g. BR-01" value="${currentCode}">
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: isEdit ? 'Save Changes' : 'Create Branch',
                cancelButtonText: 'Cancel',
                customClass: {
                    confirmButton: 'bg-brand-600 hover:bg-brand-700 text-white px-8 py-3 rounded-xl font-bold uppercase text-xs tracking-widest',
                    cancelButton: 'text-slate-500 font-bold uppercase text-xs tracking-widest px-8 py-3'
                },
                buttonsStyling: false,
                preConfirm: () => {
                    const name = document.getElementById('branchName').value.trim();
                    const code = document.getElementById('branchCode').value.trim();
                    if (!name) {
                        Swal.showValidationMessage('Branch name is required');
                        return false;
                    }
                    return { id, name, code };
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const data = result.value;
                    const url = data.id ? '@Url.Action("EditBranch", "Admin")' : '@Url.Action("AddBranch", "Admin")';
                    
                    $.ajax({
                        url: url,
                        type: 'POST',
                        data: {
                            id: data.id,
                            name: data.name,
                            code: data.code,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(res) {
                            if (res.success) {
                                Swal.fire({ icon: 'success', title: 'Success', text: res.message }).then(() => location.reload());
                            } else {
                                Swal.fire({ icon: 'error', title: 'Failed', text: res.message });
                            }
                        },
                        error: function() {
                            Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong.' });
                        }
                    });
                }
            });
        }

        function deleteBranch(id, name) {
            Swal.fire({
                title: 'Delete Branch?',
                text: `Are you sure you want to delete ${name}? This action cannot be undone.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Delete!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteBranch", "Admin")',
                        type: 'POST',
                        data: { id: id },
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (res) {
                            if (res.success) {
                                const $tr = $('#row-' + id);
                                const $tbl = $tr.closest('table.datatable');
                                if ($tbl.length && $.fn.DataTable.isDataTable($tbl[0])) {
                                    $tbl.DataTable().row($tr).remove().draw(false);
                                } else {
                                    $tr.remove();
                                }
                                Swal.fire({ 
                                    icon: 'success', 
                                    title: 'Deleted Successfully', 
                                    toast: true, 
                                    position: 'top-end', 
                                    showConfirmButton: false, 
                                    timer: 3000,
                                    background: '#f8fafc'
                                });
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error!', 'An error occurred while deleting the branch.', 'error');
                        }
                    });
                }
            });
        }

        const branchesList = @Html.Raw(Json.Serialize(Model.Select(b => new { b.Id, b.BranchName })));

        function mergeBranch(sourceId, name) {
            let optionsHtml = '<option value="">-- Select Target Branch --</option>';
            branchesList.forEach(b => {
                if(b.id.toString() !== sourceId.toString()) {
                    optionsHtml += `<option value="${b.id}">${b.branchName.replace(/</g, "&lt;")}</option>`;
                }
            });

            Swal.fire({
                title: 'Merge Branch',
                html: `
                    <p class="text-xs text-slate-500 mb-4">You are about to merge <strong class="text-rose-500">${name}</strong> into another branch. This will move all users and delete the old branch.</p>
                    <div class="text-left">
                        <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Target Branch (Keep this one)</label>
                        <select id="mergeTargetId" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-sm outline-none focus:border-brand-500">
                            ${optionsHtml}
                        </select>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Confirm Merge',
                confirmButtonColor: '#f59e0b',
                preConfirm: () => {
                    const targetId = document.getElementById('mergeTargetId').value;
                    if (!targetId) {
                        Swal.showValidationMessage('Please select a target branch');
                        return false;
                    }
                    return targetId;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const targetId = result.value;
                    Swal.fire({ title: 'Merging...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                    $.ajax({
                        url: '@Url.Action("MergeBranch", "Admin")',
                        type: 'POST',
                        data: { sourceId: sourceId, targetId: targetId },
                        headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                        success: function (res) {
                            if (res.success) {
                                const $tr = $('#row-' + sourceId);
                                const $tbl = $tr.closest('table.datatable');
                                if ($tbl.length && $.fn.DataTable.isDataTable($tbl[0])) {
                                    $tbl.DataTable().row($tr).remove().draw(false);
                                } else {
                                    $tr.remove();
                                }
                                Swal.fire({ 
                                    icon: 'success', 
                                    title: 'Merged Successfully', 
                                    toast: true, 
                                    position: 'top-end', 
                                    showConfirmButton: false, 
                                    timer: 3000,
                                    background: '#f8fafc'
                                });
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        },
                        error: function () { Swal.fire('Error!', 'An error occurred during merge.', 'error'); }
                    });
                }
            });
        }
    </script>
}
