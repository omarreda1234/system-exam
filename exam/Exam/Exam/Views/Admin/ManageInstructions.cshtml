@model string
@{
    ViewData["Title"] = "Protocol Control";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="space-y-8">
    <!-- Header Area -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 shadow-sm">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Policy Management</h2>
            <p class="text-2xl font-bold bg-gradient-to-r from-slate-900 to-slate-600 dark:from-white dark:to-slate-400 bg-clip-text text-transparent">Examination Instructions Protocol</p>
        </div>
    </div>

    <!-- Management Form -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 shadow-sm">
        <form asp-action="UpdateInstructions" method="post" class="space-y-6">
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-3 px-1">Global Instruction Set (HTML Enabled)</label>
                <div class="relative group">
                    <textarea name="instructions" rows="15" 
                        class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 text-sm font-medium text-slate-700 dark:text-slate-300 focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 outline-none transition-all resize-none group-hover:border-slate-300 dark:group-hover:border-slate-700 font-mono">@Model</textarea>
                    
                    <div class="absolute bottom-4 right-4 flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/50 dark:bg-slate-900/50 backdrop-blur border border-slate-200 dark:border-slate-800 text-[10px] font-black uppercase text-slate-400">
                        <i class="fas fa-code"></i>
                        Live Buffer
                    </div>
                </div>
                <p class="text-[10px] font-bold text-slate-400 mt-3 px-1 italic">
                    <i class="fas fa-info-circle mr-1 text-brand-500"></i>
                    These instructions will be displayed as a mandatory read before any student initiates an exam attempt.
                </p>
            </div>

            <div class="flex items-center justify-end pt-4">
                <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-10 py-4 rounded-2xl font-black uppercase text-xs tracking-widest transition-all shadow-xl shadow-brand-500/20 flex items-center gap-3 hover:-translate-y-0.5 active:translate-y-0">
                    <i class="fas fa-cloud-upload-alt text-lg"></i>
                    Update Protocol Registry
                </button>
            </div>
        </form>
    </div>
</div>
