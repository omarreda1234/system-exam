@model IEnumerable<Exam.DTOs.ExamResultRowDto>
@{
    ViewData["Title"] = "Certificates Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var waves = ViewBag.Waves as IEnumerable<Exam.DTOs.WaveDto> ?? Enumerable.Empty<Exam.DTOs.WaveDto>();
    var selectedWaveId = ViewBag.SelectedWaveId as int? ?? 0;
    var selectedExamId = ViewBag.SelectedExamId as int? ?? 0;
}

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-8 shadow-sm space-y-6">
    <!-- Header Row -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-100 dark:border-slate-800 pb-5">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Analytical Filter</h2>
            <div class="flex items-center gap-3">
                <p class="text-xl font-bold">Certificates Management</p>
                <span class="bg-emerald-100 text-emerald-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-emerald-200">
                     Advanced Mode Active
                 </span>
            </div>
        </div>
        
        <div>
            <button onclick="triggerExcelUpload()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3.5 rounded-2xl text-[10px] font-black tracking-widest uppercase shadow-md shadow-emerald-600/10 flex items-center gap-2.5 transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-emerald-600/20 active:translate-y-0 border border-transparent">
                <i class="fas fa-file-excel text-emerald-100"></i> Import Certificates Excel
            </button>
            <input type="file" id="certExcelInput" class="hidden" accept=".xlsx, .xls" onchange="uploadCertExcel(event)" />
        </div>
    </div>

    <!-- Filter Bar Row -->
    <div class="flex flex-wrap items-center gap-4">
        <div class="space-y-2">
            <label class="block text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-1">Year</label>
            <select id="yearFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-3.5 text-xs font-bold w-[110px] transition-colors focus:border-brand-500 outline-none">
                <option value="0">Year</option>
                @for (int y = DateTime.Now.Year; y >= 2024; y--)
                {
                    <option value="@y" selected="@(ViewBag.SelectedYear == y ? "selected" : null)">@y</option>
                }
            </select>
        </div>

        <div class="space-y-2">
            <label class="block text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-1">Selected Wave</label>
            <select id="examFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-3.5 text-xs font-bold min-w-[280px] transition-colors focus:border-brand-500 outline-none">
                <optgroup label="TRAINING BATCHES">
                    @foreach (var w in waves)
                    {
                        <option value="@w.Id" selected="@(w.Id == selectedWaveId ? "selected" : null)">
                            @w.WaveName.ToUpper() @(w.StartDate.HasValue ? $"({w.StartDate.Value.ToString("MMM yyyy")})" : "")
                        </option>
                    }
                </optgroup>
            </select>
        </div>

        <div class="space-y-2">
            <label class="block text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest px-1">Status Filter (تصفية بالحالة)</label>
            <select id="certStatusFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-3.5 text-xs font-bold min-w-[190px] transition-colors focus:border-brand-500 outline-none">
                <option value="all">All Statuses (الكل)</option>
                <option value="certified">Certified (تم إصدار الشهادة)</option>
                <option value="pending">Pending (لم تصدر شهادة)</option>
            </select>
        </div>
    </div>
</div>

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="datatable saas-table">
            <thead>
                <tr>
                    <th class="min-w-[280px]">Personnel</th>
                    <th>Wave</th>
                    <th>Branch</th>
                    <th>Status</th>
                    <th>Score</th>
                    <th>User Code</th>
                    <th>Certificate Code</th>
                    <th class="text-right px-8">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model) {
                    bool hasCertCode = !string.IsNullOrEmpty(s.CertificateCode) && s.CertificateCode.Trim() != "/";
                    string certStatus = "pending";
                    string certStatusText = "لم تصدر شهادة";
                    string statusBadgeClass = "bg-amber-500 text-amber-700 bg-opacity-10 dark:bg-amber-950/30 dark:text-amber-400 border border-amber-200 dark:border-amber-800";
                    
                    if (hasCertCode)
                    {
                        certStatus = "certified";
                        certStatusText = "تم إصدار الشهادة";
                        statusBadgeClass = "bg-emerald-500 text-emerald-700 bg-opacity-10 dark:bg-emerald-950/30 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800";
                    }

                    <tr class="student-row" data-cert-status="@certStatus">
                        <td>
                            <div class="flex items-center gap-3 px-4 py-3 flex-nowrap">
                                <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 font-bold uppercase transition-transform hover:scale-105">@(string.IsNullOrEmpty(s.StudentName) ? "?" : s.StudentName.Substring(0,1))</div>
                                <div class="flex flex-col">
                                    <div class="flex items-center gap-2">
                                        <span class="font-bold text-slate-900 dark:text-white leading-tight">@s.StudentName</span>
                                        <span class="px-2 py-0.5 rounded-full text-[8px] font-black uppercase bg-slate-100 dark:bg-slate-850 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
                                            @s.RoleName
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td><span class="text-[10px] font-black text-slate-400 uppercase">@s.WaveName</span></td>
                        <td><span class="text-[10px] font-black text-slate-400 uppercase">@(string.IsNullOrEmpty(s.BranchName) ? "--" : s.BranchName)</span></td>
                        <td>
                            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg @statusBadgeClass w-fit shadow-sm">
                                <span class="text-[10px] font-black tracking-wide">@certStatusText</span>
                            </div>
                        </td>

                        <td class="font-mono font-bold text-slate-700 dark:text-slate-300">
                            <span class="text-brand-600 dark:text-brand-400 text-sm">@(s.Score > 0 ? $"{s.Score.ToString("0.0")}%" : "--")</span>
                        </td>
                        <td>
                             <span class="text-[10px] font-bold text-slate-500 uppercase">@s.UserCode</span>
                        </td>
                        <td>
                            <span class="px-3 py-1.5 bg-amber-50 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400 font-mono text-[10px] font-bold tracking-widest rounded-lg border border-amber-200 dark:border-amber-800 shadow-sm whitespace-nowrap">
                                @(string.IsNullOrEmpty(s.CertificateCode) ? "--" : s.CertificateCode)
                            </span>
                        </td>
                        <td class="text-right px-8">
                            <div class="flex items-center justify-end gap-2">
                                @if (!hasCertCode)
                                {
                                    <button class="p-2.5 text-slate-400 hover:text-amber-600 bg-slate-50 dark:bg-slate-800 rounded-xl reassign-wave" 
                                            data-user-id="@s.Id" 
                                            data-username="@s.StudentName" 
                                            data-old-wave-id="@selectedWaveId"
                                            title="Move to another Wave">
                                        <i class="fas fa-exchange-alt"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function updateExamList() {
            const type = 0;
            const year = $('#yearFilter').val();
            const month = 0;

            $.get('/Admin/GetFilteredExams', { typeId: type, month: month, year: year, mode: 'cert' }, function (data) {
                const $examFilter = $('#examFilter');
                $examFilter.empty();

                if (data.length === 0) {
                    $examFilter.append('<option value="0">No waves found</option>');
                    return;
                }

                // Group by typeName
                const grouped = {};
                data.forEach(e => {
                    if (!grouped[e.typeName]) grouped[e.typeName] = [];
                    grouped[e.typeName].push(e);
                });

                Object.keys(grouped).sort().reverse().forEach(type => {
                    const $group = $('<optgroup>').attr('label', type.toUpperCase());
                    grouped[type].forEach(e => {
                        $group.append($('<option>').val(e.id).text(e.title));
                    });
                    $examFilter.append($group);
                });
            });
        }

        $('#yearFilter').change(updateExamList);

        $('#examFilter').change(function () { 
            const type = 0;
            const year = $('#yearFilter').val();
            const month = 0;
            let newUrl = '/Admin/Certificates?waveId=' + $(this).val() + '&typeId=' + type + '&year=' + year + '&month=' + month; 
            if (window.location.search.includes('iframe=true')) newUrl += '&iframe=true';
            window.location = newUrl;
        });



        function triggerExcelUpload() {
            Swal.fire({
                title: '<div class="flex flex-col items-center gap-2 pt-4 px-6"><i class="fas fa-file-excel text-emerald-500 text-3xl mb-2"></i><span class="text-xl font-black uppercase tracking-widest text-slate-800">Excel Import Guide</span></div>',
                html: `
                    <div class="text-left px-6 py-4 space-y-4">
                        <p class="text-sm text-slate-600 dark:text-slate-400 font-medium">To import certificates successfully, your Excel sheet must contain the following columns (headers):</p>
                        <div class="bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-4 space-y-3">
                            <div class="flex items-start gap-3">
                                <span class="bg-emerald-100 dark:bg-emerald-950 text-emerald-700 dark:text-emerald-400 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider mt-0.5">Required</span>
                                <div>
                                    <p class="text-xs font-bold text-slate-800 dark:text-slate-200">User Code (كود المستخدم)</p>
                                    <p class="text-[10px] text-slate-400">Accepted headers: Code, UserCode, User Code, الكود, كود, كود الطالب</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-3 border-t border-slate-200 dark:border-slate-800 pt-3">
                                <span class="bg-emerald-100 dark:bg-emerald-950 text-emerald-700 dark:text-emerald-400 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider mt-0.5">Required</span>
                                <div>
                                    <p class="text-xs font-bold text-slate-800 dark:text-slate-200">Certificate Code (كود الشهادة)</p>
                                    <p class="text-[10px] text-slate-400">Accepted headers: Certificate, CertificateCode, Certificate Code, الشهادة, كود الشهادة, رقم الشهادة</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-3 border-t border-slate-200 dark:border-slate-800 pt-3">
                                <span class="bg-indigo-100 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider mt-0.5">Optional</span>
                                <div>
                                    <p class="text-xs font-bold text-slate-800 dark:text-slate-200">Wave Name (اسم الويف)</p>
                                    <p class="text-[10px] text-slate-400">Accepted headers: Wave, الويف, الدورة, المجموعة, WaveName, Wave Name. If a wave doesn't exist, it will be automatically created and the student assigned to it.</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-3 border-t border-slate-200 dark:border-slate-800 pt-3">
                                <span class="bg-indigo-100 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-wider mt-0.5">Optional</span>
                                <div>
                                    <p class="text-xs font-bold text-slate-800 dark:text-slate-200">Score (النسبة المئوية / الدرجة)</p>
                                    <p class="text-[10px] text-slate-400">Accepted headers: Score, الدرجة, النسبة, النسبة المئوية, درجة, نسبة, Score %, Percentage. This will save the specified score directly in the system.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Select Excel File <i class="fas fa-upload ml-2"></i>',
                cancelButtonText: 'Cancel',
                width: '600px',
                customClass: {
                    popup: 'rounded-[32px] border border-slate-100 dark:border-slate-800 shadow-2xl bg-white dark:bg-slate-900',
                    confirmButton: 'bg-emerald-600 hover:bg-emerald-700 text-white font-black py-4 px-10 rounded-2xl transition-all shadow-xl shadow-emerald-600/10 text-xs uppercase tracking-widest',
                    cancelButton: 'bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-400 font-bold py-4 px-10 rounded-2xl transition-all text-xs uppercase'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#certExcelInput').click();
                }
            });
        }

        function uploadCertExcel(event) {
            const file = event.target.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('excelFile', file);
            
            Swal.fire({
                title: 'Importing Certificates...',
                text: 'Please wait while we process the Excel file',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            fetch('/Admin/UploadCertificatesOnlyExcel?examId=@selectedExamId&waveId=@selectedWaveId', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(res => {
                $('#certExcelInput').val('');
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Import Successful',
                        text: res.message,
                        confirmButtonText: 'Reload Page'
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Import Failed',
                        text: res.message
                    });
                }
            })
            .catch(err => {
                $('#certExcelInput').val('');
                console.error(err);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred during upload.'
                });
            });
        }

        const allWaves = @Html.Raw(Json.Serialize(waves.Select(w => new { id = w.Id, name = w.WaveName })));

        $(document).ready(function() {
            let table = $('.datatable').DataTable();

            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    const selectedFilter = $('#certStatusFilter').val();
                    if (selectedFilter === 'all') return true;

                    const row = table.row(dataIndex).node();
                    const rowStatus = $(row).attr('data-cert-status');
                    return rowStatus === selectedFilter;
                }
            );

            $('#certStatusFilter').on('change', function() {
                table.draw();
            });

            $(document).on('click', '.reassign-wave', function() {
                const userId = $(this).data('user-id');
                const username = $(this).data('username');
                const oldWaveId = $(this).data('old-wave-id');

                let optionsHtml = '';
                allWaves.forEach(w => {
                    if (w.id != oldWaveId) {
                        optionsHtml += `<option value="${w.id}">${w.name.toUpperCase()}</option>`;
                    }
                });

                if (!optionsHtml) {
                    Swal.fire('Warning', 'No other waves available for reassignment.', 'warning');
                    return;
                }

                Swal.fire({
                    title: 'Move student to another Wave',
                    html: `
                        <div class="text-left space-y-4 p-2">
                            <p class="text-sm text-slate-600">Select the destination Wave to move <strong>${username}</strong>:</p>
                            <select id="newWaveSelect" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold">
                                ${optionsHtml}
                            </select>
                        </div>
                    `,
                    showCancelButton: true,
                    confirmButtonText: 'Reassign Wave <i class="fas fa-exchange-alt ml-2"></i>',
                    cancelButtonText: 'Cancel',
                    customClass: {
                        confirmButton: 'bg-amber-600 hover:bg-amber-700 text-white font-bold py-3 px-6 rounded-xl transition-all shadow-md',
                        cancelButton: 'bg-white hover:bg-slate-50 text-slate-400 font-bold py-3 px-6 rounded-xl transition-all border border-slate-200 ml-2'
                    },
                    buttonsStyling: false
                }).then((result) => {
                    if (result.isConfirmed) {
                        const newWaveId = $('#newWaveSelect').val();
                        
                        Swal.fire({
                            title: 'Reassigning...',
                            didOpen: () => Swal.showLoading()
                        });

                        fetch('/Admin/MoveUserToWave', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded'
                            },
                            body: new URLSearchParams({
                                userId: userId,
                                oldWaveId: oldWaveId,
                                newWaveId: newWaveId
                            })
                        })
                        .then(r => r.json())
                        .then(res => {
                            if (res.success) {
                                Swal.fire('Success', res.message, 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            Swal.fire('Error', 'An error occurred.', 'error');
                        });
                    }
                });
            });
        });

    </script>
}
