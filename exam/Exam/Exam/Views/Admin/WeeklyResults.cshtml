@model IEnumerable<Exam.DTOs.ExamResultRowDto>
@{
    ViewData["Title"] = "Weekly Evaluation Matrix";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var exams = ViewBag.Exams as IEnumerable<Exam.DTOs.ExamDropdownDto> ?? Enumerable.Empty<Exam.DTOs.ExamDropdownDto>();
    var selectedExamId = ViewBag.SelectedExamId as int? ?? 0;
}

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-8 shadow-sm">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Performance Filter</h2>
            <div class="flex items-center gap-3">
                <p class="text-xl font-bold">Weekly Evaluation Matrix</p>
            </div>
        </div>
        
            <div class="flex flex-wrap items-center gap-4">
                <div class="space-y-2">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Exam Type</label>
                    <select id="typeFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-xs font-bold min-w-[150px]">
                        <option value="0">All Types</option>
                        @foreach (var type in ((IEnumerable<Exam.DTOs.ExamTypeDto>)ViewBag.ExamTypes).Where(t => !(t.TypeName ?? "").ToLower().Contains("wave")))
                        {
                            <option value="@type.Id" selected="@(ViewBag.SelectedTypeId == type.Id ? "selected" : null)">@type.TypeName.ToUpper()</option>
                        }
                    </select>
                </div>

                @{
                    var userBranches = ViewBag.UserBranches as IEnumerable<string> ?? Enumerable.Empty<string>();
                }
                @if (userBranches.Any())
                {
                    <div class="space-y-2">
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Branch</label>
                        <select id="branchFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-xs font-bold min-w-[140px]">
                            <option value="">All Branches</option>
                            @foreach (var bName in userBranches)
                            {
                                <option value="@bName">@bName</option>
                            }
                        </select>
                    </div>
                }

                <div class="space-y-2">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Year</label>
                    <select id="yearFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-xs font-bold w-[100px]">
                        <option value="0">Year</option>
                        @for (int y = DateTime.Now.Year; y >= 2024; y--)
                        {
                            <option value="@y" selected="@(ViewBag.SelectedYear == y ? "selected" : null)">@y</option>
                        }
                    </select>
                </div>

                <div class="space-y-2">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Month</label>
                    <select id="monthFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-xs font-bold w-[120px]">
                        <option value="0">Month</option>
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(ViewBag.SelectedMonth == m ? "selected" : null)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                    </select>
                </div>

                <div class="space-y-2">
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Selected Module</label>
                    <select id="examFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-5 py-3 text-sm font-bold min-w-[280px]">
                        @{
                            var groupedExams = exams.GroupBy(e => e.TypeName).OrderByDescending(g => g.Key);
                            foreach (var group in groupedExams)
                            {
                                <optgroup label="@(group.Key?.ToUpper() ?? "OTHER")">
                                    @foreach (var e in group)
                                    {
                                        <option value="@e.Id" selected="@(e.Id == selectedExamId ? "selected" : null)">
                                            @e.Title.ToUpper() @(!string.IsNullOrEmpty(e.WaveName) ? $"- {e.WaveName.ToUpper()}" : "") (@e.StartTime.ToString("MMM yyyy"))
                                        </option>
                                    }
                                </optgroup>
                            }
                        }
                    </select>
                </div>

                <div class="flex items-center gap-2 mt-auto">
                    <button id="btnExport" class="bg-indigo-50 text-indigo-600 hover:bg-indigo-100 px-6 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center gap-2">
                        <i class="fas fa-file-excel"></i> Export Report
                    </button>
                </div>
            </div>
    </div>
</div>

<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 overflow-hidden shadow-sm">
    <div id="tableWrapper" class="overflow-x-auto">
        <table id="weeklyResultsTable" class="saas-table">
            <thead>
                <tr>
                    <th class="min-w-[280px]">Personnel Node</th>
                    <th>Email Address</th>
                    <th>Branch</th>
                    <th>Status</th>
                    <th>Start Time</th>
                    <th>Finish Time</th>
                    @if (!User.IsInRole("Branch Manager"))
                    {
                        <th>Time (M)</th>
                    }
                    <th>Score</th>
                    <th>User Code</th>
                    @if (!User.IsInRole("Branch Manager"))
                    {
                        <th class="text-right px-8">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
    <div id="comingSoonContainer" class="hidden flex flex-col items-center justify-center py-16 text-center">
        <div class="w-16 h-16 bg-amber-50 dark:bg-amber-950/30 text-amber-500 dark:text-amber-400 rounded-3xl flex items-center justify-center text-2xl mb-4 shadow-sm">
            <i class="fas fa-hourglass-half animate-spin" style="animation-duration: 3s;"></i>
        </div>
        <h3 class="text-xl font-black text-slate-800 dark:text-white mb-2">Results Coming Soon</h3>
        <p class="text-sm text-slate-400 dark:text-slate-500 max-w-md">
            This exam is currently active. The evaluation matrix will be fully accessible to Branch Managers immediately after the exam closes.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        var table;
        $(document).ready(function () {
            table = $('#weeklyResultsTable').DataTable({
                serverSide: true,
                processing: true,
                ajax: {
                    url: '/Admin/GetWeeklyResultsPaged',
                    type: 'POST',
                    data: function (d) {
                        d.examId = $('#examFilter').val();
                        d.branchName = $('#branchFilter').val();
                    },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    dataSrc: function (json) {
                        if (json.isComingSoon) {
                            $('#tableWrapper').addClass('hidden');
                            $('#comingSoonContainer').removeClass('hidden');
                            $('#btnExport').addClass('pointer-events-none opacity-50');
                        } else {
                            $('#tableWrapper').removeClass('hidden');
                            $('#comingSoonContainer').addClass('hidden');
                            $('#btnExport').removeClass('pointer-events-none opacity-50');
                        }
                        return json.data;
                    }
                },
                columns: [
                    {
                        data: 'studentName',
                        render: function(data, type, row) {
                            const initial = data ? data.charAt(0).toUpperCase() : '?';
                            return `
                                <div class="flex items-center gap-3 px-4 py-3 flex-nowrap">
                                    <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 font-bold uppercase">${initial}</div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-900 dark:text-white leading-tight">${data}</span>
                                        <span class="text-[10px] font-bold text-slate-400 uppercase">${row.examType ? row.examType.toUpperCase() : ''}</span>
                                    </div>
                                </div>`;
                        }
                    },
                    { 
                        data: 'studentEmail',
                        render: function(data) {
                            return `<span class="text-xs font-medium text-slate-500">${data}</span>`;
                        }
                    },
                    {
                        data: 'branchName',
                        render: function(data) {
                            return `<span class="text-[10px] font-black text-slate-400 uppercase">${data}</span>`;
                        }
                    },
                    {
                        data: 'status',
                        render: function(data) {
                            const statusLower = (data || '').toLowerCase();
                            const isCompleted = statusLower.startsWith('completed');
                            const statusClass = isCompleted ? 'text-emerald-600 bg-emerald-500/10' : 'text-slate-500 bg-slate-400/10';
                            return `
                                <div class="flex items-center gap-1.5 px-3 py-1 rounded-full ${statusClass} w-fit">
                                    <span class="text-[10px] font-black uppercase">${data.toUpperCase()}</span>
                                </div>`;
                        }
                    },
                    {
                        data: 'actualStartTimeDate',
                        render: function(data, type, row) {
                            return `
                                <div class="flex flex-col text-center">
                                    <span class="text-[9px] text-slate-400 font-bold mb-0.5">${data}</span>
                                    <span class="text-[10px] font-bold text-slate-500 uppercase">${row.actualStartTimeTime}</span>
                                </div>`;
                        }
                    },
                    {
                        data: 'actualEndTimeDate',
                        render: function(data, type, row) {
                            return `
                                <div class="flex flex-col text-center">
                                    <span class="text-[9px] text-slate-400 font-bold mb-0.5">${data}</span>
                                    <span class="text-[10px] font-bold text-slate-500 uppercase">${row.actualEndTimeTime}</span>
                                </div>`;
                        }
                    },
                    @if (!User.IsInRole("Branch Manager"))
                    {
                        <text>
                        {
                            data: 'duration',
                            render: function(data) {
                                return `<span class="text-xs font-bold text-slate-500">${data}</span>`;
                            }
                        },
                        </text>
                    }
                    {
                        data: 'scoreDisplay',
                        render: function(data, type, row) {
                            return `
                                <div class="flex flex-col">
                                    <span class="text-brand-600 dark:text-brand-400 text-sm font-bold">${data}</span>
                                    <span class="text-[9px] text-slate-400 uppercase tracking-widest">${row.scorePercent}</span>
                                </div>`;
                        }
                    },
                    {
                        data: 'userCode',
                        render: function(data) {
                            return `<span class="text-[10px] font-bold text-slate-500 uppercase">${data}</span>`;
                        }
                    }
                    @if (!User.IsInRole("Branch Manager"))
                    {
                        <text>
                        ,
                        {
                            data: 'id',
                            orderable: false,
                            className: 'text-right px-8',
                            render: function(data, type, row) {
                                let actionHtml = `
                                    <div class="flex items-center justify-end gap-2">
                                        <button class="p-2.5 text-slate-400 hover:text-blue-600 bg-slate-50 dark:bg-slate-800 rounded-xl view-review" data-student-id="${data}" title="View Review">
                                            <i class="fas fa-eye"></i>
                                        </button>`;
                                if (row.isAdmin) {
                                    actionHtml += `
                                        <button class="p-2.5 text-slate-400 hover:text-rose-600 bg-slate-50 dark:bg-slate-800 rounded-xl wipe-data" data-student-id="${data}" data-student-name="${row.studentName}" title="Wipe Data & Reset">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>`;
                                }
                                actionHtml += `</div>`;
                                return actionHtml;
                            }
                        }
                        </text>
                    }
                ],
                deferRender: true,
                autoWidth: false,
                orderClasses: false,
                stateSave: true,
                pageLength: 10,
                lengthMenu: [[10, 25, 50], [10, 25, 50]],
                dom: '<"flex flex-col sm:flex-row justify-between items-center mb-4"lf>rt<"flex flex-col sm:flex-row justify-between items-center mt-4"ip>',
                language: {
                    search: "",
                    searchPlaceholder: "Search records...",
                    processing: '<div class="flex items-center gap-2 text-brand-600 font-bold"><i class="fas fa-circle-notch animate-spin text-lg"></i> Loading Matrix...</div>'
                }
            });
        });

        function updateExamList() {
            const type = $('#typeFilter').val();
            const year = $('#yearFilter').val();
            const month = $('#monthFilter').val();

            $.get('/Admin/GetFilteredExams', { typeId: type, month: month, year: year, mode: 'weekly' }, function (data) {
                const $examFilter = $('#examFilter');
                $examFilter.empty();

                if (data.length === 0) {
                    $examFilter.append('<option value="0">No exams found</option>');
                    table.draw();
                    return;
                }

                // Group by typeName
                const grouped = {};
                data.forEach(e => {
                    if (!grouped[e.typeName]) grouped[e.typeName] = [];
                    grouped[e.typeName].push(e);
                });

                Object.keys(grouped).sort().reverse().forEach(type => {
                    const $group = $('<optgroup>').attr('label', type.toUpperCase());
                    grouped[type].forEach(e => {
                        $group.append($('<option>').val(e.id).text(e.title));
                    });
                    $examFilter.append($group);
                });

                $examFilter.trigger('change');
            });
        }

        $('#typeFilter, #yearFilter, #monthFilter').change(updateExamList);
        $(document).on('change', '#branchFilter', function () {
            table.draw();
        });

        $('#examFilter').change(function () {
            const val = $(this).val();
            const type = $('#typeFilter').val();
            const year = $('#yearFilter').val();
            const month = $('#monthFilter').val();
            let newUrl = '/Admin/WeeklyResults?examId=' + val + '&typeId=' + type + '&year=' + year + '&month=' + month; 
            if (window.location.search.includes('iframe=true')) newUrl += '&iframe=true';
            window.history.pushState({ path: newUrl }, '', newUrl);

            table.draw();
        });

        $('#btnExport').on('click', function () { window.location = '/Admin/ExportStudentsToExcel?examId=' + $('#examFilter').val(); });

        $(document).on('click', '.view-review', function() {
            var id = $(this).data('student-id');
            var examId = $('#examFilter').val();
            Swal.fire({
                title: 'Professional Review Analysis',
                width: '80%',
                showConfirmButton: false,
                showCloseButton: true,
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                html: '<div id="swalRev" style="text-align:left; max-height: 70vh; overflow-y: auto;"><div class="py-10 text-center"><i class="fas fa-sync fa-spin text-3xl text-brand-500"></i></div></div>',
                didOpen: () => { 
                    $.get('/Admin/GetStudentExamReview', { examId: examId, studentId: id })
                     .done(h => $('#swalRev').html(h))
                     .fail(() => $('#swalRev').html('<div class="p-8 text-rose-500">Failed to load data.</div>'));
                }
            });
        });

        $(document).on('click', '.wipe-data', function() {
            const studentId = $(this).data('student-id');
            const studentName = $(this).data('student-name');
            const examId = $('#examFilter').val();

            Swal.fire({
                title: 'Are you absolutely sure?',
                text: `This will PERMANENTLY delete all answers and attempts for ${studentName}. They will need to be re-assigned to take the exam again.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, Wipe Everything!',
                cancelButtonText: 'Cancel',
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Wiping Data...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    $.post('/Admin/WipeStudentData', { examId: examId, studentId: studentId }, function(res) {
                        if (res.success) {
                            Swal.fire({
                                title: 'Success!',
                                text: res.message,
                                icon: 'success',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                table.draw(false);
                            });
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        });
    </script>
}
