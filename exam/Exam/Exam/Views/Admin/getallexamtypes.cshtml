@model IEnumerable<Exam.DTOs.ExamTypeDto>
@{
    ViewData["Title"] = "Exam Modality Hub";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="space-y-8">
    <!-- Header Area -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Architecture Config</h2>
                <p class="text-2xl font-bold bg-gradient-to-r from-slate-900 to-slate-600 dark:from-white dark:to-slate-400 bg-clip-text text-transparent">Exam Modality Manifest</p>
            </div>
            <button onclick="openCreateModal()" class="bg-slate-900 dark:bg-brand-600 text-white px-8 py-3.5 rounded-2xl transition-all text-xs font-bold uppercase shadow-xl shadow-brand-500/10 flex items-center gap-3 hover:-translate-y-0.5 active:translate-y-0">
                <i class="fas fa-layer-group text-lg"></i>
                Deploy New Modality
            </button>
        </div>
    </div>

    <!-- Main Table Area -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="datatable saas-table">
                <thead>
                    <tr>
                        <th class="pl-8 !w-24">MOD-ID</th>
                        <th>Exam Variety Name</th>
                        <th class="text-right pr-8">Operational Control</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model ?? Enumerable.Empty<Exam.DTOs.ExamTypeDto>())
                    {
                        <tr class="group">
                            <td class="pl-8">
                                <span class="font-mono text-[10px] font-bold text-slate-400 bg-slate-50 dark:bg-slate-800 px-2 py-1 rounded">#@item.Id</span>
                            </td>
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                                        <i class="fas fa-certificate text-xs"></i>
                                    </div>
                                    <span class="font-bold text-slate-700 dark:text-slate-200">@item.TypeName</span>
                                </div>
                            </td>
                            <td class="pr-8 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button onclick="openEditModal(@item.Id, '@item.TypeName')" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-slate-800 text-slate-500 hover:bg-brand-500 hover:text-white transition-all">
                                        <i class="fas fa-pen-nib"></i>
                                    </button>
                                    <button onclick="deleteType(@item.Id)" class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-slate-800 text-slate-500 hover:bg-rose-500 hover:text-white transition-all">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateModal() {
            Swal.fire({
                title: 'Deploy New Modality',
                text: 'Define a new exam type for assessment filtering.',
                input: 'text',
                inputPlaceholder: 'e.g. Midterm, Final, Diagnostic...',
                showCancelButton: true,
                confirmButtonText: 'Register Modality',
                confirmButtonColor: '#06b6d4',
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                preConfirm: (name) => {
                    if (!name) {
                        Swal.showValidationMessage('Modality name is mandatory');
                        return false;
                    }
                    return name;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    executeAction('@Url.Action("createexamtype", "Admin")', { typename: result.value });
                }
            });
        }

        function openEditModal(id, currentName) {
            Swal.fire({
                title: 'Modify Modality',
                input: 'text',
                inputValue: currentName,
                showCancelButton: true,
                confirmButtonText: 'Apply Changes',
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                preConfirm: (name) => {
                    if (!name) {
                        Swal.showValidationMessage('Name cannot be empty');
                        return false;
                    }
                    return name;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    executeAction('@Url.Action("updateexamtype", "Admin")', { id: id, name: result.value });
                }
            });
        }

        function deleteType(id) {
            Swal.fire({
                title: 'Purge Modality?',
                text: "Deleting a modality may impact exam filtering across the dashboard.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                confirmButtonText: 'Proceed with Purge',
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
            }).then((result) => {
                if (result.isConfirmed) {
                    executeAction('@Url.Action("deleteexamtype", "Admin")', { id: id });
                }
            });
        }

        async function executeAction(url, data) {
            Swal.fire({
                title: 'Syncing Registry...',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const response = await $.post(url, data);
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Synchronized',
                        text: response.message,
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', response.message, 'error');
                }
            } catch (err) {
                Swal.fire('Critical Error', 'Network synchronization failed.', 'error');
            }
        }
    </script>
}
