@model IEnumerable<Exam.DTOs.WaveStudentResultDto>
@{
    ViewData["Title"] = "Wave Performance Tracker";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var waves = ViewBag.Waves as IEnumerable<Exam.DTOs.WaveDto> ?? Enumerable.Empty<Exam.DTOs.WaveDto>();
    var selectedWaveId = ViewBag.SelectedWaveId as int? ?? 0;

    // Summary stats
    var total      = Model.Count();
    var certified  = Model.Count(s => s.WaveStatus == "CERTIFIED");
    var passed     = Model.Count(s => s.WaveStatus == "PASS");
    var failed     = Model.Count(s => s.WaveStatus == "FAILED");
    var incomplete = Model.Count(s => s.WaveStatus == "INCOMPLETE");
}

<!-- Header / Filter Row -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-8 mb-8 shadow-sm">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div>
            <h2 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em] mb-1">Wave Analytics</h2>
            <div class="flex items-center gap-3">
                <p class="text-xl font-bold">Wave Performance Tracker</p>
                <span class="bg-violet-100 text-violet-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border border-violet-200">
                    Aggregate Mode — All 12 Exams
                </span>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-4">
            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Year</label>
                <select id="yearFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-xs font-bold w-[100px]">
                    <option value="0">Year</option>
                    @for (int y = DateTime.Now.Year; y >= 2024; y--)
                    {
                        <option value="@y" selected="@(ViewBag.SelectedYear == y ? "selected" : null)">@y</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Month</label>
                <select id="monthFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-2 text-xs font-bold w-[120px]">
                    <option value="0">Month</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(ViewBag.SelectedMonth == m ? "selected" : null)">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                    }
                </select>
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Training Wave</label>
                <select id="waveFilter" class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-5 py-3 text-sm font-bold min-w-[260px]">
                    <optgroup label="TRAINING BATCHES">
                        @foreach (var w in waves)
                        {
                            <option value="@w.Id" selected="@(w.Id == selectedWaveId ? "selected" : null)">
                                @w.WaveName.ToUpper() @(w.StartDate.HasValue ? $"({w.StartDate.Value.ToString("MMM yyyy")})" : "")
                            </option>
                        }
                    </optgroup>
                </select>
            </div>

            <div class="flex items-center gap-2 mt-auto">
                <button id="btnExport" class="bg-indigo-50 text-indigo-600 hover:bg-indigo-100 px-6 py-3 rounded-2xl text-[10px] font-black tracking-widest uppercase transition-all flex items-center gap-2">
                    <i class="fas fa-file-excel"></i> Export
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[24px] p-5 shadow-sm flex flex-col gap-1">
        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Total Students</span>
        <span class="text-3xl font-black text-slate-900 dark:text-white">@total</span>
    </div>
    <div class="bg-emerald-50 dark:bg-emerald-950 border border-emerald-200 dark:border-emerald-800 rounded-[24px] p-5 shadow-sm flex flex-col gap-1">
        <span class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Certified</span>
        <span class="text-3xl font-black text-emerald-700">@certified</span>
        <span class="text-[9px] font-bold text-emerald-500">≥ 75% total score</span>
    </div>
    <div class="bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 rounded-[24px] p-5 shadow-sm flex flex-col gap-1">
        <span class="text-[10px] font-black text-blue-600 uppercase tracking-widest">Pass (No Cert)</span>
        <span class="text-3xl font-black text-blue-700">@passed</span>
        <span class="text-[9px] font-bold text-blue-500">70% – 74.9%</span>
    </div>
    <div class="bg-rose-50 dark:bg-rose-950 border border-rose-200 dark:border-rose-800 rounded-[24px] p-5 shadow-sm flex flex-col gap-1">
        <span class="text-[10px] font-black text-rose-600 uppercase tracking-widest">Failed / Incomplete</span>
        <span class="text-3xl font-black text-rose-700">@(failed + incomplete)</span>
        <span class="text-[9px] font-bold text-rose-400">@incomplete incomplete · @failed failed</span>
    </div>
</div>

<!-- Results Table -->
<div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-[32px] p-6 overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="datatable saas-table" id="waveResultsTable">
            <thead>
                <tr>
                    <th class="min-w-[240px]">Personnel</th>
                    <th>Branch</th>
                    <th>Role</th>
                    <th>Exams Done</th>
                    <th>Score</th>
                    <th>Percentage</th>
                    <th>Wave Status</th>
                    <th>Cert Code</th>
                    <th class="text-right px-8">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-12 text-slate-400">
                            <div class="flex flex-col items-center justify-center gap-3">
                                <div class="w-16 h-16 bg-slate-50 dark:bg-slate-900 rounded-full flex items-center justify-center text-slate-400 dark:text-slate-600 shadow-inner">
                                    <i class="fas fa-inbox text-2xl"></i>
                                </div>
                                <span class="font-bold text-sm">No records found for this branch or wave</span>
                                <p class="text-xs text-slate-400 max-w-xs leading-relaxed">Ensure the selected wave contains exams and that students from your branch are assigned to it.</p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var s in Model)
                {
                    <tr>
                        <td>
                            <div class="flex items-center gap-3 px-2 py-2 flex-nowrap">
                                <div class="w-10 h-10 bg-slate-50 dark:bg-slate-800 rounded-xl flex items-center justify-center text-slate-400 font-bold uppercase">
                                    @(s.StudentName.Length > 0 ? s.StudentName.Substring(0, 1) : "?")
                                </div>
                                <div class="flex flex-col">
                                    <span class="font-bold text-slate-900 dark:text-white leading-tight">@s.StudentName</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">@s.StudentEmail</span>
                                    <span class="text-[9px] font-bold text-slate-300 uppercase">@s.UserCode</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="text-[10px] font-black text-slate-400 uppercase">@(string.IsNullOrEmpty(s.BranchName) ? "--" : s.BranchName)</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(s.RoleName))
                            {
                                bool isPharm = s.RoleName.ToLower().Contains("pharmacist") || s.RoleName.Contains("صيدل");
                                <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase @(isPharm ? "bg-purple-50 text-purple-600 border border-purple-200" : "bg-sky-50 text-sky-600 border border-sky-200")">
                                    @(isPharm ? "Pharmacist" : "Assistant")
                                </span>
                            }
                            else
                            {
                                <span class="text-slate-400 text-xs">--</span>
                            }
                        </td>
                        <td>
                            <div class="flex flex-col items-center">
                                <span class="text-sm font-black @(s.IsFullyCompleted ? "text-emerald-600" : "text-amber-500")">
                                    @s.ExamsCompleted / @s.TotalExamsInWave
                                </span>
                                @if (!s.IsFullyCompleted)
                                {
                                    <span class="text-[9px] text-amber-400 font-bold">@(s.TotalExamsInWave - s.ExamsCompleted) pending</span>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="flex flex-col">
                                <span class="text-brand-600 dark:text-brand-400 text-sm font-bold font-mono">
                                    @s.TotalScore.ToString("0") / @s.TotalAvailable.ToString("0")
                                </span>
                            </div>
                        </td>
                        <td>
                            @{
                                double pct = s.TotalAvailable > 0 ? (double)(s.TotalScore / s.TotalAvailable) * 100 : 0;
                                string pctColor = pct >= 75 ? "text-emerald-600" : pct >= 70 ? "text-blue-600" : "text-rose-500";
                            }
                            <span class="font-black text-sm @pctColor">@pct.ToString("0.0")%</span>
                        </td>
                        <td>
                            @switch (s.WaveStatus)
                            {
                                case "CERTIFIED":
                                    <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-200 flex items-center gap-1 w-fit">
                                        <i class="fas fa-certificate"></i> CERTIFIED
                                    </span>
                                    break;
                                case "PASS":
                                    <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-blue-50 text-blue-600 border border-blue-200 w-fit">PASS (NO CERT)</span>
                                    break;
                                case "FAILED":
                                    <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-rose-50 text-rose-600 border border-rose-200 w-fit">FAILED</span>
                                    break;
                                default:
                                    <span class="px-3 py-1 rounded-lg text-[10px] font-black uppercase bg-amber-50 text-amber-600 border border-amber-200 w-fit">
                                        <i class="fas fa-clock mr-1"></i> INCOMPLETE
                                    </span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(s.CertificateCode))
                            {
                                <span class="text-[10px] font-mono font-bold text-slate-600 dark:text-slate-300 bg-slate-50 dark:bg-slate-800 px-2 py-1 rounded-lg">@s.CertificateCode</span>
                            }
                            else
                            {
                                <span class="text-slate-300 text-xs">--</span>
                            }
                        </td>
                        <td class="text-right px-8">
                            <button type="button" 
                                    class="p-2.5 text-slate-400 hover:text-blue-600 bg-slate-50 dark:bg-slate-800 rounded-xl view-wave-details" 
                                    data-student-id="@s.UserId" 
                                    data-wave-id="@s.WaveId" 
                                    title="View Exam Details">
                                <i class="fas fa-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Filter dropdowns → reload page
        function applyFilters() {
            const waveId = $('#waveFilter').val();
            const year   = $('#yearFilter').val();
            const month  = $('#monthFilter').val();
            let url = '/Admin/WaveyResults?waveId=' + waveId + '&year=' + year + '&month=' + month;
            if (window.location.search.includes('iframe=true')) url += '&iframe=true';
            window.location = url;
        }

        // Wave / year / month change → dynamically reload wave list then page
        $('#yearFilter, #monthFilter').change(function () {
            const year  = $('#yearFilter').val();
            const month = $('#monthFilter').val();

            $.get('/Admin/GetFilteredExams', { month: month, year: year, mode: 'cert' }, function (data) {
                const $wf = $('#waveFilter');
                $wf.empty();
                if (data.length === 0) {
                    $wf.append('<option value="0">No waves found</option>');
                } else {
                    const $grp = $('<optgroup>').attr('label', 'TRAINING BATCHES');
                    data.forEach(w => $grp.append($('<option>').val(w.id).text(w.title)));
                    $wf.append($grp);
                }
                applyFilters();
            });
        });

        $('#waveFilter').change(applyFilters);

        // Export
        $('#btnExport').on('click', function () {
            window.location = '/Admin/ExportWaveResultsToExcel?waveId=' + $('#waveFilter').val();
        });

        // View wave breakdown details
        $(document).on('click', '.view-wave-details', function() {
            const id = $(this).data('student-id');
            const waveId = $(this).data('wave-id');
            Swal.fire({
                title: 'Student Wave Performance Breakdown',
                width: '70%',
                showConfirmButton: false,
                showCloseButton: true,
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                html: '<div id="swalWaveDetails" style="text-align:left; max-height: 75vh; overflow-y: auto;"><div class="py-10 text-center"><i class="fas fa-sync fa-spin text-3xl text-brand-500"></i></div></div>',
                didOpen: () => { 
                    $.get('/Admin/GetStudentWaveDetails', { studentId: id, waveId: waveId })
                     .done(h => $('#swalWaveDetails').html(h))
                     .fail(() => $('#swalWaveDetails').html('<div class="p-8 text-rose-500">Failed to load data.</div>'));
                }
            });
        });

        // View individual exam review
        function viewIndividualExamReview(examId, studentId, examTitle) {
            Swal.fire({
                title: `Review: ${examTitle}`,
                width: '80%',
                showConfirmButton: false,
                showCloseButton: true,
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000',
                html: '<div id="swalIndividualReview" style="text-align:left; max-height: 70vh; overflow-y: auto;"><div class="py-10 text-center"><i class="fas fa-sync fa-spin text-3xl text-brand-500"></i></div></div>',
                didOpen: () => { 
                    $.get('/Admin/GetStudentExamReview', { examId: examId, studentId: studentId })
                     .done(h => $('#swalIndividualReview').html(h))
                     .fail(() => $('#swalIndividualReview').html('<div class="p-8 text-rose-500">Failed to load data.</div>'));
                }
            });
        }
    </script>
}
