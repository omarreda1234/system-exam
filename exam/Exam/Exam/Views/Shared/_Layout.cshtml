<!DOCTYPE html>
<html lang="en" translate="no" class="notranslate">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google" content="notranslate">
    <title>@ViewData["Title"] - Eltarshoubi Training Academy</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/jpeg" href="~/images/logo.jpeg" />
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons & Styling -->
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <script src="~/lib/tailwind/tailwindcss.js"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#edf4f3',
                            100: '#d1e4e2',
                            200: '#a8cdca',
                            300: '#75b0ab',
                            400: '#48918a',
                            500: '#2a766f',
                            600: '#01443c',
                            700: '#013831',
                            800: '#012c27',
                            900: '#011f1c',
                            950: '#00120f',
                        }
                    },
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    
    <style>
        .nav-link {
            @@apply flex items-center px-4 py-2 text-xs font-bold text-slate-500 hover:text-brand-600 transition-all uppercase tracking-widest;
        }
        .nav-link.active {
            @@apply text-brand-600;
        }
        .glass-nav {
            @@apply bg-white/80 backdrop-blur-xl border-b border-slate-100;
        }
    </style>
</head>
<body class="bg-white text-slate-900 font-sans selection:bg-brand-100 selection:text-brand-700">
    
    @if (ViewData["HideNavbar"] as bool? != true)
    {
    <header class="sticky top-0 z-50 glass-nav">
        <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <!-- Logo area -->
            <a href="/" class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center p-1 border border-slate-100 shadow-sm">
                    <img src="~/images/logo.jpeg" alt="Logo" class="w-full h-full object-contain" />
                </div>
                <div class="hidden sm:block">
                    <span class="text-sm font-black tracking-tight block leading-none text-slate-900 uppercase">Eltarshoubi</span>
                    <span class="text-[9px] font-bold text-brand-600 tracking-[0.2em] uppercase">Academy</span>
                </div>
            </a>

            <!-- Center Nav Links -->
            <div class="hidden lg:flex items-center gap-2 p-1 bg-slate-100/50 rounded-2xl border border-slate-200/50">
                <a href="/" class="rounded-xl px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow-sm transition-all">Home</a>
                <a href="#about" class="rounded-xl px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow-sm transition-all">About</a>
                <a href="#program" class="rounded-xl px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow-sm transition-all">Program</a>
            </div>

            <div class="flex items-center gap-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="hidden md:flex items-center gap-2 mr-4 border-r border-slate-100 pr-4">
                        @if (User.IsInRole("Admin") || User.IsInRole("HR") || User.IsInRole("Branch Manager") || User.IsInRole("SoftSkills Specialist"))
                        {
                            <a href="@Url.Action("Index", "Admin")" class="text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl bg-brand-600 text-white shadow-lg shadow-brand-600/20 hover:bg-brand-700 transition-all">
                                <i class="fas fa-chart-pie mr-2"></i>Examination Dash
                            </a>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Reception") || User.IsInRole("SoftSkills Specialist"))
                        {
                            <a href="@Url.Action("Index", "Attendance")" class="text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl bg-indigo-600 text-white shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 transition-all">
                                <i class="fas fa-calendar-check mr-2"></i>Attendance
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("Index", "Materials")" class="text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl bg-slate-900 text-white hover:bg-slate-800 transition-all">
                                <i class="fas fa-project-diagram mr-2"></i>Program Dash
                            </a>
                        }

                        @if (User.IsInRole("pharmacist") || User.IsInRole("assistant") || User.IsInRole("صيدلي") || User.IsInRole("مساعد صيدلي") || User.IsInRole("Pharmacist") || User.IsInRole("Assistant") || User.IsInRole("Doctor"))
                        {
                            <a href="@Url.Action("Index", "Materials")" class="text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl bg-emerald-600 text-white shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 transition-all">
                                <i class="fas fa-project-diagram mr-2"></i>Program Dash
                            </a>
                        }
                        @if (User.IsInRole("pharmacist") || User.IsInRole("assistant") || User.IsInRole("صيدلي") || User.IsInRole("مساعد صيدلي") || User.IsInRole("Pharmacist") || User.IsInRole("Assistant") || User.IsInRole("Doctor"))
                        {
                            <a href="@Url.Action("StudentExams", "Home")" class="text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl bg-brand-600 text-white shadow-lg shadow-brand-600/20 hover:bg-brand-700 transition-all">
                                <i class="fas fa-file-signature mr-2"></i>My Exams
                            </a>
                        }
                    </div>

                    <div class="flex items-center gap-3 relative">
                        @{
                            string roleDisplay = "Trainee Node";
                            if (User.IsInRole("Admin")) roleDisplay = "Administrator";
                            else if (User.IsInRole("HR") || User.IsInRole("Human Resources")) roleDisplay = "Human Resources";
                            else if (User.IsInRole("Reception")) roleDisplay = "Receptionist";
                            else if (User.IsInRole("Branch Manager")) roleDisplay = "Branch Manager";
                            else if (User.IsInRole("SoftSkills Specialist")) roleDisplay = "Soft Skills Specialist";
                        }
                        <button id="profileDropdownBtn" class="w-8 h-8 rounded-full bg-brand-50 border border-brand-100 flex items-center justify-center text-brand-600 hover:bg-brand-100 dark:hover:bg-brand-500/20 font-black text-xs transition-all focus:outline-none focus:ring-2 focus:ring-brand-500/20">
                            @(User.Identity.Name?[0].ToString().ToUpper() ?? "U")
                        </button>
                        
                        <!-- Dropdown Menu -->
                        <div id="profileDropdown" class="hidden absolute right-0 top-10 mt-2 w-64 bg-white rounded-2xl shadow-xl border border-slate-100 py-3 z-50 transition-all duration-300">
                            <div class="px-4 py-3 border-b border-slate-50 mb-2">
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest leading-none">Active Session</p>
                                <p class="text-xs font-black text-slate-800 truncate mt-1.5 mb-0.5">@User.Identity.Name</p>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-bold bg-brand-50 text-brand-600 uppercase tracking-wider mt-1">
                                    <i class="fas fa-shield-alt mr-1"></i> @roleDisplay
                                </span>
                            </div>
                            <div class="px-2">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="w-full">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-full flex items-center gap-2.5 px-3 py-2 text-left text-xs font-bold text-rose-500 hover:bg-rose-50 rounded-xl transition-all">
                                        <i class="fas fa-power-off text-sm"></i>
                                        <span>Sign Out</span>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <form asp-controller="Auth" asp-action="Logout" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-rose-500 transition-colors">
                                <i class="fas fa-power-off"></i>
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <a href="/Auth/Login" class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-brand-600/20 transition-all">
                            sign in
                    </a>
                }
                <!-- Mobile Menu Button -->
                <button id="mobileMenuBtn" class="lg:hidden ml-2 w-10 h-10 flex items-center justify-center text-slate-600 bg-slate-50 rounded-xl border border-slate-200 hover:bg-slate-100 transition-colors">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
        </nav>
        <!-- Mobile Menu Panel -->
        <div id="mobileMenu" class="hidden lg:hidden bg-white border-t border-slate-100 px-6 py-6 shadow-2xl absolute w-full left-0 top-20">
            <div class="flex flex-col gap-6">
                <a href="/" class="text-sm font-black uppercase tracking-widest text-slate-700 hover:text-brand-600">Home</a>
                <a href="/#about" class="text-sm font-black uppercase tracking-widest text-slate-700 hover:text-brand-600">About</a>
                <a href="/#program" class="text-sm font-black uppercase tracking-widest text-slate-700 hover:text-brand-600">Program</a>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="h-px bg-slate-100 w-full my-2"></div>
                    @if (User.IsInRole("Admin") || User.IsInRole("HR") || User.IsInRole("Branch Manager") || User.IsInRole("SoftSkills Specialist"))
                    {
                        <a href="@Url.Action("Index", "Admin")" class="text-xs font-black uppercase tracking-widest text-brand-600"><i class="fas fa-chart-pie mr-2"></i> Examination Dash</a>
                    }
                    @if (User.IsInRole("Admin") || User.IsInRole("Reception") || User.IsInRole("SoftSkills Specialist"))
                    {
                        <a href="@Url.Action("Index", "Attendance")" class="text-xs font-black uppercase tracking-widest text-indigo-600"><i class="fas fa-calendar-check mr-2"></i> Attendance</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="@Url.Action("Index", "Materials")" class="text-xs font-black uppercase tracking-widest text-slate-900"><i class="fas fa-project-diagram mr-2"></i> Program Dash</a>
                    }

                    @if (User.IsInRole("pharmacist") || User.IsInRole("assistant") || User.IsInRole("صيدلي") || User.IsInRole("مساعد صيدلي") || User.IsInRole("Pharmacist") || User.IsInRole("Assistant") || User.IsInRole("Doctor"))
                    {
                        <a href="@Url.Action("Index", "Materials")" class="text-xs font-black uppercase tracking-widest text-emerald-600"><i class="fas fa-project-diagram mr-2"></i> Program Dash</a>
                    }
                    @if (User.IsInRole("pharmacist") || User.IsInRole("assistant") || User.IsInRole("صيدلي") || User.IsInRole("مساعد صيدلي") || User.IsInRole("Pharmacist") || User.IsInRole("Assistant") || User.IsInRole("Doctor"))
                    {
                        <a href="@Url.Action("StudentExams", "Home")" class="text-xs font-black uppercase tracking-widest text-brand-600"><i class="fas fa-file-signature mr-2"></i> My Exams</a>
                    }
                }
            </div>
        </div>
    </header>
    }

    <main>
        @RenderBody()
    </main>

    @if (ViewData["HideNavbar"] as bool? != true)
    {
    <footer class="bg-slate-950 text-slate-400 pt-20 pb-10 mt-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20 text-center md:text-left">
                <div class="col-span-1 md:col-span-2">
                    <div class="flex items-center justify-center md:justify-start gap-3 mb-6">
                        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center text-white">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                            <span class="text-lg font-black text-white tracking-tight uppercase">Eltarshoubi Academy</span>
                    </div>
                    <p class="text-sm leading-relaxed max-w-sm mx-auto md:mx-0">
                        Bridging academia and clinical excellence through innovation. Empowering practitioners since 2008.
                    </p>
                </div>
                <div>
                    <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Resources</h4>
                    <ul class="space-y-4 text-[10px] font-bold uppercase tracking-widest">
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Privacy Policy</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Accreditation</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Terms of Service</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Connect</h4>
                    <div class="flex justify-center md:justify-start gap-4">
                        <a href="#" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-brand-600 transition-all hover:-translate-y-1">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                        <a href="#" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-brand-600 transition-all hover:-translate-y-1">
                            <i class="fab fa-twitter"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="pt-10 border-t border-white/10 text-center text-[9px] font-black tracking-[0.3em] uppercase opacity-40">
                &copy; @DateTime.Now.Year Eltarshouby Medical Training Academy.
            </div>
        </div>
    </footer>
    }

    <script src="~/lib/jquery-3.6.0/jquery.min.js"></script>
    <script src="~/lib/sweetalert2-11/sweetalert2.all.min.js"></script>
        <script>
            (function () {
                var successMsg = "@(TempData["SuccessMessage"]?.ToString())";
                var errorMsg = "@(TempData["ErrorMessage"]?.ToString())";
                if (successMsg) { Swal.fire({ icon: 'success', title: 'Synchronized', text: successMsg, timer: 3000, background: '#fff' }); }
                if (errorMsg) { Swal.fire({ icon: 'error', title: 'Protocol Alert', text: errorMsg, background: '#fff' }); }
 
                // Mobile Menu Toggle
                $('#mobileMenuBtn').on('click', function() {
                    $('#mobileMenu').slideToggle('fast');
                });

                // Profile Dropdown Toggle
                $('#profileDropdownBtn').on('click', function(e) {
                    e.stopPropagation();
                    $('#profileDropdown').toggleClass('hidden');
                });

                $(document).on('click', function(e) {
                    if (!$(e.target).closest('#profileDropdownBtn, #profileDropdown').length) {
                        $('#profileDropdown').addClass('hidden');
                    }
                });
            })();
        </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>




