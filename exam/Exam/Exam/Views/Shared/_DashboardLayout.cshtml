    <script>
        let isChatOpen = false;
        let selectedImageBase64 = null;
        let selectedImageName = "";
        let voiceRecognitionInstance = null;

        // Session Management Structure
        let aiSessions = [];
        let activeSessionId = null;

        function toggleAIChat() {
            const panel = document.getElementById('aiChatPanel');
            const adminPanel = document.getElementById('adminChatPanel');
            isChatOpen = !isChatOpen;
            if (isChatOpen) {
                panel.classList.remove('hidden');
                setTimeout(() => { panel.classList.add('active'); }, 50);
                // Clear notification badge
                const badge = document.querySelector('#aiChatBtn span.bg-amber-500');
                if (badge) badge.remove();
                
                // Initialize sessions
                initSessions();

                // Side-by-side logic
                if (typeof adminChatOpen !== 'undefined' && adminChatOpen && adminPanel) {
                    adminPanel.style.right = '440px';
                }
            } else {
                panel.classList.remove('active');

                // Restore side-by-side logic
                if (typeof adminChatOpen !== 'undefined' && adminPanel) {
                    adminPanel.style.right = '92px';
                }
            }
        }

        // Sessions Drawer Controls
        function toggleSessionsDrawer() {
            const drawer = document.getElementById('aiSessionsDrawer');
            if (drawer.classList.contains('-translate-x-full')) {
                drawer.classList.remove('-translate-x-full');
                renderSessionsList();
            } else {
                drawer.classList.add('-translate-x-full');
            }
        }

        function initSessions() {
            const stored = localStorage.getItem('ai_chat_sessions');
            const storedActive = localStorage.getItem('active_ai_session_id');
            
            if (stored) {
                try {
                    aiSessions = JSON.parse(stored);
                } catch(e) {
                    aiSessions = [];
                }
            }
            
            if (!aiSessions || aiSessions.length === 0) {
                aiSessions = [];
                createNewSession(true); // Create default session silently
            } else {
                activeSessionId = storedActive || aiSessions[0].id;
                // Verify activeSessionId exists
                if (!aiSessions.find(s => s.id === activeSessionId)) {
                    activeSessionId = aiSessions[0].id;
                }
                loadSession(activeSessionId);
            }
        }

        function createNewSession(isSilent = false) {
            const newId = 'session_' + Date.now();
            const newSession = {
                id: newId,
                title: 'New Chat Session',
                messages: [
                    {
                        isUser: false,
                        text: "Welcome Doctor / Assistant! ðŸ‘‹\n\nI am your academic research assistant. You can speak to me, upload clinical diagrams/images, or ask questions about safety standards, formulas, or course structures! How can I help you study today?"
                    }
                ]
            };
            
            aiSessions.unshift(newSession);
            saveSessionsToStorage();
            
            activeSessionId = newId;
            localStorage.setItem('active_ai_session_id', newId);
            
            if (!isSilent) {
                loadSession(newId);
                Swal.fire({
                    title: 'New Chat Created',
                    text: 'A fresh study session has been started.',
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false,
                    background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                    color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
                });
            }
        }

        function saveSessionsToStorage() {
            localStorage.setItem('ai_chat_sessions', JSON.stringify(aiSessions));
        }

        function loadSession(sessionId) {
            activeSessionId = sessionId;
            localStorage.setItem('active_ai_session_id', sessionId);
            
            const session = aiSessions.find(s => s.id === sessionId);
            if (!session) return;
            
            // Set active title in header
            document.getElementById('activeSessionTitle').innerText = session.title;
            
            // Render Messages
            const msgContainer = document.getElementById('aiChatMessages');
            msgContainer.innerHTML = '';
            
            session.messages.forEach(msg => {
                let msgHtml = '';
                if (msg.isUser) {
                    msgHtml = `
                        <div class="flex items-start justify-end gap-3">
                            <div class="bg-brand-600 text-white rounded-2xl rounded-tr-none p-4 shadow-sm text-xs leading-relaxed max-w-[80%] text-left">
                    `;
                    if (msg.imageBase64) {
                        msgHtml += `
                            <div class="mb-2 max-w-[150px] rounded-lg overflow-hidden border border-white/20">
                                <img src="${msg.imageBase64}" class="w-full object-cover" />
                            </div>
                        `;
                    }
                    if (msg.text) {
                        msgHtml += `<p>${msg.text}</p>`;
                    }
                    msgHtml += `
                            </div>
                            <div class="w-8 h-8 rounded-xl bg-brand-600 text-white flex items-center justify-center text-xs flex-shrink-0 font-bold">
                                U
                            </div>
                        </div>
                    `;
                } else {
                    msgHtml = `
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-xl bg-brand-100 dark:bg-brand-950/40 text-brand-600 dark:text-brand-400 flex items-center justify-center text-xs flex-shrink-0">
                                <i class="fas fa-robot"></i>
                            </div>
                            <div class="bg-white dark:bg-slate-800 rounded-2xl rounded-tl-none p-4 shadow-sm border border-slate-100 dark:border-slate-800 text-xs text-slate-700 dark:text-slate-300 leading-relaxed max-w-[80%] whitespace-pre-line">
                                ${msg.text}
                            </div>
                        </div>
                    `;
                }
                msgContainer.insertAdjacentHTML('beforeend', msgHtml);
            });
            
            msgContainer.scrollTop = msgContainer.scrollHeight;
        }

        function deleteSession(sessionId, event) {
            if (event) event.stopPropagation(); // Avoid loading session when clicking delete
            
            Swal.fire({
                title: 'Delete this chat?',
                text: "This specific session's history will be permanently deleted.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#01443c',
                confirmButtonText: 'Yes, delete it',
                background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
            }).then((result) => {
                if (result.isConfirmed) {
                    aiSessions = aiSessions.filter(s => s.id !== sessionId);
                    saveSessionsToStorage();
                    
                    if (aiSessions.length === 0) {
                        createNewSession(true);
                    } else if (activeSessionId === sessionId) {
                        loadSession(aiSessions[0].id);
                    }
                    
                    renderSessionsList();
                    
                    Swal.fire({
                        title: 'Deleted!',
                        text: 'Session has been removed.',
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false,
                        background: document.documentElement.classList.contains('dark') ? '#0f172a' : '#fff',
                        color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
                    });
                }
            });
        }

        function renderSessionsList() {
            const list = document.getElementById('sessionsList');
            list.innerHTML = '';
            
            aiSessions.forEach(s => {
                const isActive = s.id === activeSessionId;
                const activeClasses = isActive 
                    ? 'bg-brand-600/20 text-brand-400 border border-brand-500/30' 
                    : 'hover:bg-slate-800/50 text-slate-300 border border-transparent';
                
                const itemHtml = `
                    <div onclick="loadSession('${s.id}'); toggleSessionsDrawer();" class="group flex items-center justify-between px-3 py-3 rounded-xl cursor-pointer transition-all ${activeClasses}">
                        <div class="flex items-center gap-2.5 min-w-0 flex-1">
                            <i class="fas fa-comments text-xs text-slate-500 group-hover:text-brand-400"></i>
                            <span class="text-xs font-semibold truncate select-none">${s.title}</span>
                        </div>
                        <button onclick="deleteSession('${s.id}', event)" class="w-6 h-6 rounded-lg text-slate-500 hover:text-red-400 hover:bg-slate-800 flex items-center justify-center transition-colors opacity-0 group-hover:opacity-100" title="Delete chat">
                            <i class="fas fa-trash-alt text-[10px]"></i>
                        </button>
                    </div>
                `;
                list.insertAdjacentHTML('beforeend', itemHtml);
            });
        }

        function previewImageInput(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                selectedImageName = file.name;
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    selectedImageBase64 = e.target.result;
                    document.getElementById('imagePreviewThumbnail').src = selectedImageBase64;
                    document.getElementById('imagePreviewName').innerText = selectedImageName;
                    document.getElementById('imagePreviewBar').classList.remove('hidden');
                    document.getElementById('imagePreviewBar').classList.add('flex');
                };
                reader.readAsDataURL(file);
            }
        }

        function removeSelectedImage() {
            selectedImageBase64 = null;
            selectedImageName = "";
            document.getElementById('aiImageInput').value = "";
            document.getElementById('imagePreviewBar').classList.remove('flex');
            document.getElementById('imagePreviewBar').classList.add('hidden');
        }

        function toggleVoiceRecognition() {
            const micBtn = document.getElementById('aiMicBtn');
            const chatInput = document.getElementById('aiChatInput');

            if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
                const SpeechReq = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!voiceRecognitionInstance) {
                    voiceRecognitionInstance = new SpeechReq();
                    voiceRecognitionInstance.continuous = false;
                    voiceRecognitionInstance.lang = 'ar-EG';
                    voiceRecognitionInstance.interimResults = false;

                    voiceRecognitionInstance.onstart = function() {
                        micBtn.innerHTML = '<i class="fas fa-circle-notch animate-spin text-red-500 text-lg"></i>';
                        micBtn.classList.add('bg-red-50', 'dark:bg-red-950/20');
                    };

                    voiceRecognitionInstance.onresult = function(event) {
                        const transcript = event.results[0][0].transcript;
                        chatInput.value = (chatInput.value + " " + transcript).trim();
                    };

                    voiceRecognitionInstance.onend = function() {
                        micBtn.innerHTML = '<i class="fas fa-microphone text-base text-slate-400"></i>';
                        micBtn.classList.remove('bg-red-50', 'dark:bg-red-950/20');
                        voiceRecognitionInstance = null;
                    };

                    voiceRecognitionInstance.onerror = function() {
                        micBtn.innerHTML = '<i class="fas fa-microphone text-base text-slate-400"></i>';
                        micBtn.classList.remove('bg-red-50', 'dark:bg-red-950/20');
                        voiceRecognitionInstance = null;
                    };

                    voiceRecognitionInstance.start();
                } else {
                    voiceRecognitionInstance.stop();
                }
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Browser Compatibility',
                    text: 'Speech Recognition is not supported in this browser. Try Google Chrome or Safari!'
                });
            }
        }

        function handleChatSubmit(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendAIChat();
            }
        }

        function sendAIChat() {
            const input = document.getElementById('aiChatInput');
            const text = input.value.trim();
            if (!text && !selectedImageBase64) return;

            const msgContainer = document.getElementById('aiChatMessages');
            const currentImg = selectedImageBase64;
            
            // Append User Message
            let userMsgHtml = `
                <div class="flex items-start justify-end gap-3">
                    <div class="bg-brand-600 text-white rounded-2xl rounded-tr-none p-4 shadow-sm text-xs leading-relaxed max-w-[80%] text-left">
            `;
            
            if (currentImg) {
                userMsgHtml += `
                    <div class="mb-2 max-w-[150px] rounded-lg overflow-hidden border border-white/20">
                        <img src="${currentImg}" class="w-full object-cover" />
                    </div>
                `;
            }
            
            if (text) {
                userMsgHtml += `<p>${text}</p>`;
            }
            
            userMsgHtml += `
                    </div>
                    <div class="w-8 h-8 rounded-xl bg-brand-600 text-white flex items-center justify-center text-xs flex-shrink-0 font-bold">
                        U
                    </div>
                </div>
            `;

            msgContainer.insertAdjacentHTML('beforeend', userMsgHtml);
            msgContainer.scrollTop = msgContainer.scrollHeight;

            // Update Active Session Object
            const session = aiSessions.find(s => s.id === activeSessionId);
            if (session) {
                session.messages.push({
                    isUser: true,
                    text: text,
                    imageBase64: currentImg
                });
                
                if (session.title === 'New Chat Session' && text) {
                    session.title = text.length > 25 ? text.substring(0, 22) + '...' : text;
                    document.getElementById('activeSessionTitle').innerText = session.title;
                }
                saveSessionsToStorage();
            }

            // Reset Inputs immediately
            input.value = "";
            removeSelectedImage();

            // Typing indicator
            const typingId = "ai-typing-" + Date.now();
            const typingHtml = `
                <div class="flex items-start gap-3" id="${typingId}">
                    <div class="w-8 h-8 rounded-xl bg-brand-100 dark:bg-brand-950/40 text-brand-600 dark:text-brand-400 flex items-center justify-center text-xs flex-shrink-0">
                        <i class="fas fa-robot"></i>
                    </div>
                    <div class="bg-white dark:bg-slate-800 rounded-2xl rounded-tl-none p-4 shadow-sm border border-slate-100 dark:border-slate-800 text-xs text-slate-700 dark:text-slate-300 leading-relaxed max-w-[80%] flex items-center gap-1.5">
                        <span class="typing-dot w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce"></span>
                        <span class="typing-dot w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: -0.32s"></span>
                        <span class="typing-dot w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: -0.16s"></span>
                    </div>
                </div>
            `;
            msgContainer.insertAdjacentHTML('beforeend', typingHtml);
            msgContainer.scrollTop = msgContainer.scrollHeight;

            // Prepare history for context
            const requestHistory = [];
            if (session && session.messages) {
                const historySource = session.messages.slice(0, -1);
                const recentHistory = historySource.slice(Math.max(0, historySource.length - 8));
                recentHistory.forEach(h => {
                    requestHistory.push({
                        isUser: h.isUser,
                        text: h.text
                    });
                });
            }

            // AJAX call to real backend API endpoint
            $.ajax({
                url: '/api/ai/chat',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    message: text,
                    imageBase64: currentImg,
                    history: requestHistory
                }),
                success: function(res) {
                    const typingIndicator = document.getElementById(typingId);
                    if (typingIndicator) typingIndicator.remove();

                    const aiResponse = res.reply || res.message;
                    
                    const aiMsgHtml = `
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-xl bg-brand-100 dark:bg-brand-950/40 text-brand-600 dark:text-brand-400 flex items-center justify-center text-xs flex-shrink-0">
                                <i class="fas fa-robot"></i>
                            </div>
                            <div class="bg-white dark:bg-slate-800 rounded-2xl rounded-tl-none p-4 shadow-sm border border-slate-100 dark:border-slate-800 text-xs text-slate-700 dark:text-slate-300 leading-relaxed max-w-[80%] whitespace-pre-line">
                                ${aiResponse}
                            </div>
                        </div>
                    `;
                    msgContainer.insertAdjacentHTML('beforeend', aiMsgHtml);
                    msgContainer.scrollTop = msgContainer.scrollHeight;

                    // Save AI Message to session
                    if (session) {
                        session.messages.push({
                            isUser: false,
                            text: aiResponse
                        });
                        saveSessionsToStorage();
                    }
                },
                error: function() {
                    const typingIndicator = document.getElementById(typingId);
                    if (typingIndicator) typingIndicator.remove();

                    const errText = "âŒ **AI Connection Error:** Could not contact the study assistant server. Please check your internet connection or server logs.";
                    const aiMsgHtml = `
                        <div class="flex items-start gap-3">
                            <div class="w-8 h-8 rounded-xl bg-brand-100 dark:bg-brand-950/40 text-brand-600 dark:text-brand-400 flex items-center justify-center text-xs flex-shrink-0">
                                <i class="fas fa-robot"></i>
                            </div>
                            <div class="bg-white dark:bg-slate-800 rounded-2xl rounded-tl-none p-4 shadow-sm border border-slate-100 dark:border-slate-800 text-xs text-red-500 leading-relaxed max-w-[80%]">
                                ${errText}
                            </div>
                        </div>
                    `;
                    msgContainer.insertAdjacentHTML('beforeend', aiMsgHtml);
                    msgContainer.scrollTop = msgContainer.scrollHeight;
                }
            });
        }
    </script>
    @if (User.IsInRole("Admin"))
    {
        <!-- ADMIN CHAT FLOATING INTERFACE -->
        <div class="fixed bottom-[92px] right-6 z-[60]">
            <button onclick="toggleAdminChat()" class="w-14 h-14 bg-gradient-to-tr from-slate-800 to-slate-600 text-white rounded-full flex items-center justify-center shadow-2xl hover:shadow-slate-600/30 transition-all transform hover:-translate-y-1 active:translate-y-0 duration-300 relative group" id="adminChatBtn">
                <i class="fas fa-comments text-xl"></i>
            </button>
        </div>

        <!-- Slide-Out Admin Chat Panel -->
        <div id="adminChatPanel" class="fixed bottom-[92px] right-[92px] w-[380px] sm:w-[420px] h-[550px] bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border border-slate-200/50 dark:border-slate-800/50 rounded-[32px] shadow-2xl flex flex-col overflow-hidden z-[60] scale-95 opacity-0 pointer-events-none transition-all duration-300 transform origin-bottom-right">
            <!-- Header -->
            <div class="p-5 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between shrink-0 bg-white dark:bg-slate-900">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-2xl bg-gradient-to-tr from-slate-600 to-slate-400 p-[2px] shadow-lg">
                        <div class="w-full h-full bg-white dark:bg-slate-900 rounded-[14px] flex items-center justify-center">
                            <i class="fas fa-users text-slate-600 dark:text-slate-400"></i>
                        </div>
                    </div>
                    <div>
                        <h3 class="font-black text-slate-800 dark:text-white tracking-tight leading-tight">Admin Hub</h3>
                        <p class="text-[10px] font-bold text-slate-400 tracking-wider uppercase">Internal Staff Chat</p>
                    </div>
                </div>
                <button onclick="toggleAdminChat()" class="w-8 h-8 rounded-full bg-slate-50 dark:bg-slate-800 flex items-center justify-center text-slate-400 hover:text-slate-700 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Messages Area -->
            <div id="adminChatMessages" class="flex-1 overflow-y-auto p-5 space-y-4 scroll-smooth">
                <!-- Messages will be appended here -->
            </div>

            <!-- Input Area -->
            <div class="p-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 shrink-0">
                <div class="relative flex items-end gap-2">
                    <input type="file" id="adminChatFileInput" class="hidden" onchange="uploadAdminFile(this)" />
                    <button type="button" onclick="document.getElementById('adminChatFileInput').click()" class="w-10 h-10 shrink-0 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 hover:text-slate-600 transition-colors shadow-sm">
                        <i class="fas fa-paperclip"></i>
                    </button>
                    <button type="button" id="adminVoiceBtn" onclick="toggleAdminVoiceRecording()" class="w-10 h-10 shrink-0 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 flex items-center justify-center text-slate-400 hover:text-rose-500 transition-colors shadow-sm">
                        <i class="fas fa-microphone"></i>
                    </button>
                    <div class="flex-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-1 shadow-sm flex items-center focus-within:ring-2 focus-within:ring-slate-500/20 focus-within:border-slate-400 transition-all">
                        <textarea id="adminChatInput" rows="1" class="w-full bg-transparent border-none focus:ring-0 text-sm px-3 py-2 text-slate-700 dark:text-slate-200 placeholder-slate-400 resize-none max-h-32" placeholder="Note to admins..."></textarea>
                        <button onclick="sendAdminMessage()" class="w-8 h-8 shrink-0 rounded-xl bg-slate-800 text-white flex items-center justify-center hover:bg-slate-700 transition-colors ml-1">
                            <i class="fas fa-paper-plane text-xs"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            let adminChatOpen = false;
            let adminChatPolling = null;
            let isAdminRecording = false;
            let adminMediaRecorder;
            let adminAudioChunks = [];
            let adminLastMsgCount = localStorage.getItem('adminChatCount');
            const currentUser = '@(User.Identity?.Name ?? "Admin")';

            async function checkAdminNotifications() {
                if(adminChatOpen) return;
                try {
                    const res = await fetch('/AdminChat/GetMessages');
                    const data = await res.json();
                    if(data.success) {
                        const totalMessages = data.messages.length;
                        
                        // First time opening the page on this browser -> set count and return
                        if(adminLastMsgCount === null) {
                            adminLastMsgCount = totalMessages;
                            localStorage.setItem('adminChatCount', totalMessages);
                            return;
                        }

                        const currentCount = parseInt(adminLastMsgCount);
                        if(totalMessages > currentCount) {
                            const diff = totalMessages - currentCount;
                            let badge = document.getElementById('adminChatBadge');
                            if(!badge) {
                                badge = document.createElement('span');
                                badge.id = 'adminChatBadge';
                                // Removed animate-bounce, kept it static and professional
                                badge.className = 'absolute -top-1 -right-1 w-5 h-5 bg-rose-500 rounded-full border-2 border-white dark:border-slate-900 flex items-center justify-center text-[9px] font-black text-white shadow-lg shadow-rose-500/40 z-10';
                                document.getElementById('adminChatBtn').appendChild(badge);
                            }
                            badge.innerText = diff > 9 ? '9+' : diff;
                        }
                    }
                } catch(e) {}
            }

            setInterval(checkAdminNotifications, 10000); // Check every 10 seconds
            setTimeout(checkAdminNotifications, 2000);   // Check on initial load

            function toggleAdminChat() {
                const panel = document.getElementById('adminChatPanel');
                adminChatOpen = !adminChatOpen;
                
                if (adminChatOpen) {
                    // Side-by-side logic
                    if (typeof isChatOpen !== 'undefined' && isChatOpen) {
                        panel.style.right = '440px';
                    } else {
                        panel.style.right = '92px';
                    }

                    panel.classList.remove('scale-95', 'opacity-0', 'pointer-events-none');
                    panel.classList.add('scale-100', 'opacity-100', 'pointer-events-auto');
                    loadAdminMessages();
                    adminChatPolling = setInterval(loadAdminMessages, 3000);
                } else {
                    panel.classList.remove('scale-100', 'opacity-100', 'pointer-events-auto');
                    panel.classList.add('scale-95', 'opacity-0', 'pointer-events-none');
                    if (adminChatPolling) clearInterval(adminChatPolling);
                }
            }

            async function loadAdminMessages() {
                try {
                    const res = await fetch('/AdminChat/GetMessages');
                    const data = await res.json();
                    if(data.success) {
                        renderAdminMessages(data.messages);

                        adminLastMsgCount = data.messages.length;
                        localStorage.setItem('adminChatCount', adminLastMsgCount);
                        
                        const badge = document.getElementById('adminChatBadge');
                        if(badge) badge.remove();
                    }
                } catch(e) {}
            }

            function renderAdminMessages(messages) {
                const container = document.getElementById('adminChatMessages');
                const isScrolledToBottom = container.scrollHeight - container.clientHeight <= container.scrollTop + 50;

                container.innerHTML = '';
                messages.forEach(msg => {
                    const isMe = msg.SenderName === currentUser;
                    const timeStr = new Date(msg.CreatedAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                    
                    let contentHtml = '';
                    if(msg.FilePath) {
                        if(msg.FileType === 'audio') {
                            contentHtml = `<audio controls src="${msg.FilePath}" class="h-10 mt-1"></audio>`;
                        } else if(msg.FilePath.match(/\.(jpg|jpeg|png|gif|webp)$/i)) {
                            contentHtml = `<a href="${msg.FilePath}" target="_blank"><img src="${msg.FilePath}" class="max-w-[200px] rounded-xl cursor-pointer mt-1 border border-slate-700" /></a>`;
                        } else {
                            contentHtml = `<a href="${msg.FilePath}" target="_blank" class="flex items-center gap-2 text-white bg-black/20 p-2 rounded-lg hover:bg-black/30 mt-1"><i class="fas fa-file"></i> Open File</a>`;
                        }
                    } else {
                        contentHtml = `<p class="text-[13px] leading-relaxed whitespace-pre-wrap">${msg.Message}</p>`;
                    }

                    const bubble = `
                        <div class="flex ${isMe ? 'justify-end' : 'justify-start'} w-full">
                            <div class="flex flex-col ${isMe ? 'items-end' : 'items-start'} max-w-[85%]">
                                <span class="text-[10px] font-bold text-slate-400 mb-1 px-1">${msg.SenderName}</span>
                                <div class="${isMe ? 'bg-slate-800 text-white rounded-[20px] rounded-br-sm' : 'bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-white border border-slate-200 dark:border-slate-700 rounded-[20px] rounded-bl-sm'} p-3 shadow-sm">
                                    ${contentHtml}
                                </div>
                                <span class="text-[9px] font-bold text-slate-400 mt-1 px-1">${timeStr}</span>
                            </div>
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', bubble);
                });

                if(isScrolledToBottom) {
                    container.scrollTop = container.scrollHeight;
                }
            }

            async function sendAdminMessage() {
                const input = document.getElementById('adminChatInput');
                const text = input.value.trim();
                if(!text) return;

                input.value = '';
                
                try {
                    await fetch('/AdminChat/SendMessage', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'message=' + encodeURIComponent(text)
                    });
                    loadAdminMessages();
                } catch(e) {}
            }

            async function uploadAdminFile(input) {
                if(!input.files || input.files.length === 0) return;
                
                const file = input.files[0];
                const formData = new FormData();
                formData.append('file', file);
                formData.append('fileType', 'file');

                input.value = '';

                try {
                    await fetch('/AdminChat/UploadFile', {
                        method: 'POST',
                        body: formData
                    });
                    loadAdminMessages();
                } catch(e) {}
            }

            async function toggleAdminVoiceRecording() {
                const btn = document.getElementById('adminVoiceBtn');
                if(!isAdminRecording) {
                    try {
                        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                        adminMediaRecorder = new MediaRecorder(stream);
                        adminAudioChunks = [];

                        adminMediaRecorder.ondataavailable = e => {
                            if(e.data.size > 0) adminAudioChunks.push(e.data);
                        };

                        adminMediaRecorder.onstop = async () => {
                            const audioBlob = new Blob(adminAudioChunks, { type: 'audio/webm' });
                            const formData = new FormData();
                            formData.append('file', audioBlob, 'voice_record.webm');
                            formData.append('fileType', 'audio');

                            try {
                                await fetch('/AdminChat/UploadFile', {
                                    method: 'POST',
                                    body: formData
                                });
                                loadAdminMessages();
                            } catch(e) {}
                        };

                        adminMediaRecorder.start();
                        isAdminRecording = true;
                        btn.classList.add('bg-rose-500', 'text-white', 'animate-pulse');
                        btn.classList.remove('bg-white', 'dark:bg-slate-800', 'text-slate-400');
                    } catch(e) {
                        alert('Could not access microphone.');
                    }
                } else {
                    adminMediaRecorder.stop();
                    adminMediaRecorder.stream.getTracks().forEach(t => t.stop());
                    isAdminRecording = false;
                    btn.classList.remove('bg-rose-500', 'text-white', 'animate-pulse');
                    btn.classList.add('bg-white', 'dark:bg-slate-800', 'text-slate-400');
                }
            }

            const adminChatInput = document.getElementById('adminChatInput');
            if (adminChatInput) {
                adminChatInput.addEventListener('keydown', function(e) {
                    if(e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        sendAdminMessage();
                    }
                });

                adminChatInput.addEventListener('paste', function(e) {
                    const items = (e.clipboardData || e.originalEvent.clipboardData).items;
                    for (let index in items) {
                        const item = items[index];
                        if (item.kind === 'file') {
                            const blob = item.getAsFile();
                            if (blob) {
                                e.preventDefault(); // Prevent pasting file path text
                                
                                const formData = new FormData();
                                formData.append('file', blob, 'pasted_image.png');
                                formData.append('fileType', 'file');

                                // Visual feedback
                                adminChatInput.placeholder = 'Uploading image...';
                                adminChatInput.disabled = true;

                                fetch('/AdminChat/UploadFile', {
                                    method: 'POST',
                                    body: formData
                                }).then(() => {
                                    loadAdminMessages();
                                }).catch(err => {
                                    console.error("Upload failed", err);
                                }).finally(() => {
                                    adminChatInput.placeholder = 'Note to admins...';
                                    adminChatInput.disabled = false;
                                    adminChatInput.focus();
                                });
                                break; // Only upload the first file to prevent spam
                            }
                        }
                    }
                });
            }
        </script>
    }
}

@if (!isIframe) {
<script>
    // Tab Management Logic
    let tabCounter = 0;
    
    $(document).ready(function() {
        if(typeof Sortable !== 'undefined') {
            new Sortable(document.getElementById('mTabsContainer'), {
                animation: 150,
                filter: '[data-fixed="true"]', // Disable dragging for the fixed home tab
                onMove: function(evt) {
                    return evt.related.dataset.fixed !== "true"; // Prevent dragging others before the fixed home tab
                }
            });
        }
    });
    
    $(document).on('click', '#main-sidebar a', function(e) {
        var href = $(this).attr('href');
        // Ignore dummy links or logout
        if (!href || href === '#' || href.startsWith('javascript:')) return;
        if ($(this).closest('form').length > 0) return; // Ignore links inside forms (like logout)

        e.preventDefault();
        
        var title = $(this).find('span').text().trim() || 'New Tab';
        var icon = $(this).find('i').attr('class') || 'fas fa-file';
        
        openNewTab(title, icon, href);
        
        // Close sidebar on mobile
        if (window.innerWidth < 768) {
            closeSidebar();
        }
    });

    function openNewTab(title, iconClass, url) {
        // Unhide tab container if it's hidden
        $('#mTabsContainer').removeClass('hidden');

        // Check if a tab with this URL already exists
        var existingTabId = null;
        $('.iframe-pane').each(function() {
            var iframeUrl = $(this).attr('src').split('?')[0]; // compare without query params
            var targetUrl = url.split('?')[0];
            if (iframeUrl === targetUrl) {
                existingTabId = $(this).parent().attr('id').replace('tab-pane-', '');
            }
        });

        if (existingTabId) {
            var $iframe = $('#tab-pane-' + existingTabId).find('iframe.iframe-pane');
            var newIframeUrl = url + (url.indexOf('?') > -1 ? '&' : '?') + 'iframe=true';
            if ($iframe.attr('src') !== newIframeUrl) {
                $('#loader-' + existingTabId).show();
                $iframe.attr('src', newIframeUrl);
            }
            switchTab(existingTabId);
            return;
        }

        // Create new tab
        tabCounter++;
        var tabId = 'tab_' + tabCounter;
        
        // Append iframe param
        var iframeUrl = url + (url.indexOf('?') > -1 ? '&' : '?') + 'iframe=true';

        // Add Tab Button
        var tabBtnHtml = `
            <div class="tab-btn flex items-center gap-2 px-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-t-xl text-xs font-bold text-slate-500 hover:text-brand-600 transition-all cursor-pointer shadow-sm min-w-max relative overflow-hidden group" id="tab-btn-${tabId}" onclick="switchTab('${tabId}')">
                <i class="${iconClass}"></i> <span>${title}</span>
                <div class="flex items-center ml-2 opacity-50 group-hover:opacity-100 transition-opacity">
                    <div class="tab-reload w-5 h-5 flex items-center justify-center rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 hover:text-brand-500 transition-colors" onclick="refreshTab(event, '${tabId}')" title="Refresh Tab"><i class="fas fa-sync-alt text-[10px]"></i></div>
                    <div class="tab-close w-5 h-5 flex items-center justify-center rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 hover:text-rose-500 transition-colors ml-1" onclick="closeTab(event, '${tabId}')" title="Close Tab"><i class="fas fa-times text-[10px]"></i></div>
                </div>
            </div>
        `;
        $('#mTabsContainer').append(tabBtnHtml);

        // Add Iframe Pane
        var iframeHtml = `
            <div id="tab-pane-${tabId}" class="tab-pane">
                <div class="w-full h-full flex items-center justify-center absolute inset-0 z-0" id="loader-${tabId}">
                    <span class="loader"></span>
                </div>
                <iframe src="${iframeUrl}" class="iframe-pane relative z-10" onload="document.getElementById('loader-${tabId}').style.display='none'"></iframe>
            </div>
        `;
        $('#mainWorkspace').append(iframeHtml);

        switchTab(tabId);
    }

    function switchTab(tabId) {
        $('.tab-btn').removeClass('active bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400 border-brand-200 dark:border-brand-800 border-b-0')
                     .addClass('bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-500');
                     
        $('.tab-pane').removeClass('active');
        
        $('#tab-btn-' + tabId).addClass('active bg-brand-50 dark:bg-brand-900/20 text-brand-600 dark:text-brand-400 border-brand-200 dark:border-brand-800 border-b-0')
                              .removeClass('bg-white dark:bg-slate-800 border-slate-200 dark:border-slate-700 text-slate-500');
                              
        $('#tab-pane-' + tabId).addClass('active');
    }

    function refreshTab(event, tabId) {
        event.stopPropagation();
        var $pane = $('#tab-pane-' + tabId);
        
        if (tabId === 'home') {
            location.reload(); // If it's the home tab, reload the whole dashboard
            return;
        }

        var $iframe = $pane.find('iframe.iframe-pane');
        var $loader = $pane.find('#loader-' + tabId);
        
        if ($iframe.length) {
            $loader.show();
            var currentSrc = $iframe.attr('src');
            $iframe.attr('src', currentSrc); // Trigger reload
        }
    }

    function closeTab(event, tabId) {
        event.stopPropagation(); // prevent triggering switchTab
        
        var $btn = $('#tab-btn-' + tabId);
        var $pane = $('#tab-pane-' + tabId);
        
        var wasActive = $btn.hasClass('active');
        
        $btn.remove();
        $pane.remove();
        
        if (wasActive) {
            // Switch to the last available tab
            var lastTabId = $('.tab-btn').last().attr('id').replace('tab-btn-', '');
            switchTab(lastTabId);
        }
        
        // Hide container if only Home is left
        if ($('.tab-btn').length <= 1) {
            $('#mTabsContainer').addClass('hidden');
        }
    }
</script>
}

    @RenderSection("Scripts", required: false)
</body>
</html>
