@using Microsoft.AspNetCore.Identity
@inject Exam.Services.IExamService ExamService
@{
    Layout = null;
    bool isIframe = Context.Request.Query.ContainsKey("iframe");

    var userRoles = User.Claims
        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();

    bool HasAccess(string ctrl, string act)
    {
        if (userRoles.Contains("Admin")) return true;
        return ExamService.HasPermissionAsync(userRoles, ctrl, act).GetAwaiter().GetResult();
    }
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth @(isIframe ? "iframe-mode bg-slate-50 dark:bg-slate-950" : "")" translate="no">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google" content="notranslate">
    <title>@ViewBag.Title - Eltarshoubi Control</title>
    <link rel="icon" type="image/png" href="~/images/logo.jpeg" />
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
    
    <!-- Icons & Styling -->
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <script src="~/lib/tailwind/tailwindcss.js"></script>
    <script src="~/lib/sortablejs/Sortable.min.js"></script>
    <link rel="stylesheet" href="~/lib/datatables/css/jquery.dataTables.min.css" />
    
    <script>
        // Theme Helper - Running immediately to avoid FOUC
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        // Iframe Detection - Add class immediately to avoid layout flashing
        if (window.self !== window.top) {
            document.documentElement.classList.add('iframe-mode');
        }

        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#edf4f3',
                            100: '#d1e4e2',
                            200: '#a8cdca',
                            300: '#75b0ab',
                            400: '#48918a',
                            500: '#2a766f',
                            600: '#01443c',
                            700: '#013831',
                            800: '#012c27',
                            900: '#011f1c',
                            950: '#00120f',
                        }
                    },
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
    
    <style>
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; border: 2px solid transparent; background-clip: padding-box; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; border-radius: 10px; border: 2px solid transparent; background-clip: padding-box; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* Mobile Sidebar */
        #sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 45; backdrop-filter: blur(2px); }
        @@media (max-width: 767px) {
            #main-sidebar { transform: translateX(-100%); transition: transform 0.3s ease; }
            body.sidebar-open #main-sidebar { transform: translateX(0) !important; }
            body.sidebar-open #sidebar-overlay { display: block !important; }
        }

        /* DataTables Custom Polish */
        .dataTables_wrapper .dataTables_length {
            @@apply mb-4 sm:mb-0;
        }
        .dataTables_wrapper .dataTables_filter {
            @@apply w-full sm:w-auto mb-4 sm:mb-0 relative;
        }
        .dataTables_wrapper .dataTables_filter label {
            @@apply w-full block relative;
        }
        .dataTables_wrapper .dataTables_filter input {
            @@apply w-full sm:w-72 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl px-5 py-3 pl-10 text-sm outline-none transition-all focus:ring-4 focus:ring-brand-500/10 focus:border-brand-500 !important;
        }
        /* Add search icon via CSS for all DataTables */
        .dataTables_filter label::before {
            content: "\f002";
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            @@apply absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xs z-10;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply border-0 bg-transparent text-slate-600 dark:text-slate-400 font-semibold px-3 py-1.5 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            @@apply bg-brand-500 text-white !important;
        }
        
        table.dataTable.no-footer { border-bottom: 0 !important; }

        /* SaaS Table Style */
        .saas-table { width: 100% !important; min-width: 1000px !important; border-collapse: separate !important; border-spacing: 0 !important; }
        .saas-table thead th { 
            @@apply bg-slate-50 dark:bg-slate-900/80 text-slate-500 dark:text-slate-400 font-bold text-[11px] uppercase tracking-wider py-4 px-6 border-b border-slate-200 dark:border-slate-800 text-left;
        }
        .saas-table tbody td { 
            @@apply py-4 px-6 border-b border-slate-100 dark:border-slate-800/50 text-sm text-slate-700 dark:text-slate-300 transition-colors;
        }
        .dark .saas-table tbody tr { background-color: transparent !important; }
        .dark .saas-table tbody td { background-color: transparent !important; }
        .saas-table tbody tr:hover td { 
            @@apply bg-slate-50/50 dark:bg-slate-800/30;
        }
        .saas-table tbody tr:last-child td { border-bottom: 0; }

        /* DataTables Dark Sync */
        .dark .dataTables_wrapper .dataTables_length, 
        .dark .dataTables_wrapper .dataTables_filter, 
        .dark .dataTables_wrapper .dataTables_info, 
        .dark .dataTables_wrapper .dataTables_processing, 
        .dark .dataTables_wrapper .dataTables_paginate {
            @@apply text-slate-400;
        }
        .dark .dataTables_wrapper .dataTables_paginate .paginate_button {
            @@apply text-slate-400 !important;
        }
        .dark .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            @@apply bg-slate-800 border-slate-700 text-white !important;
        }
        .dark table.dataTable { background-color: transparent !important; }
        .dark .dataTables_wrapper { background-color: transparent !important; }
        /* Iframe Tabs Styles */
        .tab-btn.active::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 2px; background-color: #2a766f; }
        .tab-pane { display: none; width: 100%; height: 100%; }
        .tab-pane.active { display: block; }
        .iframe-pane { width: 100%; height: 100%; border: none; background: transparent; }
        
        html.iframe-mode body { background: transparent !important; }
        
        /* Auto Iframe Detection & Layout Correction */
        html.iframe-mode #main-sidebar { display: none !important; }
        html.iframe-mode header { display: none !important; }
        html.iframe-mode #mTabsContainer { display: none !important; }
        html.iframe-mode main { margin-left: 0 !important; }
        html.iframe-mode #tab-pane-home { padding: 0 !important; }
        html.iframe-mode footer { display: none !important; }
        html.iframe-mode #aiChatBtn { display: none !important; }
        html.iframe-mode #aiChatPanel { display: none !important; }

        /* Green Spinner Loader */
        .loader {
            --color-1: #94a3b8;
            --color-2: #34BB6C;
            --size: 1px;

            transform: rotateZ(45deg);
            perspective: calc(1000 * var(--size));
            border-radius: 50%;
            width: calc(48 * var(--size));
            height: calc(48 * var(--size));
            color: var(--color-1);
            position: relative;
            display: inline-block;
        }
        .dark .loader {
            --color-1: #cbd5e1;
        }
        .loader:before,
        .loader:after {
            content: '';
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            width: inherit;
            height: inherit;
            border-radius: 50%;
            transform: rotateX(70deg);
            animation: 1s spin linear infinite;
        }
        .loader:after {
            color: var(--color-2);
            transform: rotateY(70deg);
            animation-delay: 0.4s;
        }

        @@keyframes rotate {
            0% {
                transform: translate(-50%, -50%) rotateZ(0deg);
            }
            100% {
                transform: translate(-50%, -50%) rotateZ(360deg);
            }
        }

        @@keyframes rotateccw {
            0% {
                transform: translate(-50%, -50%) rotate(0deg);
            }
            100% {
                transform: translate(-50%, -50%) rotate(-360deg);
            }
        }

        @@keyframes spin {
            0%,
            100% {
                box-shadow: 0.2em 0 0 0 currentcolor;
            }
            12% {
                box-shadow: 0.2em 0.2em 0 0 currentcolor;
            }
            25% {
                box-shadow: 0 0.2em 0 0 currentcolor;
            }
            37% {
                box-shadow: -0.2em 0.2em 0 0 currentcolor;
            }
            50% {
                box-shadow: -0.2em 0 0 0 currentcolor;
            }
            62% {
                box-shadow: -0.2em -0.2em 0 0 currentcolor;
            }
            75% {
                box-shadow: 0 -0.2em 0 0 currentcolor;
            }
            87% {
                box-shadow: 0.2em -0.2em 0 0 currentcolor;
            }
        }  
        
        /* Custom SweetAlert2 Animations for smooth premium transitions */
        @@keyframes swal2-custom-show {
            0% {
                transform: scale(0.96);
                opacity: 0;
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }
        @@keyframes swal2-custom-hide {
            0% {
                transform: scale(1);
                opacity: 1;
            }
            100% {
                transform: scale(0.96);
                opacity: 0;
            }
        }
        body .swal2-popup.swal2-show {
            animation: swal2-custom-show 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
        }
        body .swal2-popup.swal2-hide {
            animation: swal2-custom-hide 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 antialiased transition-colors duration-300 overflow-x-hidden">

@if (isIframe) {
    <!-- Iframe Content Only -->
    <div class="w-full h-full min-h-screen overflow-auto">
        <div class="p-4 md:p-8">
            @RenderBody()
        </div>
    </div>
} else {
    <!-- Full Shell -->
    <!-- Sidebar Backdrop (mobile) -->
    <div id="sidebar-overlay" onclick="closeSidebar()"></div>

    <div class="h-screen flex overflow-hidden">
        <!-- Sidebar -->
        <aside id="main-sidebar" class="fixed inset-y-0 left-0 w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 z-50 transition-all duration-300">
            <div class="flex flex-col h-full">
                <!-- Logo Area -->
                <div class="h-20 flex items-center px-8 border-b border-slate-100 dark:border-slate-800/50">
                    <div class="w-10 h-10 bg-white rounded-xl overflow-hidden flex items-center justify-center text-white shadow-lg border border-slate-100 shadow-brand-500/20 mr-3 p-1">
                        <img src="~/images/logo.jpeg" alt="Eltarshoubi Logo" class="w-full h-full object-contain" />
                    </div>
                    <div>
                        <span class="text-xl font-black tracking-tighter block leading-none">ELTARSHOUBI</span>
                        <span class="text-[10px] font-bold text-brand-600 dark:text-brand-400 tracking-[0.2em] uppercase">Control Center</span>
                    </div>
                </div>

                <!-- Nav -->
                <nav class="flex-1 px-4 py-8 space-y-1.5 overflow-y-auto">
                    @{
                        var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
                        var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
                        
                        string linkClass(bool active) => active 
                            ? "flex items-center gap-3 px-4 py-3 rounded-xl bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400 font-bold transition-all"
                            : "flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-white font-medium transition-all";
                    }

                    @if (HasAccess("Admin", "Index") || HasAccess("Admin", "Items") || HasAccess("Admin", "WeeklyExams") || HasAccess("Admin", "WaveExams") || HasAccess("Admin", "Assignments"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 dark:text-slate-600 uppercase tracking-widest px-4 mb-4 mt-6">Main Operations</div>
                        
                        @if (HasAccess("Admin", "Index"))
                        {
                            <a href="@Url.Action("Index", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "index")">
                                <i class="fas fa-chart-line w-5"></i>
                                <span>LMS Overview</span>
                            </a>
                        }
                        
                        @if (HasAccess("Admin", "Items"))
                        {
                            <a href="@Url.Action("Items", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "items")">
                                <i class="fas fa-boxes w-5"></i>
                                <span>Items</span>
                            </a>
                        }
                        
                        @if (HasAccess("Admin", "WeeklyExams") || HasAccess("Admin", "WaveExams"))
                        {
                            <div class="relative">
                                <button type="button" onclick="document.getElementById('matrix-submenu').classList.toggle('hidden'); this.querySelector('.chevron-icon').classList.toggle('rotate-180');" 
                                        class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-white font-medium transition-all @((currentAction == "weeklyexams" || currentAction == "waveexams" || currentAction == "exams") ? "bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400 font-bold" : "")">
                                    <div class="flex items-center gap-3">
                                        <i class="fas fa-file-invoice w-5"></i>
                                        <span>Exam Matrix</span>
                                    </div>
                                    <i class="fas fa-chevron-down text-[10px] chevron-icon transition-transform duration-200 @((currentAction == "weeklyexams" || currentAction == "waveexams" || currentAction == "exams") ? "rotate-180" : "")"></i>
                                </button>
                                <div id="matrix-submenu" class="pl-11 pr-4 py-2 space-y-1 @((currentAction == "weeklyexams" || currentAction == "waveexams" || currentAction == "exams") ? "" : "hidden")">
                                    @if (HasAccess("Admin", "WeeklyExams"))
                                    {
                                        <a href="@Url.Action("WeeklyExams", "Admin")" class="block py-2 text-sm transition-colors @(currentAction == "weeklyexams" ? "text-brand-600 dark:text-brand-400 font-black" : "text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 font-medium")">
                                            <i class="fas fa-calendar-week mr-2 text-[10px]"></i> <span>Weekly Exams</span>
                                        </a>
                                    }
                                    @if (HasAccess("Admin", "WaveExams"))
                                    {
                                        <a href="@Url.Action("WaveExams", "Admin")" class="block py-2 text-sm transition-colors @(currentAction == "waveexams" ? "text-brand-600 dark:text-brand-400 font-black" : "text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 font-medium")">
                                            <i class="fas fa-water mr-2 text-[10px]"></i> <span>Wave Exams</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }

                        @if (HasAccess("Admin", "Assignments"))
                        {
                            <a href="@Url.Action("Assignments", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "assignments")">
                                <i class="fas fa-tasks w-5"></i>
                                <span>Wave Assignments</span>
                            </a>
                        }
                    }

                    @if (HasAccess("Admin", "WeeklyResults") || HasAccess("Admin", "WaveyResults") || HasAccess("Admin", "Students") || HasAccess("Admin", "LiveMonitor") || HasAccess("Admin", "Certificates") || HasAccess("Admin", "PendingRequests") || HasAccess("Admin", "AllUsers") || HasAccess("Admin", "DeactivatedUsers") || HasAccess("Admin", "Waves") || HasAccess("Admin", "Companies") || HasAccess("Admin", "Branches") || HasAccess("Attendance", "Analytics"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 dark:text-slate-600 uppercase tracking-widest px-4 mb-4 mt-8">Personnel Data</div>

                        @if (HasAccess("Admin", "WeeklyResults") || HasAccess("Admin", "WaveyResults") || HasAccess("Admin", "Students"))
                        {
                            <div class="relative">
                                <button type="button" onclick="document.getElementById('analytics-submenu').classList.toggle('hidden'); this.querySelector('.chevron-icon').classList.toggle('rotate-180');" 
                                        class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 hover:text-slate-900 dark:hover:text-white font-medium transition-all @((currentAction == "weeklyresults" || currentAction == "waveyresults" || currentAction == "students") ? "bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400 font-bold" : "")">
                                    <div class="flex items-center gap-3">
                                        <i class="fas fa-chart-pie w-5"></i>
                                        <span>Exam Analytics</span>
                                    </div>
                                    <i class="fas fa-chevron-down text-[10px] chevron-icon transition-transform duration-200 @((currentAction == "weeklyresults" || currentAction == "waveyresults" || currentAction == "students") ? "rotate-180" : "")"></i>
                                </button>
                                <div id="analytics-submenu" class="pl-11 pr-4 py-2 space-y-1 @((currentAction == "weeklyresults" || currentAction == "waveyresults" || currentAction == "students") ? "" : "hidden")">
                                    @if (HasAccess("Admin", "WeeklyResults"))
                                    {
                                        <a href="@Url.Action("WeeklyResults", "Admin")" class="block py-2 text-sm transition-colors @(currentAction == "weeklyresults" ? "text-brand-600 dark:text-brand-400 font-black" : "text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 font-medium")">
                                            <i class="fas fa-calendar-week mr-2 text-[10px]"></i> <span>Weekly Analytics</span>
                                        </a>
                                    }
                                    @if (HasAccess("Admin", "WaveyResults"))
                                    {
                                        <a href="@Url.Action("WaveyResults", "Admin")" class="block py-2 text-sm transition-colors @(currentAction == "waveyresults" ? "text-brand-600 dark:text-brand-400 font-black" : "text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 font-medium")">
                                            <i class="fas fa-water mr-2 text-[10px]"></i> <span>Wave Analytics</span>
                                        </a>
                                    }
                                    @if (HasAccess("Admin", "Students"))
                                    {
                                        <a href="@Url.Action("Students", "Admin")" class="block py-2 text-sm transition-colors @(currentAction == "students" ? "text-brand-600 dark:text-brand-400 font-black" : "text-slate-500 hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400 font-medium")">
                                            <i class="fas fa-globe mr-2 text-[10px]"></i> <span>General Analytics</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        }

                        @if (HasAccess("Admin", "LiveMonitor"))
                        {
                            <a href="@Url.Action("LiveMonitor", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "livemonitor")">
                                <i class="fas fa-broadcast-tower w-5"></i>
                                <span>Live Monitor</span>
                            </a>
                        }
                        
                        @if (HasAccess("Admin", "Certificates"))
                        {
                            <a href="@Url.Action("Certificates", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "certificates")">
                                <i class="fas fa-certificate w-5"></i>
                                <span>Certificates</span>
                            </a>
                        }

                        @if (HasAccess("Admin", "PendingRequests"))
                        {
                            <a href="@Url.Action("PendingRequests", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "pendingrequests")">
                                <i class="fas fa-user-clock w-5"></i>
                                <span>New Come</span>
                            </a>
                        }
                        
                        @if (HasAccess("Admin", "AllUsers"))
                        {
                            <a href="@Url.Action("AllUsers", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "allusers")">
                                <i class="fas fa-users w-5"></i>
                                <span>Personnel Registry</span>
                            </a>
                        }

                        @if (HasAccess("Admin", "DeactivatedUsers"))
                        {
                            <a href="@Url.Action("DeactivatedUsers", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "deactivatedusers")">
                                <i class="fas fa-user-slash w-5"></i>
                                <span>Deactivated</span>
                            </a>
                        }

                        @if (HasAccess("Admin", "Waves"))
                        {
                            <a href="@Url.Action("Waves", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "waves")">
                                <i class="fas fa-water w-5"></i>
                                <span>Batch Cycles</span>
                            </a>
                        }

                        @if (HasAccess("Admin", "Companies"))
                        {
                            <a href="@Url.Action("Companies", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "companies")">
                                <i class="fas fa-building w-5"></i>
                                <span>Companies</span>
                            </a>
                        }

                        @if (HasAccess("Admin", "Branches"))
                        {
                            <a href="@Url.Action("Branches", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "branches")">
                                <i class="fas fa-code-branch w-5"></i>
                                <span>Branches</span>
                            </a>
                        }

                        @if (HasAccess("Attendance", "Analytics"))
                        {
                            <a href="@Url.Action("Analytics", "Attendance")" class="@linkClass(currentController == "attendance" && currentAction == "analytics")">
                                <i class="fas fa-calendar-check w-5"></i>
                                <span>Attendance Trends</span>
                            </a>
                        }
                    }

                    @if (HasAccess("SkillTracks", "Index"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 dark:text-slate-600 uppercase tracking-widest px-4 mb-4 mt-8">Corporate Skills</div>
                        <a href="@Url.Action("Index", "SkillTracks")" class="@linkClass(currentController == "skilltracks" && currentAction == "index")">
                            <i class="fas fa-users-cog w-5"></i>
                            <span>Skill Tracks</span>
                        </a>
                    }

                    @if (HasAccess("Admin", "Roles") || HasAccess("Admin", "Permissions") || HasAccess("Admin", "getallcategories") || HasAccess("Admin", "getallexamtypes") || HasAccess("Admin", "Structure") || HasAccess("Admin", "ManageInstructions"))
                    {
                        <div class="text-[10px] font-bold text-slate-400 dark:text-slate-600 uppercase tracking-widest px-4 mb-4 mt-8">Configuration</div>

                        @if (HasAccess("Admin", "Roles"))
                        {
                            <a href="@Url.Action("Roles", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "roles")">
                                <i class="fas fa-shield-alt w-5"></i>
                                <span>System Roles</span>
                            </a>
                        }
                        @if (HasAccess("Admin", "Permissions"))
                        {
                            <a href="@Url.Action("Permissions", "Admin")" class="@linkClass(currentController == "admin" && currentAction == "permissions")">
                                <i class="fas fa-user-shield w-5"></i>
                                <span>Role Permissions</span>
                            </a>
                        }
