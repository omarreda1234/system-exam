@model IEnumerable<dynamic>
@{ 
    ViewBag.Title = "Skill Tracks - Attendance Analytics"; 
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">
    <div class="sm:flex sm:justify-between sm:items-center mb-8">
        <div>
            <h1 class="text-2xl md:text-3xl text-slate-800 font-bold">Attendance Trends</h1>
            <p class="text-sm text-slate-500 mt-2">Overall analytics for corporate programs and skill tracks.</p>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
            <div class="text-sm font-semibold text-slate-500 uppercase mb-1">Total Sessions</div>
            <div class="text-3xl font-bold text-slate-800">@ViewBag.Stats.TotalSessions</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
            <div class="text-sm font-semibold text-slate-500 uppercase mb-1">Total Checks</div>
            <div class="text-3xl font-bold text-slate-800">@ViewBag.Stats.TotalChecks</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
            <div class="text-sm font-semibold text-emerald-500 uppercase mb-1">Present Count</div>
            <div class="text-3xl font-bold text-emerald-600">@ViewBag.Stats.PresentCount</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5">
            <div class="text-sm font-semibold text-rose-500 uppercase mb-1">Absent Count</div>
            <div class="text-3xl font-bold text-rose-600">@ViewBag.Stats.AbsentCount</div>
        </div>
    </div>

    <div class="bg-white shadow-lg rounded-xl border border-slate-200">
        <div class="px-5 py-4 border-b border-slate-200">
            <h2 class="font-semibold text-slate-800">Recent Attendance Logs</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="table-auto w-full">
                <thead class="text-xs font-semibold uppercase text-slate-500 bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-4 py-3 text-left">Track Name</th>
                        <th class="px-4 py-3 text-left">Session</th>
                        <th class="px-4 py-3 text-left">Date</th>
                        <th class="px-4 py-3 text-left">User</th>
                        <th class="px-4 py-3 text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="text-sm divide-y divide-slate-200">
                    @foreach(var log in Model) {
                        <tr>
                            <td class="px-4 py-3 font-medium text-slate-800">@log.GroupName</td>
                            <td class="px-4 py-3">@log.SessionName</td>
                            <td class="px-4 py-3 text-slate-500">@log.SessionDate.ToString("MMM dd")</td>
                            <td class="px-4 py-3">
                                <div>@log.FullName</div>
                                <div class="text-xs text-slate-400">@log.UserCode</div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                @if(Convert.ToBoolean(log.IsPresent)) {
                                    <span class="bg-emerald-100 text-emerald-600 px-2 py-1 rounded-full text-xs font-bold">Present</span>
                                } else {
                                    <span class="bg-rose-100 text-rose-600 px-2 py-1 rounded-full text-xs font-bold">Absent</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

