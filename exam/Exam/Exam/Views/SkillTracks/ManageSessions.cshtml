@model IEnumerable<dynamic>
@{ 
    ViewBag.Title = "Manage Sessions - " + ViewBag.Track.TrackName; 
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">
    <div class="sm:flex sm:justify-between sm:items-center mb-8">
        <div>
            <h1 class="text-2xl md:text-3xl text-slate-800 font-bold">@ViewBag.Track.TrackName - Sessions</h1>
        </div>
        <div>
            <form action="@Url.Action("CreateSession")" method="post" class="flex gap-2">
                <input type="hidden" name="trackId" value="@ViewBag.Track.Id" />
                <input type="text" id="sessionDatePicker" name="sessionDate" placeholder="dd/mm/yyyy" class="form-input text-sm" required />
                <input type="text" name="sessionName" class="form-input text-sm" placeholder="Session Name" required />
                <button type="submit" class="btn bg-brand-500 hover:bg-brand-600 text-white p-2 rounded-lg text-sm">Create Session</button>
            </form>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach(var session in Model) {
            <div class="bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden hover:shadow-xl transition-shadow relative">
                <div class="p-5 flex flex-col h-full">
                    <div class="flex justify-between items-start mb-2">
                        <h2 class="text-lg font-bold text-slate-800">@session.SessionName</h2>
                        <div class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">@session.PresentCount Attended</div>
                    </div>
                    <div class="text-sm text-slate-500 mb-4">
                        <i class="fas fa-calendar-day mr-2"></i> @session.SessionDate.ToString("MMM dd, yyyy")
                    </div>
                    <div class="mt-auto flex gap-2 pt-4 border-t border-slate-100">
                        <a href="@Url.Action("TakeAttendance", new { sessionId = session.Id })" class="flex-1 text-center bg-indigo-50 hover:bg-indigo-100 text-indigo-600 font-semibold py-2 rounded-lg transition-colors">
                             Take Attendance
                        </a>
                        <form action="@Url.Action("DeleteSession")" method="post" onsubmit="return confirm('Delete this session?');">
                            <input type="hidden" name="sessionId" value="@session.Id" />
                            <input type="hidden" name="trackId" value="@ViewBag.Track.Id" />
                            <button type="submit" class="bg-rose-50 hover:bg-rose-100 text-rose-500 p-2 rounded-lg"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <!-- Flatpickr CSS & JS -->
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script>
        $(function() {
            flatpickr("#sessionDatePicker", {
                altInput: true,
                altFormat: "d/m/Y",
                dateFormat: "Y-m-d",
                altInputClass: "form-input text-sm"
            });
        });
    </script>
}
