<style>
    /* Floating Animation */
    @@keyframes floatAnim {
        0%, 100% { transform: translateY(0px) scale(1); }
        50% { transform: translateY(-10px) scale(1.01); }
    }
    .animate-float {
        animation: floatAnim 6s ease-in-out infinite;
    }

    /* Hover Sweeping Shine Effect */
    @@keyframes shine {
        100% {
            left: 125%;
        }
    }
    .animate-shine {
        position: absolute;
        top: 0;
        left: -75%;
        width: 50%;
        height: 100%;
        background: linear-gradient(to right, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.4) 50%, rgba(255, 255, 255, 0) 100%);
        transform: skewX(-25deg);
    }
    .group:hover .animate-shine {
        animation: shine 1.2s ease-in-out;
    }

    /* Continuous Color Morphing for Title (From Dark Brand Green to Black and Back) */
    @@keyframes morphColor {
        0%, 100% { color: #01443c; text-shadow: 0 0 20px rgba(1, 68, 60, 0.05); }
        50% { color: #0f172a; text-shadow: none; }
    }
    .morph-color {
        animation: morphColor 10s ease-in-out infinite;
    }

    /* Letter reveal effects with padding to preserve 'g' and 'y' tail descenders */
    .academy-reveal-wrapper {
        display: inline-flex;
        align-items: baseline;
        cursor: default;
        padding-bottom: 0.15em;
        margin-bottom: -0.15em;
    }
    .reveal-letter {
        display: inline-block;
        transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        padding-bottom: 0.15em;
        margin-bottom: -0.15em;
    }
    .reveal-rest {
        display: inline-block;
        max-width: 0;
        opacity: 0;
        overflow: hidden;
        white-space: nowrap;
        vertical-align: bottom;
        padding-bottom: 0.15em;
        margin-bottom: -0.15em;
        transition: max-width 3.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 2.8s ease;
    }

    /* Infinite periodic reveal loop: collapses to TA, reveals, holds, and repeats every 20s */
    @@keyframes autoRevealTextLoop {
        0%, 8% { max-width: 0; opacity: 0; }
        18%, 92% { max-width: 320px; opacity: 1; }
        98%, 100% { max-width: 0; opacity: 0; }
    }
    .reveal-rest {
        animation: autoRevealTextLoop 20s cubic-bezier(0.16, 1, 0.3, 1) infinite;
    }
</style>

