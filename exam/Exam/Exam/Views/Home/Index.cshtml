                        </div>
                        
                        <!-- Simple Slider Navigation Dots -->
                        <div class="absolute bottom-6 right-6 flex items-center gap-2 z-10">
                            <div class="w-2 h-2 rounded-full bg-white shadow shadow-black/20 transition-all duration-300 opacity-100 scale-125" id="dot-0"></div>
                            <div class="w-2 h-2 rounded-full bg-white shadow shadow-black/20 transition-all duration-300 opacity-50 hover:opacity-100 cursor-pointer" id="dot-1" onclick="goToSlide(1)"></div>
                            <div class="w-2 h-2 rounded-full bg-white shadow shadow-black/20 transition-all duration-300 opacity-50 hover:opacity-100 cursor-pointer" id="dot-2" onclick="goToSlide(2)"></div>
                        </div>
                    </div>
                    
                    <script>
                        let currentSlide = 0;
                        const totalSlides = 3;
                        let slideInterval;

                        function goToSlide(index) {
                            if(index === currentSlide) return;
                            
                            // Hide current
                            document.querySelector(`[data-slide="${currentSlide}"]`).classList.remove('opacity-100');
                            document.querySelector(`[data-slide="${currentSlide}"]`).classList.add('opacity-0');
                            document.getElementById(`dot-${currentSlide}`).classList.remove('opacity-100', 'scale-125');
                            document.getElementById(`dot-${currentSlide}`).classList.add('opacity-50');

                            // Show new
                            currentSlide = index;
                            document.querySelector(`[data-slide="${currentSlide}"]`).classList.remove('opacity-0');
                            document.querySelector(`[data-slide="${currentSlide}"]`).classList.add('opacity-100');
                            document.getElementById(`dot-${currentSlide}`).classList.remove('opacity-50');
                            document.getElementById(`dot-${currentSlide}`).classList.add('opacity-100', 'scale-125');
                            
                            resetInterval();
                        }

                        function nextSlide() {
                            let next = (currentSlide + 1) % totalSlides;
                            goToSlide(next);
                        }

                        function resetInterval() {
                            clearInterval(slideInterval);
                            slideInterval = setInterval(nextSlide, 5000); // Change every 5 seconds
                        }

                        // Start slider
                        resetInterval();
                    </script>
