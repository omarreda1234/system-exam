@model IEnumerable<Exam.DTOs.ExamDto>
@{
    ViewData["Title"] = "Neural Access Terminal";
    var shift = ViewBag.UserShift as Exam.DTOs.UserShiftDto;
    var now = DateTime.Now;
    var currentTime = now.TimeOfDay;
}

<div class="max-w-7xl mx-auto px-6 pt-12 pb-24">
    <!-- Header Section -->
    <div class="mb-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 border border-brand-100 mb-4">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
                    </span>
                    <span class="text-[10px] font-black uppercase text-brand-600 tracking-widest">Student Portal</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight">My Exams & Assessments</h2>
                <p class="text-sm font-medium text-slate-500 mt-2">Welcome back, @User.Identity.Name! | Server Time: @now.ToString("hh:mm tt")</p>
            </div>

            <div class="flex flex-wrap items-center gap-4 w-full md:w-auto">
                <a href="@Url.Action("Index", "Assignments")" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg shadow-indigo-600/20 transition-all flex items-center gap-2">
                    <i class="fas fa-tasks text-xs"></i> Solve Training Assignments
                </a>

                @if (shift != null)
                {
                    <div class="bg-white border border-slate-200 px-6 py-4 rounded-2xl shadow-sm flex items-center gap-4 sm:gap-6">
                        <div class="text-left md:text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Assigned Shift</p>
                            <p class="text-sm font-black text-slate-800">@(shift.ShiftName?.ToUpper() ?? "N/A")</p>
                        </div>
                        <div class="w-px h-8 bg-slate-200"></div>
                        <div class="text-left md:text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Shift Window</p>
                            <p class="text-sm font-black text-brand-600">@shift.StartTime.ToString(@"hh\:mm") — @shift.EndTime.ToString(@"hh\:mm")</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Exams Grid -->
    <div>
    @if (Model == null || !Model.Any())
    {
        <div class="bg-white border border-slate-200 rounded-[32px] p-16 text-center shadow-sm max-w-2xl mx-auto mt-10">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-50 rounded-full mb-6 border border-slate-100">
                <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            </div>
            <h3 class="text-xl font-black text-slate-900 tracking-tight mb-2">No Active Assignments</h3>
            <p class="text-sm text-slate-500 font-medium">You currently have no exams scheduled. Please check back later or contact your instructor.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var e in Model)
            {
                var inExamWindow = now >= e.ExamDate && now <= e.EndTime;
                var inShift = true;
                
                if (shift != null && shift.ShiftId > 0)
                {
                    var sStart = shift.StartTime;
                    var sEnd = shift.EndTime;

                    if (sStart <= sEnd)
                    {
                        inShift = (currentTime >= sStart && currentTime <= sEnd);
                    }
                    else
                    {
                        // Midnight cross
                        inShift = (currentTime >= sStart || currentTime <= sEnd);
                    }
                }

                var canStart = inExamWindow && inShift;
                
                <div class="bg-white border border-slate-200 rounded-[32px] overflow-hidden shadow-sm hover:shadow-xl hover:border-brand-500/20 transition-all duration-300 flex flex-col group relative">
                    <!-- Status Header -->
                    <div class="p-6 border-b border-slate-50 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-br from-slate-50 to-white opacity-50"></div>
                        <div class="relative flex justify-between items-start">
                            <div>
                                <span class="bg-slate-100 text-slate-500 px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest">Exam ID: @e.ExamId.ToString("D4")</span>
                            </div>
                            @if(canStart) {
                                <div class="flex items-center gap-1.5 bg-emerald-50 text-emerald-600 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm">
                                    <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></div> Open
                                </div>
                            } else {
                                <div class="bg-slate-100 text-slate-500 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest shadow-sm">
                                    Locked
                                </div>
                            }
                        </div>
                        
                        <h4 class="text-xl font-black text-slate-900 tracking-tight mt-6 group-hover:text-brand-600 transition-colors">@e.ExamTitle</h4>
                        <p class="text-sm text-slate-500 mt-2 line-clamp-2 font-medium">@(string.IsNullOrEmpty(e.ExamDescription) ? "No additional details provided for this assessment." : e.ExamDescription)</p>
                    </div>

                    <!-- Details Body -->
                    <div class="p-6 flex-1 space-y-4 bg-slate-50/50">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Availability Window</p>
                                <p class="text-sm font-bold text-slate-700">@e.ExamDate.ToString("MMM dd, hh:mm tt") — @e.EndTime.ToString("MMM dd, hh:mm tt")</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 shrink-0">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Time Limit</p>
                                <p class="text-sm font-bold text-slate-700">@e.DurationInMinutes Minutes</p>
                            </div>
                        </div>
                    </div>

                    <!-- Action Footer -->
                    <div class="p-6 pt-0 bg-slate-50/50">
                        @if (canStart)
                        {
                            <button type="button" onclick="showInstructions('@e.ExamId', '@Url.Action("Start", "Exams", new { id = e.ExamId })')"
                               class="w-full bg-brand-600 hover:bg-brand-700 text-white py-4 rounded-2xl font-black uppercase text-xs tracking-widest transition-all shadow-xl shadow-brand-500/20 flex items-center justify-center gap-3 group/btn hover:-translate-y-0.5">
                                Start Examination
                                <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            </button>
                        }
                        else
                        {
                            <button disabled class="w-full bg-slate-200 text-slate-500 py-4 rounded-2xl font-black uppercase text-xs tracking-widest cursor-not-allowed">
                                @if(!inShift) {
                                    <span class="flex items-center justify-center gap-2">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                        Outside Your Shift
                                    </span>
                                } else if(now < e.ExamDate) {
                                    <span>Wait For Window</span>
                                } else {
                                    <span>Window Closed</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
    </div>
</div>

@section Scripts {
    <script>
        async function showInstructions(examId, startUrl) {
            Swal.fire({
                title: 'Syncing Protocol...',
                didOpen: () => { Swal.showLoading(); }
            });

            try {
                const response = await fetch('@Url.Action("GetInstructions", "Home")');
                const data = await response.json();
                
                Swal.fire({
                    title: '<div class="flex flex-col items-center gap-2 pt-4 px-6"><i class="fas fa-scroll text-brand-500 text-3xl mb-2"></i><span class="text-xl font-black uppercase tracking-widest text-slate-800">Examination Protocol</span></div>',
                    html: `
                        <div class="text-left px-6 py-4">
                            <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6 mb-6 max-h-[400px] overflow-y-auto custom-scrollbar">
                                <div class="text-sm font-medium text-slate-600 leading-relaxed whitespace-pre-wrap">${data.instructions}</div>
                            </div>
                            
                            <label class="flex items-start gap-4 cursor-pointer group p-4 rounded-2xl hover:bg-brand-50/50 transition-all border border-transparent hover:border-brand-100" onclick="setTimeout(() => { document.getElementById('agreeCheckbox').checked = !document.getElementById('agreeCheckbox').checked; }, 0); event.preventDefault();">
                                <div class="relative flex shrink-0 mt-0.5">
                                    <input type="checkbox" id="agreeCheckbox" class="w-5 h-5 accent-brand-600 cursor-pointer shadow-sm rounded bg-white" onclick="event.stopPropagation();">
                                </div>
                                <div>
                                    <p class="text-xs font-black text-slate-800 uppercase tracking-tight">I certify full understanding</p>
                                    <p class="text-[10px] font-bold text-slate-400 mt-0.5">I have meticulously reviewed the instructions and acknowledge the terms of this assessment.</p>
                                </div>
                            </label>
                        </div>
                    `,
                    showCancelButton: true,
                    confirmButtonText: 'Initiate Access <i class="fas fa-bolt ml-2"></i>',
                    cancelButtonText: 'Return',
                    width: '600px',
                    customClass: {
                        popup: 'rounded-[32px] border border-slate-100 shadow-2xl',
                        confirmButton: 'bg-slate-900 hover:bg-slate-800 text-white font-black py-4 px-10 rounded-2xl transition-all shadow-xl shadow-slate-900/10 text-xs uppercase tracking-widest',
                        cancelButton: 'bg-white hover:bg-slate-50 text-slate-400 font-bold py-4 px-10 rounded-2xl transition-all text-xs uppercase'
                    },
                    buttonsStyling: false,
                    preConfirm: () => {
                        const checkbox = document.getElementById('agreeCheckbox');
                        if (!checkbox.checked) {
                            Swal.showValidationMessage('Certification is mandatory and required to proceed');
                            return false;
                        }
                        return true;
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Initiating Security Protocol...',
                            text: 'Please wait while we establish your exam session.',
                            allowOutsideClick: false,
                            didOpen: () => { Swal.showLoading(); }
                        });
                        window.location.href = startUrl;
                    }
                });
            } catch (err) {
                Swal.fire('Connection Error', 'Failed to retrieve examination protocol.', 'error');
            }
        }

        // ===== BLOCK BROWSER / ANDROID BACK from Student Portal =====
        history.pushState(null, '', window.location.href);
        window.addEventListener('popstate', function () {
            // Re-push so we stay on the page while the dialog is open
            history.pushState(null, '', window.location.href);

            Swal.fire({
                title: 'Leave Portal?',
                html: '<p class="text-sm text-slate-500">Are you sure you want to navigate away from<br><strong class="text-slate-800">My Assignments</strong>?</p>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, Leave',
                cancelButtonText: 'Stay Here',
                reverseButtons: true,
                customClass: {
                    popup: 'rounded-3xl border border-slate-200 shadow-2xl',
                    confirmButton: 'bg-rose-600 hover:bg-rose-700 text-white font-bold py-3 px-8 rounded-xl transition-all ml-3 text-sm',
                    cancelButton:  'bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 px-8 rounded-xl transition-all text-sm'
                },
                buttonsStyling: false
            }).then(function (result) {
                if (result.isConfirmed) {
                    history.back();
                }
                // Cancelled → stay on MyAssignments
            });
        });
        // ============================================================
    </script>
}
