@model Exam.DTOs.ForgotPasswordDTO
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="min-h-[70vh] flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Recover Password</h1>
            <p class="mt-2 text-sm font-bold text-slate-500 uppercase tracking-widest">Enter your email to receive recovery link</p>
        </div>

        <div class="bg-white border border-slate-200 rounded-[32px] shadow-xl shadow-slate-200/50 overflow-hidden relative">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-indigo-600"></div>
            <div class="p-8 sm:p-10">
                <form asp-action="ForgotPassword" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-rose-600 text-[11px] font-bold uppercase tracking-widest bg-rose-50 p-3 rounded-xl border border-rose-100 text-center"></div>
                    <div class="space-y-1.5">
                        <label asp-for="Email" class="block text-xs font-bold text-slate-700 uppercase tracking-widest ml-1">Account Email</label>
                        <input asp-for="Email" class="block w-full border-slate-200 bg-slate-50 text-slate-900 font-medium rounded-xl shadow-sm focus:border-indigo-500 focus:bg-white focus:ring-indigo-500 px-4 py-3.5 transition-colors" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-rose-500 text-[10px] font-bold tracking-widest uppercase ml-1 block mt-1"></span>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-4 rounded-xl transition-all text-sm font-black uppercase tracking-widest shadow-lg shadow-indigo-500/30 hover:-translate-y-0.5 active:translate-y-0">
                            Send Reset Link
                        </button>
                    </div>
                </form>
                <div class="mt-8 text-center">
                    <a asp-action="Login" class="text-xs font-bold text-slate-400 hover:text-indigo-600 uppercase tracking-widest transition-colors"><i class="fas fa-arrow-left mr-2"></i> Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
